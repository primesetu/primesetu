INSERT INTO Class12Combo (Class1Cd,Class2Cd,Billable,SizeGroup,RetailMarkUp,DealerMarkUp,PrefVendorId,ProdTaxType,
SuperClass1,SuperClass2,IsServiceCombo,IsConsignmentItem,Vauid,Vactr,VatermId,VacompCode) 
select distinct class1cd,class2cd,1,0,0,0,'NA','NA','NA','NA',0,0,'SUPER',
(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select TXT from sysparam where paramcode = 'COMPANYCODE') 
from ItemMaster where class1cd+':'+class2cd not in (select class1cd+':'+class2cd from class12combo)
-GO-
update class12combo set sizegroup=0 where (sizegroup is null or sizegroup='')
-GO-
update class12combo set SUPERCLASS1='NA' where (SUPERCLASS1 is null or SUPERCLASS1='')
-GO-
update class12combo set SUPERCLASS2='NA' where (SUPERCLASS2 is null or SUPERCLASS2='')
-GO-
Declare @VaCtr as int
Declare @Vacompany as varchar(10) 
Set @VaCtr = (select intg from sysparam where paramcode = 'VaSysCounter')
Set @Vacompany = (select TXT from sysparam where paramcode = 'COMPANYCODE')  
Insert Into Genlookup (Recid,Code,Descr,flag,number,Vauid,Vactr,VatermId,VacompCode) 
SELECT 1,CLASS1CD,CLASS1CD,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE CLASS1CD NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 1) Union 
SELECT 2,CLASS2CD,CLASS2CD,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE CLASS2CD NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 2) Union 
SELECT 65,ANALCODE1,ANALCODE1,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE1 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 65) Union 
SELECT 66,ANALCODE2,ANALCODE2,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE2 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 66) Union 
SELECT 67,ANALCODE3,ANALCODE3,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE3 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 67) Union 
SELECT 68,ANALCODE4,ANALCODE4,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE4 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 68) Union 
SELECT 69,ANALCODE5,ANALCODE5,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE5 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 69) 
-GO-
Declare @VaCtr as int
Declare @Vacompany as varchar(10) 
Set @VaCtr = (select intg from sysparam where paramcode = 'VaSysCounter')
Set @Vacompany = (select TXT from sysparam where paramcode = 'COMPANYCODE')  
Insert Into Genlookup (Recid,Code,Descr,flag,number,Vauid,Vactr,VatermId,VacompCode) 
SELECT 54,PRODTAXTYPE,PRODTAXTYPE,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE PRODTAXTYPE NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 54) Union
SELECT 70,SRCTAXTYPE,SRCTAXTYPE,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE SRCTAXTYPE NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 70) Union
SELECT 53,SIZEGROUP,SIZEGROUP,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM CLASS12COMBO WHERE SIZEGROUP NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 53) Union
SELECT 53,SIZEGROUPID,SIZEGROUPID,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM SIZECAT WHERE SIZEGROUPID NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 53) Union
SELECT 51,SUPERCLASS1,SUPERCLASS1,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM CLASS12COMBO WHERE SUPERCLASS1 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 51) Union 
SELECT 52,SUPERCLASS2,SUPERCLASS2,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM CLASS12COMBO WHERE SUPERCLASS2 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 52)  
-GO-
