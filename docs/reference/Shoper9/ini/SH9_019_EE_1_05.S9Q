<s9qsqlblk>
  <s9qScriptid>S9Q_019_1_0006</s9qScriptid> 
  <s9qtitle> New table FOR Billing components</s9qtitle> 
  <s9qpgmtype>I</s9qpgmtype>  
  <s9qpgmtype>L</s9qpgmtype>  
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>1</s9qRunMultiple> 
  <s9qQryType>DDL</s9qQryType> 
  <s9qScript>
IF EXISTS (SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'[dbo].[TransactionComponentsDtls]') AND type in (N'U'))
drop table [TransactionComponentsDtls]
-GO-
CREATE TABLE [dbo].[TransactionComponentsDtls](
	[Trntype] [int] NOT NULL,
	[TrnSubtype] [int] NULL,
	[FieldCode] [varchar](50) NOT NULL,
	[Srlno] [int] NOT NULL,
	[EventId] [varchar](50) Not NULL,
	[EventKeycode] [int] NULL,
	[ComponentDesc] [varchar](256) NULL,
	[OrderOfexec] [int] NULL,
	[CompStatus] [varchar](1) NULL) ON [PRIMARY]
-GO-
ALTER TABLE [dbo].[TransactionComponentsDtls]WITH NOCHECK ADD 
	CONSTRAINT [PK_SalesComponentsDtls] PRIMARY KEY  CLUSTERED 
	(
		[Trntype] ASC,
		[FieldCode] ASC,
		[Srlno] ASC,
		[EventId] ASC
	)  ON [PRIMARY] 
-GO-
IF EXISTS (SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'[dbo].[EventExtnReturnFieldDtls]') AND type in (N'U'))
drop table [EventExtnReturnFieldDtls]
-GO-
  </s9qScript>
</s9qsqlblk>


