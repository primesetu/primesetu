<S9QQRYTYPE>DML</S9QQRYTYPE>
<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
<S9QSCRIPT>

Delete from dbo.Genlookup where recid = 0 and code = '13100'
-GO-
Delete from dbo.Genlookup where recid = '13100'
-GO-
Delete from dbo.GenlookUpExtd where recid = '13100'
-GO-
Insert dbo.GenlookUp Select 0,'13100','Stock Take Mode','N',null,null,null,null,null
-GO-
