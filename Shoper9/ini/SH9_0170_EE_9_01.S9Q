UPDATE CLASS12COMBO SET SizeGroup = t.SizeGroupId,                                                             
PrefVendorId=t.VendorCode,ProdTaxType=t.ProdTaxType,SuperClass1=left(t.SuperClass1,16),                                                             
SuperClass2=left(t.SuperClass2,16),VActr = @vaCtr
From TmpPriceMaster as t inner join CLASS12COMBO as c                          
on t.CLASS1CD = c.CLASS1CD and t.CLASS2CD = c.CLASS2CD                           
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
         
UPDATE SUBCLASS2CAT SET SubClass2Desc=t.SubClass2Desc,VActr = @vaCtr FROM TmpPriceMaster as t inner join SUBCLASS2CAT as sc2                          
on t.Class1Cd =sc2.Class1Cd and t.Class2Cd =sc2.Class2Cd and t.SubClass2Cd=sc2.SUBCLASS2CD                           
IF (@@ERROR <> 0)                           
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
         
Set @RecCount = 0                              
SELECT @RecCount = count(*) FROM SYSPARAM WHERE PARAMCODE = 'AllowSizeCatToBeUpdatedInBackendImport'                           
if @RecCount = 0                              
begin                             
 UPDATE SIZECAT SET SizeGroupId = t.SizeGroupID,                         
 SizeGroupSrlno=t.SizeGroupSrlno,VActr = @vaCtr FROM TmpPricemaster as t inner join SIZECAT as sz on                          
 t.CLASS1CD = sz.CLASS1CD  and t.CLASS2CD = sz.CLASS2CD and t.SIZECD =sz.Sizecd                           
        IF (@@ERROR <> 0)                                     
        BEGIN                                     
         GOTO ErrorHandle                                     
        END                                     
end                                  
Set @RecCount = 0                              
SELECT @RecCount = count(*) FROM SYSPARAM WHERE PARAMCODE = 'AllowSizeCatToBeUpdatedInBackendImport' and Boolean=1            
if @RecCount > 0                          
begin                             
 UPDATE SIZECAT SET sizegroupid = t.SizeGroupID,
 SizeGroupSrlno=t.SizeGroupSrlno,VActr = @vaCtr FROM TmpPricemaster as t inner join SIZECAT as sz on                          
 t.CLASS1CD = sz.CLASS1CD  and t.CLASS2CD = sz.CLASS2CD and t.SIZECD =sz.Sizecd                           
        IF (@@ERROR <> 0)                                     
        BEGIN                                     
         GOTO ErrorHandle                                     
        END                                     
end               
