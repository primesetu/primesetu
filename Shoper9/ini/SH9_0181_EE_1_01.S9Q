create table [DBO].franchiseelog(idtype varchar(32)NOT NULL,shoperdt datetime NOT NULL,srlno int default 0 NOT NULL,trnstype varchar(10)NOT NULL,paymode varchar(16)NOT NULL,
trnsamt money default 0,VAUid	varchar	(32),VActr int,VATermId varchar(32),VACompCode varchar(16),CONSTRAINT PK_franchiseelog PRIMARY KEY (idtype,shoperdt,srlno,trnstype,paymode))
-GO-
create table [DBO].franmismatchlog(shoperdt datetime NOT NULL,paymode varchar(16)NOT NULL,logopbal money default 0,trnopbal money default 0,
VAUid varchar(32),VActr	int,VATermId varchar(32),VACompCode	varchar(16),CONSTRAINT PK_franmismatchlog PRIMARY KEY (shoperdt,paymode))
-GO-
create table [DBO].Bakfranchiseelog(idtype varchar(32),shoperdt datetime,srlno int,
trnstype varchar(10),paymode varchar(16),trnsamt money,VAUid varchar(32),VActr int,
VATermId varchar(32),VACompCode varchar(16),UpdFlag Varchar(1))
-GO-
create table [DBO].Bakfranmismatchlog(shoperdt datetime,paymode varchar(16),logopbal money,
trnopbal money,VAUid varchar(32),VActr int,VATermId varchar(32),VACompCode varchar(16),UpdFlag Varchar(1))
-GO-
