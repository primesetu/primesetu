<s9qsqlblk>
  <s9qScriptid>S9Q_019_0_0002</s9qScriptid> 
  <s9qtitle>Alter Statement to Tally interface mapping table</s9qtitle> 
  <s9qpgmtype>I</s9qpgmtype>  
  <s9qpgmtype>L</s9qpgmtype>  
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>1</s9qRunMultiple> 
  <s9qQryType>DDL</s9qQryType> 
  <s9qScript>
ALTER TABLE TallyMapSettingInfo ADD isCustomerInfoInRemarks VARCHAR(1) NOT NULL  default 0
-GO-
INSERT INTO Genlookup (recid,code,descr) values (299,'P901495','Shoper Update Version No:')
-GO-
Update Genlookup set Descr = (select 'Shoper Update Version No:9.0.1.9495' + ' ;system date:' + convert(varchar(20),getdate(),105) + ' ;shoper date:' + (select convert(varchar(20),dt,105) from sysparam where paramcode ='SHOPERSysDt') ) where code = 'P901495' and recid = 299
-GO-
INSERT INTO [dbo].VersionDtls VALUES (14,getdate(),'9','1.9','A','P901495','',1,'.','')
-GO-
insert into genlookup values (5000,3,'SR580200.ClassTransBrowse','',0,'Super',1,'.','') 
-GO-
update GenLookUp set Number = (select isnull(MAX(RecNo),5000000) from MailingList) where Recid = 101 and code = 'MAILNO'
-GO-
update genlookup set descr='SR580100' where recid='16000' and code like '%+04' and descr='SR519700'
-GO-
  </s9qScript>
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptid>S9Q_019_0_0003</s9qScriptid> 
  <s9qtitle></s9qtitle> 
  <s9qpgmtype>I</s9qpgmtype>  
  <s9qpgmtype>L</s9qpgmtype>  
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>1</s9qRunMultiple> 
  <s9qQryType>DDL</s9qQryType> 
  <s9qScript>
IF EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[BakTallyPrintConfigHeader]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
DROP TABLE BakTallyPrintConfigHeader
-GO-
IF EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[BakTallyPrintConfigDetails]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
DROP TABLE BakTallyPrintConfigDetails
-GO-
SELECT * INTO BakTallyPrintConfigHeader FROM TallyPrintConfigHeader
-GO-
SELECT * INTO BakTallyPrintConfigDetails FROM TallyPrintConfigDetails
-GO-
DROP TABLE [dbo].[TallyPrintConfigHeader]
-GO-
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[TallyPrintConfigHeader]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[TallyPrintConfigHeader](
	[Terminal] [varchar](256) NOT NULL,
	[TrnType] [int] NOT NULL,
	[ConfigName] [varchar](256) NOT NULL,
	[ReportName] [varchar](256) NULL,
	[TcpLocation] [varchar](256) NULL,
	[IsActive] [bit] NULL,
	[PrinterName] [varchar](256) NULL,
	[PrintMode] [varchar](256) NULL,
	[PrintPreview] [bit] NULL,
	[NoOfCopies] [int] NULL,
	[IsCustom] [tinyint] NULL
	CONSTRAINT [PK_TallyPrintConfigHeader] PRIMARY KEY CLUSTERED
	(
		Terminal, TrnType, ConfigName
	)
)
END
-GO-
DROP TABLE [dbo].[TallyPrintConfigDetails]
-GO-
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[TallyPrintConfigDetails]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[TallyPrintConfigDetails](
	[ConfigName] [varchar](256) NOT NULL,
	[ParamName] [varchar](256) NOT NULL,
	[ParamValue] [varchar](256) NULL, 
	[DataType] [varchar](16) NULL
	CONSTRAINT [PK_TallyPrintConfigDetails] PRIMARY KEY CLUSTERED
	(
		ConfigName, ParamName
	)
	
)
END
-GO-
TRUNCATE TABLE [dbo].[TallyPrintConfigHeader]
-GO-
