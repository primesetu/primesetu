  </s9qScript>		
</s9qsqlblk>


<S9QSQLBLK>
	<S9QSCRIPTID>S9Q_020_2_0006</S9QSCRIPTID>
	<S9QTITLE>Stock-Data Migration File for 2.0-Prefix</S9QTITLE>
	<S9QPGMTYPE>D</S9QPGMTYPE>
	<S9QVERSION>*</S9QVERSION>
	<S9QENVIRONMENT>P</S9QENVIRONMENT>
	<S9QRUNMULTIPLE>0</S9QRUNMULTIPLE>
	<S9QSEVERITY>3</S9QSEVERITY>
	<S9QQRYTYPE>DML</S9QQRYTYPE>
	<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
	<S9QSCRIPT>

BEGIN TRANSACTION
BEGIN
	Declare @Month int, @SysDate datetime, @VACtr Int, @VACompCd VarChar(256) 

	Select @Month = Convert(Int, Txt) from Sysparam Where Paramcode = 'YearEndMonthNo' 

	Select @SysDate = Convert(DateTime ,Dt) from Sysparam Where Paramcode = 'SHOPERSysDt' 

	Select @VACtr = Convert(Int, Intg) from Sysparam Where Paramcode = 'VaSysCounter' 

	Select @VACompCd = Convert(Varchar(256), Txt) from Sysparam Where Paramcode = 'CompanyCode' 

	IF EXISTS (Select * from prefixmaster where BasePrefix <> '<CTRLPX>' and trntype IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')) BEGIN Delete from prefixmaster where BasePrefix <> '<CTRLPX>' and trntype IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') END 

	IF EXISTS (Select * from prefixtrnno where ActualPrefix <> '<CTRLPX>' and trntype IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')) BEGIN Delete from prefixtrnno where ActualPrefix <> '<CTRLPX>' and trntype IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') END 

	IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixMaster]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixMaster] 

	IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixTrnNo]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixTrnNo] 

	IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixGenlookUp]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixGenlookUp] 

	Select * Into TmpPrefixGenlookUp from GenLookUp where Recid = 102 AND SUBSTRING(Code,1,4) IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') AND (Code <> ' ' or Code <> '') AND LEN(Code) > 5 

	Insert Into TmpPrefixGenlookUp (Recid,Code,Descr,Flag,Number,VAUid,VACtr,VATermId,VACompCode) Select Distinct '102' as Recid, Convert(Varchar(10),H.TrnType)+'+'+H.DocNoPrefix as Code,'' as Descr,'' as Flag,0 as Number,'Super' as VAUid,0 as Vactr,'.' as VATermId,'ABC' as VACompCode from StkTrnHdr H Where Not Exists (Select 1 from TmpPrefixGenlookUp A Where A.Code=Convert(Varchar(10),H.TrnType)+'+'+H.DocNoPrefix) AND H.TrnType in (1100,1200,1400,1500,2710,2720,2730,2740,2200,2300,2400,2500,1710,1720,1730,1740) AND Len(Convert(Varchar(10),H.TrnType)+'+'+H.DocNoPrefix) > 5 

	Select * Into TmpPrefixMaster from PrefixMaster where 1 = 2 

	ALTER TABLE TmpPrefixMaster ADD KeyCol INT NOT NULL IDENTITY 

	Select * Into TmpPrefixTrnNo from PrefixTrnNo where 1 = 2 

	Insert Into TmpPrefixMaster (Trntype,OPId,TerminalGroupId,SrlNo,Prefix,BasePrefix,Suffix,IsActive,ResetRequired,VaUID,VaCtr,VaTermID,VaCompCode) SELECT SUBSTRING(CODE,1,4) as TrnType,1 as OpId,'<<ALLNODE>>' as TerminalGroupId,0 as SrlNo,'' as Prefix,SUBSTRING(CODE,CHARINDEX('+',CODE,1)+1,LEN(CODE)-7) AS BasePrefix,REVERSE(SUBSTRING(REVERSE(CODE),1,2)) as Suffix,1 as IsActive,1 as ResetRequired,'Super' as VaUID,1 as VaCtr,'.' as VATermID,'NULL' as VCompCode FROM TmpPrefixGenlookUp WHERE RECID = 102 AND SUBSTRING(CODE,1,4) IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') AND ISNUMERIC(SUBSTRING(REVERSE(CODE),1,2))= 1 

	Update TmpPrefixGenlookUp Set Vatermid = 'Y' WHERE RECID = 102 AND SUBSTRING(CODE,1,4) IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') AND ISNUMERIC(SUBSTRING(REVERSE(CODE),1,2))= 1 

	Insert Into TmpPrefixMaster (Trntype,OPId,TerminalGroupId,SrlNo,Prefix,BasePrefix,Suffix,IsActive,ResetRequired,VaUID,VaCtr,VaTermID,VaCompCode) SELECT SUBSTRING(CODE,1,4) as TrnType,1 as OpId,'<<ALLNODE>>' as TerminalGroupId,0 as SrlNo,'' as Prefix,SUBSTRING(CODE,CHARINDEX('+',CODE,1)+1,LEN(CODE)-6) as BasePrefix,REVERSE(SUBSTRING(REVERSE(CODE),1,1)) as Suffix,1 as IsActive,1 as ResetRequired,'Super' as VaUID,1 as VaCtr,'.' as VATermID,'NULL' as VCompCode FROM TmpPrefixGenlookUp WHERE RECID = 102 AND SUBSTRING(CODE,1,4) IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') AND ISNUMERIC(SUBSTRING(REVERSE(CODE),1,1))= 1 AND VaTermId <> 'Y' 

	Update TmpPrefixGenlookUp Set Vatermid = 'Y' WHERE RECID = 102 AND SUBSTRING(CODE,1,4) IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') AND ISNUMERIC(SUBSTRING(REVERSE(CODE),1,1))= 1 AND VaTermId <> 'Y'

	Update TmpPrefixMaster set Srlno = T2.NewSrlNo From TmpPrefixMaster T1,(select *,(select COUNT(*) from TmpPrefixMaster as B where B.Trntype=A.trntype And B.KeyCol<=A.KeyCol) as NewSrlNo from TmpPrefixMaster as A) T2 where T1.Trntype=T2.trntype and T1.BasePrefix=T2.Baseprefix and T1.Suffix=T2.Suffix 

	IF NOT EXISTS (Select Distinct TrnType from StkTrnHdr Where trntype IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740'))
		BEGIN
			BEGIN
				Update TT Set Suffix = PrefixVAl.PrefixVAl from TmpPrefixMaster TT,
				(Select CASE 
					WHEN MONTH(@SysDate) BETWEEN @Month+1 AND 12 THEN RIGHT(DATEPART(yy , @SysDate) , 2) 
					WHEN MONTH(@SysDate) BETWEEN 1 AND @Month+1 THEN RIGHT(DATEPART(yy ,@SysDate) - 1 , 2) 
				END As PrefixVAl) As PrefixVAl where TT.TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')
			END

			Insert Into TmpPrefixTrnNo (TrnType,ActualPrefix,DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode) Select TrnType as TrnTye,Prefix+BasePrefix+Suffix as ActualPrefix,0 as DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode from TmpPrefixMaster Where Trntype in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') 

			Insert Into PrefixMaster (Trntype,OPId,TerminalGroupId,SrlNo,Prefix,BasePrefix,Suffix,IsActive,ResetRequired,VaUID,VaCtr,VaTermID,VaCompCode) Select Trntype,OPId,TerminalGroupId,SrlNo,Prefix,BasePrefix,Suffix,IsActive,ResetRequired,VaUID,VaCtr,VaTermID,VaCompCode from TmpPrefixMaster 

			Insert Into PrefixTrnNo (TrnType,ActualPrefix,DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode) Select TrnType,ActualPrefix,DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode from TmpPrefixTrnNo 

			Update T1 Set T1.DocNumber = T2.Number from PrefixTrnNo T1 INNER JOIN (Select code,IsNull(Number,1) as Number from Genlookup where RECID = 101 AND code in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')) T2 ON T1.ActualPrefix = '<CTRLPX>' and T1.Trntype = T2.Code 

			Update T1 Set T1.DocNumber = T2.Number from PrefixTrnNo T1 INNER JOIN (Select code,IsNull(Number,1) as Number from Genlookup where RECID = 102 AND SubString(code,1,4) in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')) T2 ON T1.ActualPrefix <> '<CTRLPX>' and T1.Trntype = SubString(T2.Code,1,4)  

			IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixMaster]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixMaster] 

			IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixTrnNo]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixTrnNo] 

			IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixGenlookUp]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixGenlookUp] 

			Update PrefixMaster Set Vactr = @VACtr,VaCompCode = @VACompCd where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') 

			Update PrefixTrnNo Set Vactr = @VACtr, VaCompCode = @VACompCd where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') 
		END
	ELSE
		BEGIN
			Insert Into TmpPrefixTrnNo (TrnType,ActualPrefix,DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode) Select TrnType as TrnTye,Prefix+BasePrefix+Suffix as ActualPrefix,0 as DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode from TmpPrefixMaster Where Trntype in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') 

			Insert Into PrefixMaster (Trntype,OPId,TerminalGroupId,SrlNo,Prefix,BasePrefix,Suffix,IsActive,ResetRequired,VaUID,VaCtr,VaTermID,VaCompCode) Select Trntype,OPId,TerminalGroupId,SrlNo,Prefix,BasePrefix,Suffix,IsActive,ResetRequired,VaUID,VaCtr,VaTermID,VaCompCode from TmpPrefixMaster 

			Insert Into PrefixTrnNo (TrnType,ActualPrefix,DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode) Select TrnType,ActualPrefix,DocNumber,IsActive,VaUID,VaCtr,VaTermID,VaCompCode from TmpPrefixTrnNo 

			IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixMaster]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixMaster] 

			IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixTrnNo]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixTrnNo] 

			IF EXISTS (select * from sysobjects where id = object_id(N'[dbo].[TmpPrefixGenlookUp]') and OBJECTPROPERTY(id, N'IsUserTable') = 1) drop table [dbo].[TmpPrefixGenlookUp] 

			Update T1 Set T1.DocNumber = T2.Number from PrefixTrnNo T1 INNER JOIN (Select code,IsNull(Number,1) as Number from Genlookup where RECID = 102 AND SubString(code,1,4) in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')) T2 ON T1.ActualPrefix <> '<CTRLPX>' and T1.Trntype = SubString(T2.Code,1,4) and (T1.TrnType+'+'+T1.ActualPrefix) = T2.Code 

			Update T1 Set T1.DocNumber = T2.TrnCtrlNo from PrefixTrnNo T1 INNER JOIN (Select TrnType,MAX(IsNull(TrnCtrlNo,0))+1 as TrnCtrlNo from StkTrnHdr where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') group by TrnType) T2 ON T1.ActualPrefix = '<CTRLPX>' and T1.Trntype = T2.TrnType 

			Update T1 Set T1.DocNumber = T2.DocNo from PrefixTrnNo T1 INNER JOIN (Select TrnType,DocNoPrefix,MAX(IsNull(DocNo,0))+1 as DocNo from StkTrnHdr where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') group by TrnType,DocNoPrefix) T2 ON T1.Trntype = T2.TrnType and T1.ActualPrefix = T2.DocNoPrefix 

			IF EXISTS (Select  TrnType,COUNT(*) from PrefixTrnNo Where TrnType IN ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') and isactive = 1 group by TrnType) 
			BEGIN
				Update TT Set IsActive = 0 from PrefixMaster TT,
				(Select CASE 
					WHEN MONTH(@SysDate) BETWEEN @Month+1 AND 12 THEN RIGHT(DATEPART(yy , @SysDate) , 2) 
					WHEN MONTH(@SysDate) BETWEEN 1 AND @Month+1 THEN RIGHT(DATEPART(yy ,@SysDate) - 1 , 2) 
				END As PrefixVAl) As PrefixVAl where TT.TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') and PrefixVAl.PrefixVAl <> TT.Suffix And BasePrefix <> '<CTRLPX>'

				Update B Set B.IsActive = A.IsActive from PrefixMaster A,PrefixTrnNo B Where A.Trntype in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740') and	A.TrnType = B.Trntype and (A.Prefix+A.BasePrefix+A.Suffix) = B.ActualPrefix
			END
			Update PrefixMaster Set Vactr = @VACtr,VaCompCode = @VACompCd where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')

			Update PrefixTrnNo Set Vactr = @VACtr, VaCompCode = @VACompCd where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')
		END
END
COMMIT TRANSACTION

	</s9qScript>		
</s9qsqlblk>