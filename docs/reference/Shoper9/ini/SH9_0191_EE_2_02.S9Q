<s9qsqlblk>
  <s9qScriptID>S9Q_0191_2_0002</s9qScriptID>
  <s9qtitle>Version Details</s9qtitle>
  <s9qpgmtype>I</s9qpgmtype>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>1</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>

Update StkTrnDtls Set OrdDocType = POType,OrdEntSubSrlNo = EntrySubSrlNo from PurchOrdDtl, StkTrnDtls where PurchOrdDtl.PoNoPrefix = StkTrnDtls.OrdDocNoPrefix and PurchOrdDtl.POCtrlNo = StkTrnDtls.OrdDocNo and PurchOrdDtl.EntrySrlNo = StkTrnDtls.OrdEntSrlNo and StkTrnDtls.OrdDocType = 0 and StkTrnDtls.OrdEntSubSrlNo = 0
-GO-
Update PurchOrdDtl Set VActr = (Select Intg from SysParam Where ParamCode = 'Vasyscounter'), PurchOrdDtl.RcvdQty = (Select isnull(sum(PhyQtyIn),0) From StkTrnDtls Where PurchOrdDtl.POType = StkTrnDtls.OrdDocType      and   PurchOrdDtl.PoNoPrefix = StkTrnDtls.OrdDocNoPrefix and PurchOrdDtl.POCtrlNo = StkTrnDtls.OrdDocNo and PurchOrdDtl.EntrySrlNo = StkTrnDtls.OrdEntSrlNo and PurchOrdDtl.EntrySubSrlNo = StkTrnDtls.OrdEntSubSrlNo) from StkTrnDtls, PurchOrdDtl Where PurchOrdDtl.POType = StkTrnDtls.OrdDocType      and   PurchOrdDtl.PoNoPrefix = StkTrnDtls.OrdDocNoPrefix and PurchOrdDtl.POCtrlNo = StkTrnDtls.OrdDocNo and PurchOrdDtl.EntrySrlNo = StkTrnDtls.OrdEntSrlNo and PurchOrdDtl.EntrySubSrlNo = StkTrnDtls.OrdEntSubSrlNo
-GO-
