CREATE TABLE GS1Dtls (SlNO  INT NOT NULL,GS1IdKey VarChar(16),GS1CompanyPrefix VarChar(32) NOT NULL,StartingNo INT NOT NULL,EndingNo INT NOT NULL,Class1Cd Varchar(16) NOT NULL,Class2Cd Varchar(16) NOT NULL,SubClass1Cd Varchar(16) ,SubClass2Cd Varchar(16) ,SizeCd Varchar(16) ,TotalBarCodesPresent int,TotalBarCodesUsed int,TotalBarCodesAvbl int,LastNoUsed int,Active int,DefaultPfx int, BarCodeLen int,DateInsert datetime,Remarks Varchar(255),VAUid Varchar(32),VActr int,VATermId Varchar(32),VACompCode Varchar(16))
-GO-
ALTER TABLE GS1Dtls ADD CONSTRAINT  PK_GS1Dtls  PRIMARY KEY   (SlNO,GS1CompanyPrefix,StartingNo,EndingNo,Class1Cd,Class2Cd)
-GO-
Alter Table CurrencyCat Add DecimalDesc Varchar(256)
-GO-
Alter Table CurrencyCat Add CurSymbol Varchar(64)
-GO-
create table CurrencyDenomination (Code varchar(16) not null, SrlNo Int not null,DenomCap varchar(64),Denominations Int,SmallestUnit Int,Active Int,ImageId varchar(64),VAUid varchar(32),VActr int,VATermId varchar(32),VACompCode varchar(16))
-GO-
ALTER TABLE [dbo].[CurrencyDenomination] WITH NOCHECK ADD CONSTRAINT [PK_CurrencyDenomination] PRIMARY KEY CLUSTERED (	[Code],	[SrlNo])  ON [PRIMARY]
-GO-
create table BakCurrencyDenomination (Code varchar(16) not null, SrlNo Int not null,DenomCap varchar(64),Denominations Int,SmallestUnit Int,Active Int,ImageId varchar(64),VAUid varchar(32),VActr int,VATermId varchar(32),VACompCode varchar(16),UpdFlag varchar(1))
