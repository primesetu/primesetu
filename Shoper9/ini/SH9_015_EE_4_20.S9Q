<s9qsqlblk>
  <s9qScriptID>S9Q_015_4_1002</s9qScriptID>
  <s9qtitle>Menu Correction for tally interface</s9qtitle>
  <s9qpgmtype>I</s9qpgmtype>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>M</s9qenvironment>
  <s9qRunMultiple>1</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>
	
update VAMENU set MNUCAP = 'Manage Master Changes' where MNUNAME ='TALLY INTERFACE UTILITIES' and (PGMOPT = 5 or PGMOPT =6)
-GO-
</s9qScript>		
</s9qsqlblk>
