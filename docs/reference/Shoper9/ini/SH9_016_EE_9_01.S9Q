-GO-
ALTER TABLE [dbo].[ItemReClassConfig] WITH NOCHECK ADD CONSTRAINT [PK_ItemReClassConfig] PRIMARY KEY CLUSTERED ([FLDID])  ON [PRIMARY]
-GO-
Create Table [BakItemReClassConfig] (FldId VarChar(16) Not Null,FldDBColName Varchar(128),FldTerminology VarChar(128),FldDefaultName VarChar(128),FilterOrder Int,FilterFlag Int,ReplaceOrder Int,ReplaceFlag Int,LoookupDtls VarChar(128),FilterDataType VarChar(64),ReplaceDataType VarChar(64),DataLen Int,FilterControlType VarChar(64),ReplaceControlType VarChar(64),AttribType int,PreviewFlag Int,AllowedOp Varchar(16),AllowedInSwap Varchar(16),VAUid Varchar(32),VActr int,VATermId Varchar(32),VACompCode vARCHAR(16),UpdFlag varchar(1))
