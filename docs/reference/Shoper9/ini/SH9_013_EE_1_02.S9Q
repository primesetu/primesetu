<s9qScript>


-- 1300 Net Value Mismatch
IF OBJECT_ID('tempdb..#valuemismatch') IS NOT NULL BEGIN drop table #valuemismatch END
select stktrndtls.trntype, stktrndtls.trnctrlno,stktrndtls.entsrlno,docentvalue - (docentnetvalue + docenttotdisc + docentdedns - docentaddons) as Diffval into #valuemismatch  from stktrndtls,stktrnhdr where stktrndtls.trntype=stktrnhdr.trntype and stktrndtls.TrnCtrlNo=stktrnhdr.TrnCtrlNo and stktrnhdr.SHOPERDBVER=730 and docentvalue <> ( docentnetvalue + docenttotdisc + docentdedns - docentaddons) and stktrndtls.trntype = 1300 and stktrndtls.TrnCtrlNo not in (select distinct(TrnCtrlNo) from stktrnaddldtls where trntype=1300) 
-GO-
update stktrndtls set  docentnetvalue=(docentnetvalue-abs(Diffval)) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and #valuemismatch.entsrlno= stktrndtls.entsrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval < 0
-GO-
update stktrndtls set docentaddons=(docentaddons+abs(Diffval)) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval < 0 and stktrndtls.entsrlno=(select min(entsrlno) from stktrndtls as std where std.trntype=#valuemismatch.trntype and std.trnctrlno=#valuemismatch.trnctrlno and std.docentaddons >0) 
-GO-
update stktrndtls set  docentnetvalue=(docentnetvalue + Diffval) from  #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and #valuemismatch.entsrlno= stktrndtls.entsrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval > 0
-GO-
update stktrndtls set  docentdedns=(docentdedns+Diffval) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval > 0 and stktrndtls.entsrlno=(select min(entsrlno) from stktrndtls as std where std.trntype=#valuemismatch.trntype and std.trnctrlno=#valuemismatch.trnctrlno and std.docentdedns >0) 
-GO-
update stktrndtls set docentnetvalue= (docentvalue-docenttotdisc+docentaddons-docentdedns+DocEntAddonsTax) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and stktrndtls.trntype=1300 
-GO-
update stktrnhdr set  totdocaddons=std.docentaddons from stktrndtls as std ,#valuemismatch where #valuemismatch.trntype=stktrnhdr.trntype and #valuemismatch.trnctrlno=stktrnhdr.trnctrlno  and #valuemismatch.trntype=std.trntype and #valuemismatch.trnctrlno=std.trnctrlno and std.docentaddons >0 and stktrnhdr.trntype=1300 and stktrnhdr.SHOPERDBVER=730 
-GO-
update stktrnhdr set  totdocdedns=std.docentdedns from stktrndtls as std ,#valuemismatch where #valuemismatch.trntype=stktrnhdr.trntype and #valuemismatch.trnctrlno=stktrnhdr.trnctrlno  and #valuemismatch.trntype=std.trntype and #valuemismatch.trnctrlno=std.trnctrlno and std.docentdedns >0 and stktrnhdr.trntype=1300 and stktrnhdr.SHOPERDBVER=730
-GO-

</s9qScript>
</s9qsqlblk>

<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0051</s9qScriptID>
<s9qtitle>cORRECTING THE Net value mismatch between STD AND STH TABLE (TRANSACTION TYPE 1600 VOID ) </s9qtitle>
