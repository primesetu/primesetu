Create Table [ItemReClassHeader] (IRCId VarChar(16) Not Null,IRCStatus Int,ApprovedFlag Int,CreatedAt Int,ShoperDate Datetime,SystemDate Datetime,Narration VarChar(256),FilterFlag Int,RunMultiple Int,RunInImport Int,RunInMenu Int,RunInDayBegin Int,RunSQLStmt Int,AtHO Int,AtHORunNo Int,AtHOLastRunDate Datetime,AtPOS Int,AtPOSRunNo Int,AtPOSLastRunDate Datetime,AtReplPOS Int,AtReplPOSRunNo Int,AtReplPOSLastRunDate Datetime,VAUid Varchar(32),VActr Int,VATermId Varchar(32),VACompCode VARCHAR(16))
