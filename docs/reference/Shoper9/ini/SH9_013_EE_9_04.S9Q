<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0010</s9qScriptid> 
  <s9qtitle>Catalogue Module: Replace NULL value with Blank/Space Scripts</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>

Update dbo.Itemmaster Set Class1Cd='NA'  Where  Class1Cd is NULL
-GO-
Update dbo.Itemmaster Set Class2Cd='NA'  Where  Class2Cd is NULL
-GO-
Update dbo.Itemmaster Set SubClass1Cd='NA'  Where  SubClass1Cd is NULL
-GO-
Update dbo.Itemmaster Set SubClass2Cd='NA'  Where  SubClass2Cd is NULL
-GO-
Update dbo.Itemmaster Set SizeCd='NA'  Where  SizeCd is NULL
-GO-
Update dbo.Itemmaster Set ItemDesc='NA'  Where  ItemDesc is NULL
-GO-
update dbo.SalesTaxCat Set TaxRevisionId='0'  Where  TaxRevisionId is null or TaxRevisionId = ''
-GO-
Update dbo.Class12Combo Set PrefVendorId=''  Where  PrefVendorId is NULL
-GO-
Update dbo.Class12Combo Set AltVendorId1=''  Where  AltVendorId1 is NULL
-GO-
Update dbo.Class12Combo Set AltVendorId2=''  Where  AltVendorId2 is NULL
-GO-
Update dbo.Class12Combo Set AltVendorId3=''  Where  AltVendorId3 is NULL
-GO-
Update dbo.Class12Combo Set SuperClass1=''  Where  SuperClass1 is NULL
-GO-
Update dbo.Class12Combo Set SuperClass2=''  Where  SuperClass2 is NULL
-GO-
Update dbo.SizeCat Set SizeGroupId='NA'  Where  SizeGroupId is NULL
-GO-
Update dbo.SizeCat Set ConvSizeCd='NA'  Where  ConvSizeCd is NULL
-GO-
Update dbo.SalesTaxCat Set TaxDesc=''  Where  TaxDesc is NULL
-GO-
Update dbo.SalesTaxCat Set T1Name=''  Where  T1Name is NULL
-GO-
Update dbo.SalesTaxCat Set T1Descr=''  Where  T1Descr is NULL
-GO-
Update dbo.SalesTaxCat Set T1Type=''  Where  T1Type is NULL
-GO-
Update dbo.SalesTaxCat Set T1DerivedFormula=''  Where  T1DerivedFormula is NULL
-GO-
Update dbo.SalesTaxCat Set T1CompOn=''  Where  T1CompOn is NULL
-GO-
Update dbo.SalesTaxCat Set T2Name=''  Where  T2Name is NULL
-GO-
Update dbo.SalesTaxCat Set T2Descr=''  Where  T2Descr is NULL
-GO-
Update dbo.SalesTaxCat Set T2Type=''  Where  T2Type is NULL
-GO-
Update dbo.SalesTaxCat Set T2DerivedFormula=''  Where  T2DerivedFormula is NULL
-GO-
Update dbo.SalesTaxCat Set T2CompOn=''  Where  T2CompOn is NULL
-GO-
Update dbo.SalesTaxCat Set T3Name=''  Where  T3Name is NULL
-GO-
Update dbo.SalesTaxCat Set T3Descr=''  Where  T3Descr is NULL
-GO-
Update dbo.SalesTaxCat Set T3Type=''  Where  T3Type is NULL
-GO-
Update dbo.SalesTaxCat Set T3DerivedFormula=''  Where  T3DerivedFormula is NULL
-GO-
Update dbo.SalesTaxCat Set T3CompOn=''  Where  T3CompOn is NULL
-GO-
Update dbo.SalesTaxCat Set T4Name=''  Where  T4Name is NULL
-GO-
Update dbo.SalesTaxCat Set T4Descr=''  Where  T4Descr is NULL
-GO-
Update dbo.SalesTaxCat Set T4Type=''  Where  T4Type is NULL
-GO-
Update dbo.SalesTaxCat Set T4DerivedFormula=''  Where  T4DerivedFormula is NULL
-GO-
Update dbo.SalesTaxCat Set T4CompOn=''  Where  T4CompOn is NULL
-GO-
Update dbo.SalesTaxCat Set T5Name=''  Where  T5Name is NULL
-GO-
Update dbo.SalesTaxCat Set T5Descr=''  Where  T5Descr is NULL
-GO-
Update dbo.SalesTaxCat Set T5Type=''  Where  T5Type is NULL
-GO-
Update dbo.SalesTaxCat Set T5DerivedFormula=''  Where  T5DerivedFormula is NULL
-GO-
Update dbo.SalesTaxCat Set T5CompOn=''  Where  T5CompOn is NULL
-GO-
Update dbo.SalesTaxCat Set PreTaxFormName=''  Where  PreTaxFormName is NULL
-GO-
