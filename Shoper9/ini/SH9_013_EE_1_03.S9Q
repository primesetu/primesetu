<s9qenvironment>P</s9qenvironment>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>
Update Sysparam set Intg=1 where paramcode='CashRcptPayoutBillFormType'
-GO-
insert into sysparam (id,Descr,Paramcode,Intg,opt) values ('SR7-0901-0000313','Pay Slip Printing Type','PaySlipPrintingType','1','I')
-GO-
insert into sysparamextd (Id,Paramcode,Fixed,changed,category,catdescr,Disporder ) values ('SR7-0901-0000313','PaySlipPrintingType','Variable','0','02. Franchisee','This Gives Franchisee Parameters','7')
-GO-
Insert into sysparam (Id, Descr, ParamCode, Intg, Opt) Values('SR1-0901-0000315','Expected Transaction-Slip Printing Type','ExpTrnSlipPrintingType',1,'I')
-GO-
</s9qScript>
</s9qsqlblk>


