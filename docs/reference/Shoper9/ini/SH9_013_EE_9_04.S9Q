-GO-
UPDATE dbo.SUBCLASS2CAT SET SUBCLASS2DESC = SUBCLASS2CD  Where  (SUBCLASS2DESC IS NULL OR SUBCLASS2DESC = '')

  </s9qScript>
</s9qsqlblk>


<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0011</s9qScriptid> 
  <s9qtitle>Catalogue Module: Fix SalesTaxCat and PromoMnHeader Scripts</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>
	
UPDATE dbo.SalesTaxCat set T1Type='F', T1CompOn='P1#VALUE AFTER DISCOUNT'
-GO-
UPDATE dbo.SalesTaxCat set T2Type='F', T2CompOn='T1#TAX COMPONENT1'  Where  T2COMPON='1'
-GO-
UPDATE dbo.SalesTaxCat set T3Type='F', T3CompOn='T1#TAX COMPONENT1'  Where  T3COMPON='1'
-GO-
UPDATE dbo.SalesTaxCat set T3Type='F', T3CompOn='T2#TAX COMPONENT2'  Where  T3COMPON='2'
-GO-
UPDATE dbo.SalesTaxCat set T4Type='F', T4CompOn='T1#TAX COMPONENT1'  Where  T4COMPON='1'
-GO-
UPDATE dbo.SalesTaxCat set T4Type='F', T4CompOn='T2#TAX COMPONENT2'  Where  T4COMPON='2'
-GO-
UPDATE dbo.SalesTaxCat set T4Type='F', T4CompOn='T3#TAX COMPONENT3'  Where  T4COMPON='3'
-GO-
UPDATE dbo.SalesTaxCat set T5Type='F', T5CompOn='T1#TAX COMPONENT1'  Where  T5COMPON='1'
-GO-
UPDATE dbo.SalesTaxCat set T5Type='F', T5CompOn='T2#TAX COMPONENT2'  Where  T5COMPON='2'
-GO-
UPDATE dbo.SalesTaxCat set T5Type='F', T5CompOn='T3#TAX COMPONENT3'  Where  T5COMPON='3'
-GO-
UPDATE dbo.SalesTaxCat set T5Type='F', T5CompOn='T4#TAX COMPONENT4'  Where  T5COMPON='4'
-GO-
delete from dbo.salesfactors where validityENDdt < (select dt from dbo.sysparam where paramcode='SHOPERSysDt')
-GO-
Update dbo.SalesFactors set AppPt=3  Where  type in (7,6) and Apppt=1
-GO-
update dbo.salesfactors set stockno = null  Where  stockno ='-N..A-'
-GO-
UPDATE dbo.SIZECAT SET SIZEGROUPID = A.SIZEGROUP FROM dbo.CLASS12COMBO A,dbo.SIZECAT B WHERE A.CLASS1CD = B.CLASS1CD AND A.CLASS2CD = B.CLASS2CD AND A.SIZEGROUP <> B.SIZEGROUPID
-GO-
Update dbo.PosPaymodes set ISEnabled=0  Where  PayModeType=3
-GO-
Update dbo.PosPaymodes set ISEnabled=0  Where  PayModeType=9 
-GO-
update dbo.PromoMnHeader  set   DiscRateAmtInd = (CASE WHEN A.ITEMDISCPERCENT = 0 AND A.ITEMDISCAMOUNT = 0 then 1 when A.ITEMDISCPERCENT > 0 AND A.ITEMDISCAMOUNT = 0 then 1 when A.ITEMDISCPERCENT = 0 AND A.ITEMDISCAMOUNT > 0 then 2 end) from dbo.PROMOMNITEMLVLDISCDTLS As A where PromoMnHeader.SalesPromoCode = A.SalesPromoCode and PromoMnHeader.DefinitionType=1 and PromoMnHeader.DefinitionLevel=1 and (PromoMnHeader.DiscRateAmtInd Is Null or PromoMnHeader.DiscRateAmtInd =0)
-GO-
update dbo.PromoMnHeader  set   DiscRateAmtInd = (CASE WHEN A.BILLDISCPERCENT = 0 AND A.BILLDISCAMOUNT = 0 then 1 when A.BILLDISCPERCENT > 0 AND A.BILLDISCAMOUNT = 0 then 1 when A.BILLDISCPERCENT = 0 AND A.BILLDISCAMOUNT > 0 then 2 end) from dbo.PROMOMNBILLLVLDISCDTLS As A where PromoMnHeader.SalesPromoCode = A.SalesPromoCode and PromoMnHeader.DefinitionType=1 and PromoMnHeader.DefinitionLevel=2 and (PromoMnHeader.DiscRateAmtInd Is Null or PromoMnHeader.DiscRateAmtInd =0)
-GO-
update dbo.PromoMnHeader  set  DiscRateAmtInd = 0 where DefinitionType=2 and (PromoMnHeader.DiscRateAmtInd Is Null or PromoMnHeader.DiscRateAmtInd =0)
-GO-
update dbo.PromoMnHeader  set   DiscRateAmtInd = 0 where DefinitionType=1 and DefinitionLevel=1 and ItemLvlDiscountType In (2,3,4,5) and (PromoMnHeader.DiscRateAmtInd Is Null or PromoMnHeader.DiscRateAmtInd =0)
-GO-
update dbo.PromoMnHeader  set   DiscRateAmtInd = 0 where DefinitionType=1 and DefinitionLevel=2 and BillLvlDiscountType=0 and (PromoMnHeader.DiscRateAmtInd Is Null or PromoMnHeader.DiscRateAmtInd =0)
-GO-
Update dbo.GenLookup Set  Flag ='1' Where RecId = 9050 and Code ='4' 
-GO-
update dbo.genlookup set  descr = 'Buy X Get Discount On (X+1)th' where recid=9050 and code ='4'

</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0012</s9qScriptid> 
  <s9qtitle>Catalogue Module: Update Genlookup For P901128 Build</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>

Begin Transaction
Insert into dbo.Genlookup (recid,code,descr) values (299,'P901128','Shoper Update Version No:')
Update dbo.Genlookup set Descr = (select 'Shoper Update Version No:9.0.1.9128' + ' ;system date:' + convert(varchar(20),getdate(),105) + ' ;shoper date:' + (select convert(varchar(20),dt,105) from dbo.sysparam where paramcode ='SHOPERSysDt') ) where code = 'P901128' and recid = 299
Update dbo.Genlookup Set Vactr=(select intg from dbo.sysparam where paramcode = 'VaSysCounter') where code = 'P901128' and recid = 299
Commit Transaction
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0013</s9qScriptid> 
  <s9qtitle>Catalogue Module: PgmWiseFeatureDtls Scripts</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
