<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0056</s9qScriptID>
<s9qtitle>UPDATING THE TAX PERCENTAGE FOR 1600 RECORDS </s9qtitle>
<s9qpgmtype>L</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>
update stktrndtls set 
stdTaxComp1Per = (select StdTaxComp1Per from stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ), 
stdTaxComp2Per = (select StdTaxComp2Per from stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ),
stdTaxComp3Per = (select StdTaxComp3Per from stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ),
stdTaxComp4Per = (select StdTaxComp4Per from stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ),
stdTaxComp5Per = (select StdTaxComp5Per from stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo )
 from stktrndtls std where trntype =1600
-GO-
</s9qScript>
</s9qsqlblk>
