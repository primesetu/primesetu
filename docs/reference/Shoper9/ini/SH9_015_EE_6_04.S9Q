CREATE TABLE [dbo].[PrintNodeTrnConfigMaster](
	[NodeID] [varchar](16) NOT NULL,	
	[TrnTypeIdentifier] [int] NOT NULL,
	[TrnTypeIDCaption] [varchar](256) NOT NULL,
	[TrnTypeGroup] [varchar](256) NOT NULL,	
	[DisplayOrder] [int] NOT NULL,
	[LinkedRefID] [varchar](256) NOT NULL,
	[TrnLinkedRefExecutionOrder] [int] NOT NULL,
	[PrintPreference] [int] NOT NULL,
	[IsActive] [int] NOT NULL,	
	[VAUId] [varchar](256) NULL,
	[VACtr] [int] NULL CONSTRAINT [DF_PrintNodeTrnConfigMaster_VACtr]  DEFAULT ((0)),
	[VATermId] [varchar](256) NULL,
	[VACompCode] [varchar](256) NULL,
	[ShoperDBVer] [int] NULL CONSTRAINT [DF_PrintNodeTrnConfigMaster_SHOPERDBVER]  DEFAULT ((730))
) ON [PRIMARY]
