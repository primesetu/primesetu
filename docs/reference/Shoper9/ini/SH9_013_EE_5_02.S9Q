  EXEC (@SQUERY)               
  SET @SQUERY = 'UPDATE TMPPRICEMASTER SET ANALDESC32 = A.DESCR FROM '+@DBNAME+'.GENLOOKUP AS A,TMPPRICEMASTER AS B WHERE A.CODE = B.ANALCODE32 AND A.RECID = 7026'              
