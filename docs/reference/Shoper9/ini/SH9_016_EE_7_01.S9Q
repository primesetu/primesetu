<s9qsqlblk> 
<s9qScriptID>S9Q_016_7_0001</s9qScriptID>
<s9qtitle>Extension Frame Work: Update Scripts</s9qtitle>
<s9qpgmtype>L</s9qpgmtype>
<s9qpgmtype>I</s9qpgmtype>
<s9qversion>*</s9qversion>
<s9qenvironment>M</s9qenvironment>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qQryType>DDL</s9qQryType>
<s9qScript>

if NOT exists (select * from sysobjects where id = object_id(N'[dbo].[VaSecurityConfig]') and OBJECTPROPERTY(id, N'IsUserTable') = 1)
CREATE TABLE [VaSecurityConfig]([Id] [varchar](16) NOT NULL, [Descr] [varchar](100), [ParamCode] [varchar](50),
	[Boolean] [bit], [Intg] [int], [Txt] [varchar](256), [Dt] [datetime], [Sng] [real], [Cur] [money], [Opt] [varchar](16),
	[Fixed] [varchar](15), [Changed] [int], [Category] [varchar](30), [CatSrlNo] [INT], [ParamSrlNo] [INT] Default 0,
	CONSTRAINT [PK_VaSecurityConfig] PRIMARY KEY  CLUSTERED ([Id])  ON [PRIMARY] ) ON [PRIMARY]
-GO-

if NOT exists (select * from sysobjects where id = object_id(N'[dbo].[VaPasswordHistory]') and OBJECTPROPERTY(id, N'IsUserTable') = 1)
Create Table [VaPasswordHistory](LoginId Varchar(16),SrlNo Int,LoginPwd Varchar(50),UpdtDate DateTime Default Getdate(),
CONSTRAINT [PK_VaPasswordHistory] PRIMARY KEY  CLUSTERED ([LoginId],[SrlNo])  ON [PRIMARY] ) ON [PRIMARY]

-GO-

if NOT exists (select * from sysobjects where id = object_id(N'[dbo].[VaUserExtdInfo]') and OBJECTPROPERTY(id, N'IsUserTable') = 1)
Create Table [VaUserExtdInfo](LoginId Varchar(16),StatusFlag Int default 0,InvalidLogCount Int default 0,AcctExpiryDt Datetime, PwdUpdatedDt Datetime,
CONSTRAINT [PK_VaUserExtdInfo] PRIMARY KEY  CLUSTERED ([LoginId])  ON [PRIMARY] ) ON [PRIMARY]

-GO-

if NOT exists (select * from sysobjects where id = object_id(N'[dbo].[VaLogHistory]') and OBJECTPROPERTY(id, N'IsUserTable') = 1)
Create Table [VaLogHistory](LogCtrlNo Varchar(128),LogSrlNo Int,LoginId Varchar(16),NodeId Varchar(16),CompCode Varchar(32),LogDate Datetime Default Getdate(),ActivityType Varchar(32)
,ActivityStatus Varchar(32),ExeName Varchar(50), LogRemarks Varchar(256),
CONSTRAINT [PK_VaLogHistory] PRIMARY KEY  CLUSTERED ([LogCtrlNo],[LogSrlNo])  ON [PRIMARY] ) ON [PRIMARY]

-GO-

if NOT exists (select * from sysobjects where id = object_id(N'[dbo].[VaNodeExtd]') and OBJECTPROPERTY(id, N'IsUserTable') = 1)
Create Table VaNodeExtd(NodeId Varchar(16), NodeAC1 Varchar(32), NodeAC2 Varchar(32), NodeAC3 Varchar(32),NodeAC4 Varchar(32), NodeAC5 Varchar(32)
CONSTRAINT [PK_VaNodeExtd] PRIMARY KEY  CLUSTERED ([NodeId])  ON [PRIMARY] ) ON [PRIMARY]

-GO-
if NOT exists (select * from sysobjects where id = object_id(N'[dbo].[VaGenlookup]') and OBJECTPROPERTY(id, N'IsUserTable') = 1)
Create Table VaGenlookup(Recid	int,Code Varchar(128),Descr varchar(256),Flag varchar(256),Number int
CONSTRAINT [PK_VaGenlookup] PRIMARY KEY  CLUSTERED ([Recid],[Code])  ON [PRIMARY] ) ON [PRIMARY]

-GO-

if not exists (Select * from VaSecurityConfig Where Paramcode= 'PasswordMaxLength')
