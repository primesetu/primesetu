		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 5. C1,C2,SC1=All,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 6. C1,C2,SC1=All,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 7. C1,C2,SC1=All,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd
		Union All
		-- 8. C1,C2,SC1=All,SC2=All,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 9. C1=All,C2=All,SC1,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 10. C1=All,C2=All,SC1,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 11. C1=All,C2=All,SC1,SC2=All,Size 
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd
		Union All
		-- 12. C1=All,C2=All,SC1,SC2=All,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 13. C1=All,C2=All,SC1=All,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 14. C1=All,C2=All,SC1=All,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 15. C1=All,C2=All,SC1=All,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd

		IF (@@ERROR <> 0)  
			BEGIN  
				SET @ErrorSave = 'Failure: Insertion to PromoMnIntermediate (Get Item Details) ' + CAST(@@ERROR AS VARCHAR(32))  
				GOTO ERREXIT  
			END  

	END

COMMIT TRANSACTION  
Return (0)  

ERREXIT:  
	BEGIN  
		ROLLBACK TRANSACTION
		RAISERROR(@ErrorSave,16,1)   
		RETURN (-1)  
	END
-GO-
SET QUOTED_IDENTIFIER OFF 
-GO-
SET ANSI_NULLS ON 
