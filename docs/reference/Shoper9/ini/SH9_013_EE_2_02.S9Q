-GO-
Insert dbo.GenlookUp Select 13100,2,'Half Yearly Stock Take','N',null,null,null,null,null
-GO-
Insert dbo.GenlookUp Select 13100,3,'Quarterly Stock Take','N',null,null,null,null,null
-GO-
Insert dbo.GenlookUp Select 13100,4,'Monthly Stock Take','N',null,null,null,null,null
-GO-
