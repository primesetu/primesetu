  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>
Insert Into dbo.PgmWiseFeatureDtls Values(1,'SR430300.EXE',1,'Introduced Sales Promotions First Time','',1,'.','')
-GO-
Insert Into dbo.PgmWiseFeatureDtls Values(1,'SR130000.EXE',2,'Introduced Sales Promotions First Time','',1,'.','')
-GO-
Insert Into dbo.PgmWiseFeatureDtls Values(2,'SR430300.EXE',1,'Introduced AND condition, Item Level Disc Type 4 and Apply Disc On Lowest/Highest Priced Item','',1,'.','')
-GO-
Insert Into dbo.PgmWiseFeatureDtls Values(2,'SR130000.EXE',2,'Introduced AND condition, Item Level Disc Type 4 and Apply Disc On Lowest/Highest Priced Item','',1,'.','')
-GO-
Insert Into dbo.PgmWiseFeatureDtls Values(3,'SR430300.EXE',1,'Introduced AND condition, Item Level Offer Type With Buy and Get Items Are Different','',1,'.','')
-GO-
Insert Into dbo.PgmWiseFeatureDtls Values(3,'SR130000.EXE',2,'Introduced AND condition, Item Level Offer Type With Buy and Get Items Are Different','',1,'.','')
-GO-
Insert into dbo.sysparamextd ([ID], ParamCode, Fixed, Changed, Category, CatDescr, DispOrder) values ('SR4-9111-0000333','LowestHighestPricedItem','Variable',0,'11. Billing','This Gives Billing Parameters',28)
-GO-
Insert into dbo.sysparam ([ID],descr,paramcode,Intg,opt) values ('SR4-9111-0000333','Catalogue – For Item Level Fixed Discounts/Offers – Default behaviour for Lowest/Highest Priced Item','LowestHighestPricedItem',1,'I')
