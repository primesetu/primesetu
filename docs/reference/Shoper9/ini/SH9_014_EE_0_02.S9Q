Update ItemMaster set IsRPTaxInclusive = 1,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') where isrptaxinclusive is null
-GO-
Update ItemMaster set IsInventoryItem =1,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') where IsInventoryItem is null 
-GO-
Update ItemMaster set IsBillable =1,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') where IsBillable is null 
-GO-
Update ItemMaster set Regularind=1,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') where RegularInd is null 
-GO-
UPDATE ITEMMASTER SET PRODTAXTYPE ='NA',VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE (PRODTAXTYPE IS NULL OR PRODTAXTYPE ='') 
-GO-
UPDATE SubClass1Cat SET PRODTAXTYPE ='NA',VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE (PRODTAXTYPE IS NULL OR PRODTAXTYPE ='') 
-GO-
update itemmaster set class1cd=ltrim(rtrim(class1cd)),class2cd=ltrim(rtrim(class2cd)),subclass1cd=ltrim(rtrim(subclass1cd)),subclass2cd=ltrim(rtrim(subclass2cd)),sizecd=ltrim(rtrim(sizecd))
-GO-
