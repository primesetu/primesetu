<s9qsqlblk>
<s9qScriptID>S9Q_020_6_0004</s9qScriptID>
<s9qtitle>Security Database Script</s9qtitle>
<s9qpgmtype>I</s9qpgmtype>
<s9qpgmtype>L</s9qpgmtype>
<s9qversion>*</s9qversion>
<s9qenvironment>M</s9qenvironment>
<s9qRunMultiple>1</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>
Create Table PrintDesignerTrnGrpInfo(
	[TrnType] int not null, 
	[TrnCaption] Varchar(256), 
	[TrnGroupName] Varchar(256), 
	[GroupOrder] int,
	[TrnOrderInGroup] int,
	[IsActive] int,
	[Remarks] Varchar(256),
	[AdditionalTrnGrpDetail1] [Varchar] (250),
	[AdditionalTrnGrpDetail2] [Varchar] (250),
	[AdditionalTrnGrpDetail3] [Varchar] (250),
	[AdditionalTrnGrpDetail4] [Varchar] (250),
	[AdditionalTrnGrpDetail5] [Varchar] (250),
	[VAUid] [Varchar] (32) NULL,
	[VActr] [int] NULL,
	[VATermId] [Varchar] (32)   NULL ,
	[VACompCode] [Varchar] (16)   NULL ,
	[SHOPERDBVER] [Int] NULL 
)
-GO-
ALTER TABLE [dbo].[PrintDesignerTrnGrpInfo] WITH NOCHECK ADD 
	CONSTRAINT [PK_PrintDesignerTrnGrpInfo] PRIMARY KEY  CLUSTERED 
	(
		[TrnType]
	)  ON [PRIMARY]

</s9qScript>
</s9qsqlblk>

