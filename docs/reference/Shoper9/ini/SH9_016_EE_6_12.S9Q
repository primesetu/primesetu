)
Insert into Sysparam(ID,Descr,ParamCode,txt,opt) Values('SR1-0901-0000341','Print SKU Wise or Item Wise (Extension Framework/Customisation fields)','PrnSKUORItemWiseExtnFields','NNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNNN','T')
