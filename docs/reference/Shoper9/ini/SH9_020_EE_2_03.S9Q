Update PrefixTrnNo Set Vactr = (select intg from sysparam where paramcode = 'VaSysCounter'),VaCompCode = (select Txt from sysparam where paramcode = 'CompanyCode') where TrnType in ('1100','1200','1400','1500','2710','2720','2730','2740','2200','2300','2400','2500','1710','1720','1730','1740')
