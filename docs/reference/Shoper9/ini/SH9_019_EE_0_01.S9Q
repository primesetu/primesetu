sp_rename 'ReportScheduleHistory.Status', 'Description', 'COLUMN'
-GO-
ALTER TABLE ReportScheduleHistory ADD Status varchar(64)
-GO-
UPDATE ReportScheduleHistory SET Status = 'SUCCESS' WHERE Description = 'Successfully executed.'
-GO-
UPDATE ReportScheduleHistory SET Status = 'FAILED' WHERE Status IS NULL
-GO-
