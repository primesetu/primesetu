-GO-
Update VaRestrictMnuConfig Set Mnuno = 613,MenuOpt = 6132 Where Mnuno = 600 And MenuOpt = 602
-GO-
Update Vamenu Set Exename = 'SR442300.EXE',PGMOPT= 1 WHERE EXENAME = 'SR404800.EXE'
-GO-
Update Vamenu Set Exename = 'SR442300.EXE',PGMOPT= 2 WHERE EXENAME = 'SR405300.EXE'
-GO-
