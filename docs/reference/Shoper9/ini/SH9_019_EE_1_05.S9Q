IF NOT EXISTS (SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'[dbo].[EventExtnFieldConfig]') AND type in (N'U'))
BEGIN
CREATE TABLE [dbo].[EventExtnFieldConfig](
	[ProgramId] [varchar](64) NOT NULL,
	[EventId] [varchar](64) NOT NULL,
	[FieldSrlNo] [int] NOT NULL,
	[FieldName] [varchar](32) NOT NULL,
	[ReturnFlag] [int] NULL ,
	[FieldLock] [int] NULL,
	[VaUid] [varchar](32) NULL,
	[VaCtr] [int] NULL,
	[VaTermId] [varchar](32) NULL,
	[VaCompCode] [varchar](16) NULL,
 CONSTRAINT [PK_EventExtnFieldConfig] PRIMARY KEY CLUSTERED 
(
	[ProgramId] ASC,
	[EventId] ASC,
	[FieldSrlNo] ASC,
	[FieldName] ASC
)
) ON [PRIMARY]
END
-GO-
