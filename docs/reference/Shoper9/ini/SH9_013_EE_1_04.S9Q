<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0025</s9qScriptID>
<s9qtitle>cORRECTING THE LINE LEVEL value mismatch IN  STH AND STD  </s9qtitle>
<s9qpgmtype>D</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>

-- Line level mismatch

IF OBJECT_ID('tempdb..#Lineitemlvlmismatch') IS NOT NULL BEGIN drop table #Lineitemlvlmismatch END
-GO-
select trntype, trnctrlno, netdocvalue,netdocvalue-(totdocvalue-totdocdisc+totdocaddons-totdocdedns) as diffvalue into #Lineitemlvlmismatch from dbo.stktrnhdr  where SHOPERDBVER=730 and trntype=2100 and  netdocvalue <> (totdocvalue-totdocdisc+totdocaddons-totdocdedns) and stktrnhdr.totrndoffvalue <> 0 
-GO-
update dbo.stktrnhdr set totdocaddons=totdocaddons-totrndoffvalue,totdocentafttaxaddons=totdocentafttaxaddons-totrndoffvalue from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrnhdr.trntype and #Lineitemlvlmismatch.trnctrlno=stktrnhdr.trnctrlno and stktrnhdr.trntype=2100 and stktrnhdr.totrndoffvalue >0 and SHOPERDBVER=730 
-GO-
update dbo.stktrnhdr set totdocdedns=totdocdedns-abs(totrndoffvalue),totdocentafttaxdedns=totdocentafttaxdedns-abs(totrndoffvalue) from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrnhdr.trntype and #Lineitemlvlmismatch.trnctrlno=stktrnhdr.trnctrlno and stktrnhdr.trntype=2100 and stktrnhdr.totrndoffvalue < 0 and SHOPERDBVER=730 
-GO-
update dbo.stktrnhdr set totrndoffvalue=totrndoffvalue+(diffvalue) from #Lineitemlvlmismatch where #Lineitemlvlmismatch.trntype=stktrnhdr.trntype and #Lineitemlvlmismatch.trnctrlno=stktrnhdr.trnctrlno and stktrnhdr.trntype=2100 and SHOPERDBVER=730  
-GO-
update dbo.stktrnhdr set totdocaddons=totdocaddons+totrndoffvalue,totdocentafttaxaddons=totdocentafttaxaddons+totrndoffvalue from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrnhdr.trntype and #Lineitemlvlmismatch.trnctrlno=stktrnhdr.trnctrlno and stktrnhdr.trntype=2100 and stktrnhdr.totrndoffvalue >0 and SHOPERDBVER=730 
-GO-
update dbo.stktrnhdr set totdocdedns=totdocdedns+ abs(totrndoffvalue),totdocentafttaxdedns=totdocentafttaxdedns + abs(totrndoffvalue) from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrnhdr.trntype and #Lineitemlvlmismatch.trnctrlno=stktrnhdr.trnctrlno and stktrnhdr.trntype=2100 and stktrnhdr.totrndoffvalue < 0 and SHOPERDBVER=730 
-GO-
update dbo.stktrndtls set docentaddons=docentaddons-docrndoffvalue,docentafttaxaddons=docentafttaxaddons-docrndoffvalue from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrndtls.trntype and #Lineitemlvlmismatch.trnctrlno=stktrndtls.trnctrlno and stktrndtls.trntype=2100 and stktrndtls.docrndoffvalue >0 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #Lineitemlvlmismatch.trntype=std.trntype and #Lineitemlvlmismatch.trnctrlno=std.trnctrlno and docentnetvalue > 0)
-GO-
update dbo.stktrndtls set docentdedns=docentdedns-abs(docrndoffvalue),docentafttaxdedns=docentafttaxdedns-abs(docrndoffvalue) from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrndtls.trntype and #Lineitemlvlmismatch.trnctrlno=stktrndtls.trnctrlno and stktrndtls.trntype=2100 and stktrndtls.docrndoffvalue < 0 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #Lineitemlvlmismatch.trntype=std.trntype and #Lineitemlvlmismatch.trnctrlno= std.trnctrlno and std.docentnetvalue > 0)
-GO-
update dbo.stktrndtls set docrndoffvalue= stktrnhdr.totrndoffvalue from dbo.stktrnhdr,#Lineitemlvlmismatch where #Lineitemlvlmismatch.trntype=stktrndtls.trntype and #Lineitemlvlmismatch.trnctrlno=stktrndtls.trnctrlno and #Lineitemlvlmismatch.trntype=stktrnhdr.trntype and #Lineitemlvlmismatch.trnctrlno=stktrnhdr.trnctrlno and stktrnhdr.SHOPERDBVER=730 and stktrndtls.trntype=2100 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #Lineitemlvlmismatch.trntype=std.trntype and #Lineitemlvlmismatch.trnctrlno= std.trnctrlno and std.docentnetvalue > 0)
-GO-
update dbo.stktrndtls set docentaddons=docentaddons+docrndoffvalue,docentafttaxaddons=docentafttaxaddons+docrndoffvalue from #Lineitemlvlmismatch where #Lineitemlvlmismatch.trntype=stktrndtls.trntype and #Lineitemlvlmismatch.trnctrlno=stktrndtls.trnctrlno and stktrndtls.trntype=2100 and stktrndtls.docrndoffvalue >0 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #Lineitemlvlmismatch.trntype=std.trntype and #Lineitemlvlmismatch.trnctrlno=std.trnctrlno and docentnetvalue > 0)
-GO-
update dbo.stktrndtls set docentdedns=docentdedns+abs(docrndoffvalue),docentafttaxdedns=docentafttaxdedns+abs(docrndoffvalue) from #Lineitemlvlmismatch where #Lineitemlvlmismatch.trntype=stktrndtls.trntype and #Lineitemlvlmismatch.trnctrlno=stktrndtls.trnctrlno and stktrndtls.trntype=2100 and stktrndtls.docrndoffvalue < 0 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #Lineitemlvlmismatch.trntype=std.trntype and #Lineitemlvlmismatch.trnctrlno= std.trnctrlno and std.docentnetvalue > 0)
-GO-
update dbo.stktrndtls set docentnetvalue=(docentvalue-docenttotdisc + docentaddons-docentdedns+DocEntAddonsTax) from #Lineitemlvlmismatch  where #Lineitemlvlmismatch.trntype=stktrndtls.trntype and #Lineitemlvlmismatch.trnctrlno=stktrndtls.trnctrlno and stktrndtls.trntype=2100 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #Lineitemlvlmismatch.trntype=std.trntype and #Lineitemlvlmismatch.trnctrlno= std.trnctrlno and std.docentnetvalue > 0)  
-GO-

</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0026</s9qScriptID>
<s9qtitle>cORRECTING THE TX value mismatch IN  STD (TRAN TYPE -2100-SALES)</s9qtitle>
<s9qpgmtype>D</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>

-- 2100 Tax Mismatch

IF OBJECT_ID('tempdb..#taxmismatch') IS NOT NULL BEGIN drop table #taxmismatch END
-GO-
select sth.trntype,sth.trnctrlno,sth.totdoctax,std.taxamt,(totdoctax-std.taxamt) as diffval  into #taxmismatch  from dbo.stktrnhdr sth, (select trntype,trnctrlno,sum(docenttax) as taxamt from dbo.stktrndtls where trntype=2100 and stdtaxcomp1per <> 0 and docentnetvalue >0 group by trntype,trnctrlno) as std where sth.trntype=std.trntype and sth.trnctrlno=std.trnctrlno and std.taxamt <>sth.totdoctax and sth.trntype=2100 and sth.SHOPERDBVER=730
-GO-
update dbo.stktrndtls set docenttax=docenttax+diffval,taxcomp1=taxcomp1+diffval from #taxmismatch where stktrndtls.trntype=#taxmismatch.trntype and stktrndtls.trnctrlno=#taxmismatch.trnctrlno and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where #taxmismatch.trntype=std.trntype and #taxmismatch.trnctrlno=std.trnctrlno and stdtaxcomp1per <> 0 and docenttax <>0 and docentnetvalue <>0)
-GO-
update dbo.stktrndtls set docenttax=0,taxcomp1=0 from dbo.stktrnhdr where stktrnhdr.trntype=stktrndtls.trntype and stktrnhdr.trnctrlno=stktrndtls.trnctrlno and stktrnhdr.SHOPERDBVER=730 and docentnetvalue =0 and stktrndtls.trntype=2100 and stktrndtls.docenttax <> 0 
-GO-
update dbo.stktrndtls set docenttax=0,taxcomp1=0 from dbo.stktrnhdr where stktrnhdr.trntype=stktrndtls.trntype and stktrnhdr.trnctrlno=stktrndtls.trnctrlno and stktrnhdr.SHOPERDBVER=730  and stktrndtls.stdtaxcomp1per =0 and stktrndtls.trntype=2100 and stktrndtls.docenttax <> 0
-GO-
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
