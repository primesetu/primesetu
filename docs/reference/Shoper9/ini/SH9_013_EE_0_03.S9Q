<s9qsqlblk>
  <s9qScriptid>	S9Q_013_0_0008	</s9qScriptid>
  <s9qtitle>All DDL Statements.</s9qtitle>
  <s9qpgmtype>I</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qenvironment>R</s9qenvironment>
  <s9qRunMultiple>1</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>
update agentactivity set hocompcd='HHHH', Vactr = (select intg from sysparam where paramcode = 'VaSysCounter')  where hocompcd is NULL
</s9qScript>
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptID>S9Q_013_0_0009</s9qScriptID>
  <s9qtitle></s9qtitle>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>0</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>		
	Update genlookup set vacompcode= (Select txt from sysparam where paramcode='CompanyCode') where (vacompcode is null or vacompcode='')
  </s9qScript>		
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptID>	S9Q_013_0_0010	</s9qScriptID>
  <s9qtitle></s9qtitle>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>0</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>		
Update Sysparam Set Txt = 'N09#N10#N11#N12#N13#N14#N15#N16#N17' Where paramcode = 'BrowseDescString2' and Txt <> 'N09#N10#N11#N12#N13#N14#N15#N16#N17'
-GO-
Update sysparam set txt ='BILL SUSPENSION#SALES ADVICE SLIP#SALES ORDER#BRIDAL REGISTRY#APPROVAL ISSUES#APPROVAL RECEIPTS#TAILORING ORDER#SALES DC#APPROVAL ISSUE DC#DISPATCH ADVICE' WHERE PARAMCODE='EXPTTRNTITLE' and txt <>'BILL SUSPENSION#SALES ADVICE SLIP#SALES ORDER#BRIDAL REGISTRY#APPROVAL ISSUES#APPROVAL RECEIPTS#TAILORING ORDER#SALES DC#APPROVAL ISSUE DC#DISPATCH ADVICE'
  </s9qScript>		
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptID>	S9Q_013_0_0011	</s9qScriptID>
  <s9qtitle></s9qtitle>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>0</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>		
Update genlookupextd Set Additional1 = '01' where recid in (70,71) and Additional1 <> '01' 
  </s9qScript>		
</s9qsqlblk>


<s9qsqlblk>
  <s9qScriptID>	S9Q_013_0_0012	</s9qScriptID>
  <s9qtitle></s9qtitle>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>0</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>		
Update Sysparam Set Txt = 'BAK#TMP#XTMP#MSYS#TEMP#AST#PASTE#RST#SDR#DTP#SYS#DCREF#PTHDR#PTDTL#RST#SDR#COPY#PASTE#DCREF#GLOBAL#PHYTMP#REP#AST#LOG#LST#RPT#TALLY#XSP' Where paramcode = 'TempTableToSkipFromAST1' and len(txt) < 135
  </s9qScript>		
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptID>	S9Q_013_0_0013	</s9qScriptID>
  <s9qtitle></s9qtitle>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>0</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>		
update genlookup set [number] = (select isnull(max(TrnCtrlNo)+1,1) from franchiseetrans where TrnAccType = '1') where recid = 101 and code = '5000'
-GO-
update genlookup set [number] = (select isnull(max(TrnCtrlNo)+1,1) from franchiseetrans where TrnAccType = '2') where recid = 101 and code = '5100'
  </s9qScript>		
</s9qsqlblk>	

<s9qsqlblk>
  <s9qScriptID>	S9Q_013_0_0014	</s9qScriptID>
  <s9qtitle></s9qtitle>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>P</s9qenvironment>
  <s9qRunMultiple>0</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>		
INSERT INTO GENLOOKUP SELECT 102,'PO+' + PONOPREFIX,'PO#Purchase Order',NULL,MAX(POCTRLNO+1),'super',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select txt from sysparam where paramcode = 'CompanyCode') FROM PURCHORDHDR WHERE 'PO+' + PONOPREFIX NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 102) GROUP BY PONOPREFIX
-GO-
insert into genlookup select 101,'2100','Sales',null,1,'super',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select txt from sysparam where paramcode = 'CompanyCode')
-GO-
update genlookup set number=(select isnull(max(TrnCtrlNo),0)+1 from stktrnhdr where trntype=2100) where recid=101 and code='2100'
-GO-
insert into genlookup select 101,'1600','Void Sales',null,0,'super',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select txt from sysparam where paramcode = 'CompanyCode')
-GO-
update genlookup set number=(select isnull(max(TrnCtrlNo),0)+1 from stktrnhdr where trntype=1600)  where recid=101 and code='1600'
-GO-
insert into genlookup select 101,'1300','Sales Return',null,0,'super',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select txt from sysparam where paramcode = 'CompanyCode')
-GO-
update genlookup set number=(select isnull(max(TrnCtrlNo),0)+1 from stktrnhdr where trntype=1300)  where recid=101 and code='1300'
-GO-
insert into genlookup select 101,'4000','Pos Cash',null,0,'super',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select txt from sysparam where paramcode = 'CompanyCode')
-GO-
update genlookup set number=(select isnull(max(CtrlNo),0)+1 from Poscashtrn)  where recid=101 and code='4000'
-GO-
update genlookup set Number=(select isnull(max(Docno),0)+1 from poscashtrn where entrytype=13 and DocNoPrefix= (select reverse(left(reverse(code),charindex('+',reverse(code),1)-1 )) from genlookup where recid=102 and code like '4000+13+%'))  where recid=102 and code like '4000+13+%'
-GO-
Update Genlookup Set Descr = Code  Where Descr is NULL
  </s9qScript>		
</s9qsqlblk>


