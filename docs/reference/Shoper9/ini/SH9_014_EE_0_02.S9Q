SELECT 7009,ANALCODE15,ANALCODE15,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE15 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7009) Union 
SELECT 7010,ANALCODE16,ANALCODE16,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE16 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7010) Union 
SELECT 7011,ANALCODE17,ANALCODE17,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE17 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7011) Union 
SELECT 7012,ANALCODE18,ANALCODE18,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE18 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7012) Union 
SELECT 7013,ANALCODE19,ANALCODE19,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE19 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7013) Union 
SELECT 7014,ANALCODE20,ANALCODE20,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE20 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7014) Union 
SELECT 7015,ANALCODE21,ANALCODE21,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE21 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7015) Union 
SELECT 7016,ANALCODE22,ANALCODE22,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE22 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7016) Union 
SELECT 7017,ANALCODE23,ANALCODE23,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE23 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7017) Union 
SELECT 7018,ANALCODE24,ANALCODE24,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE24 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7018) 
-GO-
Declare @VaCtr as int
Declare @Vacompany as varchar(10) 
Set @VaCtr = (select intg from sysparam where paramcode = 'VaSysCounter')
Set @Vacompany = (select TXT from sysparam where paramcode = 'COMPANYCODE')  
Insert Into Genlookup (Recid,Code,Descr,flag,number,Vauid,Vactr,VatermId,VacompCode) 
SELECT 7019,ANALCODE25,ANALCODE25,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE25 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7019) Union 
SELECT 7020,ANALCODE26,ANALCODE26,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE26 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7020) Union 
SELECT 7021,ANALCODE27,ANALCODE27,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE27 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7021) Union 
SELECT 7022,ANALCODE28,ANALCODE28,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE28 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7022) Union 
SELECT 7023,ANALCODE29,ANALCODE29,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE29 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7023) Union 
SELECT 7024,ANALCODE30,ANALCODE30,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE30 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7024) Union 
SELECT 7025,ANALCODE31,ANALCODE31,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE31 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7025) Union 
SELECT 7026,ANALCODE32,ANALCODE32,'',0,'SUPER',@VaCtr,'.',@Vacompany FROM ITEMMASTER WHERE ANALCODE32 NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 7026) 
-GO-
Insert Into Genlookup (Recid,Code,Descr,flag,number,Vauid,Vactr,VatermId,VacompCode)  
SELECT DISTINCT 53,PRODTAXTYPE,PRODTAXTYPE,'',0,'SUPER',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select TXT from sysparam where paramcode = 'COMPANYCODE') FROM CLASS12COMBO WHERE PRODTAXTYPE NOT IN (SELECT CODE FROM GENLOOKUP WHERE RECID = 53) 
-GO-
UPDATE GENLOOKUP SET CODE= LTRIM(RTRIM(CODE)) WHERE RECID IN (1,2,65,66,67,68,69,53,54,70,51,52,7000,7001,7002,7003,7004,7005,7006,7007,7008,7009,7010,7011,7012,7013,7014,7015,7016,7017,7018,7019,7020,7021,7022,7023,7024,7025,7026)
-GO-
UPDATE GENLOOKUP SET DESCR = LEFT(LTRIM(RTRIM(DESCR)),50) WHERE RECID IN (1,2,65,66,67,68,69,53,54,70,51,52,7000,7001,7002,7003,7004,7005,7006,7007,7008,7009,7010,7011,7012,7013,7014,7015,7016,7017,7018,7019,7020,7021,7022,7023,7024,7025,7026)
-GO-
UPDATE GENLOOKUP SET DESCR = LTRIM(RTRIM(CODE)) WHERE RECID IN (1,2,65,66,67,68,69,53,54,70,51,52,7000,7001,7002,7003,7004,7005,7006,7007,7008,7009,7010,7011,7012,7013,7014,7015,7016,7017,7018,7019,7020,7021,7022,7023,7024,7025,7026) AND (DESCR IS NULL OR LTRIM(RTRIM(DESCR)) = '') 
-GO-
UPDATE SIZECAT SET SIZEGROUPID = A.SIZEGROUP,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') FROM CLASS12COMBO A,SIZECAT B WHERE A.CLASS1CD = B.CLASS1CD AND A.CLASS2CD = B.CLASS2CD AND A.SIZEGROUP <> B.SIZEGROUPID
-GO-
Update SizeCat set SizeGroupId=0 where sizegroupid ='' or sizegroupid is null
-GO-
INSERT INTO sizecat (class1cd,class2cd,sizecd,ispivotalsize,sizegroupid,sizegroupsrlno,Vauid,Vactr,VatermId,VacompCode) 
select distinct class1cd,class2cd,sizecd,1,0,0,'SUPER',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',
(select TXT from sysparam where paramcode = 'COMPANYCODE') from itemmaster where 
class1cd +':'+class2cd+':'+sizecd  not in (select class1cd +':'+class2cd+':'+sizecd from sizecat)
-GO-
UPDATE ITEMMASTER SET LASTPURCHPRICE = 0,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE LASTPURCHPRICE IS NULL 
-GO-
UPDATE ITEMMASTER SET CURRENTCOST = 0,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE CURRENTCOST IS NULL 
-GO-
UPDATE ITEMMASTER SET DEALER_PRICE = 0,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE DEALER_PRICE IS NULL 
-GO-
UPDATE ITEMMASTER SET RETAIL_PRICE = 0,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE RETAIL_PRICE IS NULL 
-GO-
UPDATE ITEMMASTER SET ITEMDESC = CLASS1CD+CLASS2CD+SUBCLASS1CD+SUBCLASS2CD+SIZECD,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') FROM ITEMMASTER WHERE (ITEMDESC IS NULL OR ITEMDESC ='')
-GO-
UPDATE SUBCLASS1CAT SET SUBCLASS1DESC = SUBCLASS1CD,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE (SUBCLASS1DESC IS NULL OR SUBCLASS1DESC = '')
-GO-
UPDATE SUBCLASS2CAT SET SUBCLASS2DESC = SUBCLASS2CD,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter') WHERE (SUBCLASS2DESC IS NULL OR SUBCLASS2DESC = '')
-GO-
INSERT INTO SUBCLASS1CAT(Class1Cd,Class2Cd,SubClass1Cd,SubClass1Desc,Vauid)
SELECT DISTINCT Class1Cd,Class2Cd,SubClass1Cd,SubClass1Cd,'U' FROM ItemMaster
WHERE CLASS1CD+':'+ CLASS2CD+ ':'+SUBCLASS1CD NOT IN (SELECT DISTINCT CLASS1CD+':'+ CLASS2CD+ ':'+SUBCLASS1CD FROM SUBCLASS1CAT)
-GO-
UPDATE SUBCLASS1CAT Set ProdTaxType=t.ProdTaxType,                                                
AnalCode1=t.AnalCode1,AnalCode2=t.AnalCode2,AnalCode3=t.AnalCode3,AnalCode4=t.AnalCode4,                                                
AnalCode5=t.AnalCode5,AnalCode6=t.AnalCode6,AnalCode7=t.AnalCode7,AnalCode8=t.AnalCode8,AnalCode9=t.AnalCode9,                                       
AnalCode10=t.AnalCode10,AnalCode11=t.AnalCode11,AnalCode12=t.AnalCode12,AnalCode13=t.AnalCode13,AnalCode14=t.AnalCode14,                                       
AnalCode15=t.AnalCode15,AnalCode16=t.AnalCode16,AnalCode17=t.AnalCode17,AnalCode18=t.AnalCode18,AnalCode19=t.AnalCode19,                        
AnalCode20=t.AnalCode20,AnalCode21=t.AnalCode21,AnalCode22=t.AnalCode22,AnalCode23=t.AnalCode23,AnalCode24=t.AnalCode24,                                       
AnalCode25=t.AnalCode25,AnalCode26=t.AnalCode26,AnalCode27=t.AnalCode27,AnalCode28=t.AnalCode28,AnalCode29=t.AnalCode29,                                       
AnalCode30=t.AnalCode30,AnalCode31=t.AnalCode31,AnalCode32=t.AnalCode32,VACTR =(select intg from sysparam where paramcode = 'VaSysCounter'),
VaCompCode=(select TXT from sysparam where paramcode like 'COMPANYCODE') FROM ItemMaster as t inner join SUBCLASS1CAT as sc1 on 
t.Class1Cd = sc1.Class1Cd and t.Class2Cd = sc1.Class2Cd and t.SubClass1Cd = sc1.SubClass1Cd Where Sc1.VAUID = 'U'               
-GO-
UPDATE SUBCLASS1CAT SET VAUID = 'SUPER' WHERE VAUID = 'U'
-GO-
INSERT INTO SUBCLASS2CAT(Class1Cd,Class2Cd,SubClass2Cd,SubClass2Desc,Vauid,VaCtr,VATermId,VaCompCode)
SELECT DISTINCT Class1Cd,Class2Cd,SubClass2Cd,SubClass2Cd,'SUPER',(select intg from sysparam where paramcode = 'VaSysCounter'),'.',(select TXT from sysparam where paramcode = 'COMPANYCODE') FROM ItemMaster
WHERE CLASS1CD+':'+ CLASS2CD+ ':'+SUBCLASS2CD NOT IN (SELECT DISTINCT CLASS1CD+':'+ CLASS2CD+ ':'+SUBCLASS2CD FROM SUBCLASS2CAT)
-GO-
UPDATE SUBCLASS1CAT Set Regularind=t.Regularind,VaCompCode=(select TXT from sysparam where paramcode like 'COMPANYCODE'),VaTermId='U' FROM ItemMaster as t inner join SUBCLASS1CAT as sc1 on 
t.Class1Cd = sc1.Class1Cd and t.Class2Cd = sc1.Class2Cd and t.SubClass1Cd = sc1.SubClass1Cd Where (Sc1.RegularInd <> t.RegularInd AND T.RegularInd is not null) or Sc1.RegularInd IS NULL
-GO-
UPDATE SUBCLASS1CAT Set ImageId=t.ImageId,VaCompCode=(select TXT from sysparam where paramcode like 'COMPANYCODE'),VaTermId='U' FROM ItemMaster as t inner join SUBCLASS1CAT as sc1 on 
t.Class1Cd = sc1.Class1Cd and t.Class2Cd = sc1.Class2Cd and t.SubClass1Cd = sc1.SubClass1Cd Where (Sc1.ImageId <> t.ImageId and t.Imageid is not null) or Sc1.ImageId IS NULL
-GO-
UPDATE SUBCLASS1CAT SET VACTR = (select intg from sysparam where paramcode like 'VaSysCounter')
WHERE VATERMID = 'U' AND REGULARIND IS NOT NULL
-GO-
UPDATE SUBCLASS1CAT SET VACTR = (select intg from sysparam where paramcode like 'VaSysCounter')
WHERE VATERMID = 'U' AND IMAGEID IS NOT NULL
-GO-
UPDATE SUBCLASS1CAT SET VATERMID ='.' WHERE VATERMID = 'U'
-GO-
Delete From Genlookup where ltrim(rtrim(code)) = ''
-GO-
DELETE Mailinglist WHERE RECNO IN (SELECT RECNO FROM  Mailinglist M,customers c where m.catcd=c.code and m.recno<>c.maillistsrlno )
-GO-
DELETE Mailinglist WHERE RECNO IN (SELECT RECNO FROM  Mailinglist M,vendors V where m.catcd=v.code and m.recno<>v.maillistsrlno )
-GO-
DELETE Mailinglist WHERE RECNO IN (SELECT RECNO FROM  Mailinglist M,chainstores CH where  m.catcd=ch.code and m.recno<>ch.maillistsrlno )
-GO-
  </s9qScript>		
</s9qsqlblk>