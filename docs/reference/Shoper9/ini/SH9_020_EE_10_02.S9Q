-GO-
Insert Into VaContextHelpDtls (AppName,PgmOption,ControlName,Srlno,TransId,HelpContextId,HelpPath,HelpFileName)
Values ('SR438600.EXE',1,'FrmPrefix',1,'','',Null,Null) 
-GO-
Update VaContextHelpDtls Set AppNoteDtls = 'Bill Prefix :
This option is used to define the document prefixes and the starting document number for list of transactions 
	* Sales transactions (Sales, Sales Return and Void Sales)
	* Cash transactions (Cash Receipts and Cash Payouts) 
	* Intermediate transaction Slips 
		* Bill Suspension
		* Sales Advice Slip
		* Service Order
		* Sales Order
		* Sales DC 
		* Approval DC
	* Inward Transaction (Purchase, TransferIn and Misc.Receipt)
	* Outward Transaction (Purchase Return, TransferOut and Misc.Issues) 

Note: You are allowed to perform any Sales/Cash/Inward/Outward transactions in Shoper 9, 
only after defining the document prefixes of the corresponding transaction type. 
If you try to open the transaction windows without defining the prefix, you will be alerted 
with an appropriate message.' Where AppName = 'SR438600.EXE'


</s9qScript>
</s9qsqlblk>
