Insert Into dbo.Genlookup Values(9060,'2','Last Piece Discount','1',2,'super',1,'.','')  

</s9qScript>
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0014</s9qScriptid> 
  <s9qtitle>Catalogue Module: Set Vendor Items</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>
-- To Setup All Vendors Will Supply All Product/Brand Combinations
Begin Transaction
if exists (select * from sysobjects where id = object_id(N'[TmpVendorItems]') and OBJECTPROPERTY(id, N'IsTable') = 1) drop table [TmpVendorItems]

CREATE TABLE TmpVendorItems ([VendCd] [varchar] (16) NOT NULL, [RecNo] [int] NOT NULL,      [ItemClass1] [varchar] (16) NULL, [ItemClass2] [varchar] (16) NULL,     [PrefOrAlt] [varchar] (2) NULL,     [VAUid] [varchar] (32) NULL, [VActr] [int] NULL, [VATermId] [varchar] (32) NULL, [VACompCode] [varchar] (16) NULL, Ctr Int Identity(1,1))

Insert into TmpVendorItems (VendCd,RecNo,ItemClass1,ItemClass2,VAUid,VACtr,VATermId,VACompCode) Select Distinct Code,1,'<All>','<All>','Super',(Select Intg From dbo.SysParam Where ParamCode ='VaSysCounter'),'.',(Select Txt From dbo.SysParam Where ParamCode ='CompanyCode') From dbo.Vendors

Delete From dbo.VendorItems

Insert Into dbo.VendorItems (VendCd, RecNo, ItemClass1, ItemClass2, PrefOrAlt,VAUid,VACtr,VATermId,VACompCode) Select VendCd, Ctr, ItemClass1, ItemClass2, PrefOrAlt,VAUid,VACtr,VATermId,VACompCode from TmpVendorItems

if exists (select * from sysobjects where id = object_id(N'[TmpVendorItems]') and OBJECTPROPERTY(id, N'IsTable') = 1) drop table [TmpVendorItems]

Commit Transaction	

  </s9qScript>
</s9qsqlblk>


<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0015</s9qScriptid> 
  <s9qtitle>Catalogue Module: Using REPLACE Function To Remove Spaces</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 

  <s9qScript>
UPDATE dbo.Itemmaster SET ItemDesc = REPLACE(ItemDesc, CHAR(13), '')
-GO-
UPDATE dbo.SubClass1Cat SET SubClass1Desc = REPLACE(SubClass1Desc, CHAR(13), '')
-GO-
UPDATE dbo.SubClass2Cat SET SubClass2Desc = REPLACE(SubClass2Desc, CHAR(13), '')
-GO-
UPDATE dbo.StkTrnHdr SET AccDocNo = REPLACE(AccDocNo, CHAR(13), '')
-GO-
UPDATE dbo.Genlookup SET Code = REPLACE(Code, CHAR(13), ''), Descr = REPLACE(Descr, CHAR(13), '')
-GO-
UPDATE dbo.MailingList SET StreetAddr = REPLACE(StreetAddr, CHAR(13), '')
-GO-
UPDATE dbo.Vendors SET Nm = REPLACE(Nm, CHAR(13), '')
-GO-
UPDATE dbo.Customers SET Nm = REPLACE(Nm, CHAR(13), '')
-GO-
UPDATE dbo.Itemmaster SET ItemDesc = REPLACE(ItemDesc, CHAR(10), '')
-GO-
UPDATE dbo.SubClass1Cat SET SubClass1Desc = REPLACE(SubClass1Desc, CHAR(10), '')
-GO-
UPDATE dbo.SubClass2Cat SET SubClass2Desc = REPLACE(SubClass2Desc, CHAR(10), '')
-GO-
UPDATE dbo.StkTrnHdr SET AccDocNo = REPLACE(AccDocNo, CHAR(10), '')
-GO-
UPDATE dbo.Genlookup SET Code = REPLACE(Code, CHAR(10), ''), Descr = REPLACE(Descr, CHAR(10), '')
-GO-
UPDATE dbo.MailingList SET StreetAddr = REPLACE(StreetAddr, CHAR(10), '')
-GO-
UPDATE dbo.Vendors SET Nm = REPLACE(Nm, CHAR(10), '')
-GO-
UPDATE dbo.Customers SET Nm = REPLACE(Nm, CHAR(10), '')

  </s9qScript>

</s9qsqlblk>


<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0016</s9qScriptid> 
