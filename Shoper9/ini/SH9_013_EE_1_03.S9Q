<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0001</s9qScriptID>
<s9qtitle>TRNSFERING DATA TO TEMP TABLE AND CREATION OF TABLE  </s9qtitle>
<s9qpgmtype>L</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>
if exists (select * from dbo.sysobjects where id = object_id(N'[dbo].[xtempacceptdisplaydtls]') 
and OBJECTPROPERTY(id, N'IsUserTable') = 1)
drop table [dbo].[xtempacceptdisplaydtls]
-GO-
update AcceptDisplayDtls set AcptDatatype=2,DispDatatype=2 where [index] in (53,56,59,62,65)
-GO-
select * into xtempacceptdisplaydtls from AcceptDisplayDtls
-GO-
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0002</s9qScriptID>
<s9qtitle>Dropping of table and creation  </s9qtitle>
<s9qpgmtype>L</s9qpgmtype>
<s9qpgmtype>I</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qQryType>DDL</s9qQryType>
<s9qScript>

if exists (select * from dbo.sysobjects where id = object_id(N'[dbo].[AcceptDisplayDtls]') 
and OBJECTPROPERTY(id, N'IsUserTable') = 1)
drop table [dbo].[AcceptDisplayDtls]

-GO-
CREATE TABLE [dbo].[AcceptDisplayDtls] (
	[trntype] [int] NOT NULL ,
	[Index] [int] NOT NULL ,
	[AcptCap] [varchar] (50)   NULL ,
	[DispCap] [varchar] (50)   NULL ,
	[AcptVisible] [bit] NULL ,
	[DispVisible] [bit] NULL ,
	[AcptPos] [int] NULL ,
	[DispPos] [int] NULL ,
	[AcptDataType] [int] NULL ,
	[DispDataType] [int] NULL ,
	[AcptWidth] [real] NULL ,
	[DispWidth] [real] NULL ,
	[AcptAlign] [int] NULL ,
	[DispAlign] [int] NULL ,
	[AcptFontName] [varchar] (50)   NULL ,
	[DispFontName] [varchar] (50)   NULL ,
	[AcptFourColour] [varchar] (50)   NULL ,
	[DispFourColour] [varchar] (50)   NULL ,
	[AcptFontSize] [real] NULL ,
	[DispFontSize] [real] NULL ,
	[AcptRowHight] [real] NULL ,
	[DispRowHight] [real] NULL ,
	[AcptBackColour] [varchar] (50)   NULL ,
	[DispBackColour] [varchar] (50)   NULL ,
	[VAUid] [varchar] (32)   NULL ,
	[VActr] [int] NULL ,
	[VATermId] [varchar] (32)   NULL ,
	[VACompCode] [varchar] (16)   NULL 
) ON [PRIMARY]
-GO-
ALTER TABLE [dbo].[AcceptDisplayDtls] WITH NOCHECK ADD 
	CONSTRAINT [PK_AcceptDisplayDtls] PRIMARY KEY  CLUSTERED 
	(	[trntype],
		[Index]
	)  ON [PRIMARY] 
-GO-
</s9qScript>
</s9qsqlblk>



<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0003</s9qScriptID>
<s9qtitle>TRNSFERING DATA from temp table TO main TABLE </s9qtitle>
<s9qpgmtype>L</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>

--insert into Acceptdisplaydtls select 2100, * from xtempacceptdisplaydtls

insert into Acceptdisplaydtls(Trntype,[Index],AcptCap,DispCap,AcptVisible,DispVisible,AcptPos,DispPos,AcptDataType,DispDataType,AcptWidth,DispWidth,AcptAlign,DispAlign,AcptFontName,DispFontName,AcptFourColour,DispFourColour,AcptFontSize,DispFontSize,AcptRowHight,DispRowHight,AcptBackColour,DispBackColour,VAUid,VActr,VATermId,VACompCode)
select 2100,[Index],AcptCap,DispCap,AcptVisible,DispVisible,AcptPos,DispPos,AcptDataType,DispDataType,AcptWidth,DispWidth,AcptAlign,DispAlign,AcptFontName,DispFontName,AcptFourColour,DispFourColour,AcptFontSize,DispFontSize,AcptRowHight,DispRowHight,AcptBackColour,DispBackColour,VAUid,VActr,VATermId,VACompCode from xtempacceptdisplaydtls

-GO-
INSERT INTO Acceptdisplaydtls(Trntype,[Index],AcptCap,DispCap,AcptVisible,DispVisible,AcptPos,DispPos,AcptDataType,DispDataType,AcptWidth,DispWidth,AcptAlign,DispAlign,AcptFontName,DispFontName,AcptFourColour,DispFourColour,AcptFontSize,DispFontSize,AcptRowHight,DispRowHight,AcptBackColour,DispBackColour,VAUid,VActr,VATermId,VACompCode)VALUES(  2100,141,'IsRateorAmt','IsRateorAmt',0,0,141,141,1,1,0,0,2,2,' ',' ',' ',' ',0,0,0,0,' ',' ',' ',1,' ',' ')
