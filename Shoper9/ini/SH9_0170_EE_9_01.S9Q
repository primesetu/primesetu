UPDATE ITEMMASTER SET BatchSrlNo = T.BatchSrlNo,IsInventoryItem =T.IsInventoryItem,ImagePresent=T.ImagePresent,                                                    
SrcTaxType=T.SrcTaxType,ExtDescPresent=T.ExtDescPresent,ReordLvl=T.ReordLvl,EOQ=T.EOQ,MinOrdQty=T.MinOrdQty,                                                    
IsBillable=T.IsBillable,IsService=T.IsService,RtlMarkUp=T.RtlMarkUp,DlrMarkUp=T.DlrMarkUp,MfgDate=T.MfgDate,                                                    
ExpDate=T.ExpDate,ShelfLife=T.ShelfLife,CCStockNo=T.CCStockNo,FinalMRP=T.FinalMRP,IsConsignmentItem=T.IsConsignmentItem,VActr = @vaCtr                                                    
FROM TMPPRICEMASTER AS T ,ITEMMASTER WHERE T.STOCKNO=ITEMMASTER.STOCKNO                                                    
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                                 
