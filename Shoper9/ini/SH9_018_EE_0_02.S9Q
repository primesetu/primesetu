IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[ReportConfigSettings]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[ReportConfigSettings](
	[ConfigurationName] [varchar](64) NOT NULL,
	[TaskID] [varchar](64) NOT NULL,
	[Configuration] [text] NULL,
	[Status] [tinyint] NULL,
 CONSTRAINT [PK_ReportConfigSettings] PRIMARY KEY CLUSTERED 
(
	[ConfigurationName] ASC,
	[TaskID] ASC
)
)
END
-GO-
TRUNCATE TABLE [dbo].[ReportConfigSettings] 
-GO-
INSERT [dbo].[ReportConfigSettings] ([ConfigurationName], [TaskID], [Configuration], [Status]) VALUES ('Default', '201', '<SETTINGS><CONFIGURATION><REPORTTITLE>Sales Summary Report</REPORTTITLE><TRANSACTIONTYPE>POSStockSummary</TRANSACTIONTYPE><REPEATFIELD></REPEATFIELD></CONFIGURATION><PERIOD><TODATE>17/06/2011</TODATE><FROMDATE>17/06/2011</FROMDATE><PERIODTYPE>Current Month</PERIODTYPE><DATETYPE>PERIOD</DATETYPE></PERIOD><VALUES><FIELD><NAME>SaleQuantity</NAME><CAPTION>Sale Quantity</CAPTION></FIELD><FIELD><NAME>SaleValue</NAME><CAPTION>Sale Value</CAPTION></FIELD></VALUES><PARTICULARS><FIELD><NAME>Class1Desc</NAME><CAPTION>Secondary Category Desc</CAPTION><INDEX>0</INDEX></FIELD><FIELD><NAME>Class2Desc</NAME><CAPTION>Vendor Desc</CAPTION><INDEX>1</INDEX></FIELD></PARTICULARS><FILTER><ANDCLAUSE><CONDITION>BETWEEN</CONDITION><TEMPLATE>TRANSACTIONDATE</TEMPLATE><VALUE>&#39;17/06/2011&#39; AND &#39;17/06/2011&#39;</VALUE></ANDCLAUSE></FILTER></SETTINGS>', 1)
