update dbo.stktrndtls set docentnetvalue=(docentnetvalue-abs(Diffval)) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and #valuemismatch.entsrlno= stktrndtls.entsrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval < 0
-GO-
update dbo.stktrndtls set docentaddons=(docentaddons+abs(Diffval)) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval < 0 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where std.trntype=#valuemismatch.trntype and std.trnctrlno=#valuemismatch.trnctrlno and std.docentaddons >0) 
-GO-
update dbo.stktrndtls set docentnetvalue=(docentnetvalue + Diffval) from  #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and #valuemismatch.entsrlno= stktrndtls.entsrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval > 0
-GO-
update dbo.stktrndtls set docentdedns=(docentdedns+Diffval) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and stktrndtls.trntype=1300 and #valuemismatch.Diffval > 0 and stktrndtls.entsrlno=(select min(entsrlno) from dbo.stktrndtls as std where std.trntype=#valuemismatch.trntype and std.trnctrlno=#valuemismatch.trnctrlno and std.docentdedns >0) 
-GO-
update dbo.stktrndtls set docentnetvalue= (docentvalue-docenttotdisc+docentaddons-docentdedns+DocEntAddonsTax) from #valuemismatch where #valuemismatch.trntype=stktrndtls.trntype and #valuemismatch.trnctrlno= stktrndtls.trnctrlno and stktrndtls.trntype=1300 
-GO-
update dbo.stktrnhdr set totdocaddons=std.docentaddons from dbo.stktrndtls as std ,#valuemismatch where #valuemismatch.trntype=stktrnhdr.trntype and #valuemismatch.trnctrlno=stktrnhdr.trnctrlno  and #valuemismatch.trntype=std.trntype and #valuemismatch.trnctrlno=std.trnctrlno and std.docentaddons >0 and stktrnhdr.trntype=1300 and stktrnhdr.SHOPERDBVER=730 
-GO-
update dbo.stktrnhdr set totdocdedns=std.docentdedns from dbo.stktrndtls as std ,#valuemismatch where #valuemismatch.trntype=stktrnhdr.trntype and #valuemismatch.trnctrlno=stktrnhdr.trnctrlno  and #valuemismatch.trntype=std.trntype and #valuemismatch.trnctrlno=std.trnctrlno and std.docentdedns >0 and stktrnhdr.trntype=1300 and stktrnhdr.SHOPERDBVER=730
-GO-

</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0024</s9qScriptID>
<s9qtitle>cORRECTING THE Net value mismatch between STD AND STH TABLE (TRANSACTION TYPE 1600 VOID ) </s9qtitle>
