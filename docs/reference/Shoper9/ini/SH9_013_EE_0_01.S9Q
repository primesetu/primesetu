		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 14. C1=All,C2=All,SC1=All,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 15. C1=All,C2=All,SC1=All,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd

		IF (@@ERROR <> 0)  
			BEGIN  
				SET @ErrorSave = 'Failure: Insertion to PromoMnIntermediate (Buy Item Details) ' + CAST(@@ERROR AS VARCHAR(32))  
				GOTO ERREXIT  
			END  

	END

	-- 14/07/2009, Replacing "ApplicableItems" field with "FreeOfferItemType" field, since Get Item, Item Selection Type Is Updated In "FreeOfferItemType".
	-- Where ever "ApplicableItems" field is present in the following Get Item SQL Stmts, it is replaced with "FreeOfferItemType"
	-- To Process Get Item Details
	BEGIN
		Insert Into PromoMnIntermediate
		(StockNo,SalesPromoCode,PromoDescription,BuyOrGetId  ,SetNo,ApplicableHappyHours,HappyHoursStartTime,HappyHoursEndTime,Weekdays,ApplicableCustomers,DefinationType, FixedOrVariable,ItemLvlDiscountType, ItemLvlDefVariesOnBuyingQty, ItemLvlBuyingRateValueCond ,UseIMTable,BUYANDGETSAMEITEMS)
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 3 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Stockno= B.Stockno 
		Union All
		-- 1. C1,C2,SC1,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 2. C1,C2,SC1,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 3. C1,C2,SC1,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd
		Union All
		-- 4. C1,C2,SC1,SC2=All,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 5. C1,C2,SC1=All,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 6. C1,C2,SC1=All,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 7. C1,C2,SC1=All,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd
		Union All
		-- 8. C1,C2,SC1=All,SC2=All,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 9. C1=All,C2=All,SC1,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 10. C1=All,C2=All,SC1,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 11. C1=All,C2=All,SC1,SC2=All,Size 
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd
		Union All
		-- 12. C1=All,C2=All,SC1,SC2=All,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 13. C1=All,C2=All,SC1=All,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 14. C1=All,C2=All,SC1=All,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 15. C1=All,C2=All,SC1=All,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,2,0, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C, itemmaster as b,PROMOMNgetITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 2 AND C.Status  = 1 AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		B.JwlCaratage = 2  AND A.Class1Cd = '<<ALL>>' AND A.Class2Cd = '<<ALL>>' AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd

		IF (@@ERROR <> 0)  
			BEGIN  
				SET @ErrorSave = 'Failure: Insertion to PromoMnIntermediate (Get Item Details) ' + CAST(@@ERROR AS VARCHAR(32))  
				GOTO ERREXIT  
			END  

	END

	-- Change JwlCaratage Value to 0, to represent NEW Items process is over(i.e: it becomes old items)
	UPDATE ITEMMASTER SET JwlCaratage = 0 WHERE JwlCaratage = 2
	IF (@@ERROR <> 0)  
		BEGIN  
			SET @ErrorSave = 'Failure: Change JwlCaratage Value to 0(Over) ' + CAST(@@ERROR AS VARCHAR(32))  
			GOTO ERREXIT  
		END  

COMMIT TRANSACTION  
Return (0)  

ERREXIT:  
	BEGIN  
		ROLLBACK TRANSACTION
		RAISERROR(@ErrorSave,16,1)   
		RETURN (-1)  
	END
-GO-
SET QUOTED_IDENTIFIER OFF 
-GO-
SET ANSI_NULLS ON 
-GO-
