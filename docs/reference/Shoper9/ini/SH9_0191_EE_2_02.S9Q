Update PurchOrdDtl set DocLineNetValue=DocLineGrossValue+ISNULL(SalesTaxAmt,0)+(ISNULL(AddOnBefTaxAmt,0)+ISNULL(AddOnAftTaxAmt,0)+ISNULL(AddOnBeftaxAprtndAmt,0)+ISNULL(AddOnAftTaxAprtndAmt,0))-(ISNULL(DeductBefTaxAmt,0)+ISNULL(DeductAftTaxAmt,0)+ISNULL(DeductBefTaxAprtndAmt,0)+ISNULL(DeductAftTaxAprtndAmt,0))-(ISNULL(DiscountBefTaxAmt,0)+ISNULL(DiscountAftTaxAmt,0)+ISNULL(DiscountBefTaxAprtndAmt,0)+ISNULL(DiscountAftTaxAprtndAmt,0)) 
-GO-
