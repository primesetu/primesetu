<S9QSQLBLK>
<S9QSCRIPTID>S9Q_013_2_0014</S9QSCRIPTID>
<S9QTITLE>Exitsing Data correcting in the Purchase Order (Header and Detail) Transaction Table</S9QTITLE>
<S9QPGMTYPE>D</S9QPGMTYPE>
<S9QVERSION>*</S9QVERSION>
<S9QENVIRONMENT>P</S9QENVIRONMENT>
<S9QRUNMULTIPLE>0</S9QRUNMULTIPLE>
<S9QSEVERITY>3</S9QSEVERITY>
<S9QQRYTYPE>DML</S9QQRYTYPE>
<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
<S9QSCRIPT>

INSERT INTO dbo.GENLOOKUP SELECT 102,'PO+' + PONOPREFIX,'PO#Purchase Order',NULL,MAX(POCTRLNO+1),'super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),'.',(select txt from dbo.sysparam where paramcode = 'CompanyCode') FROM dbo.PURCHORDHDR WHERE 'PO+' + PONOPREFIX NOT IN (SELECT CODE FROM dbo.GENLOOKUP WHERE RECID = 102) GROUP BY PONOPREFIX
-GO-
UPDATE dbo.PURCHORDHDR SET POVENDERTYPE = 'V',POVENDORID = SHOPERCOMP  FROM dbo.VENDORS WHERE SUPPID = CODE AND POVENDORID IS NULL
-GO-
UPDATE dbo.PURCHORDHDR SET POBILLTOVENDORID = SOURCECOMPCD  WHERE POBILLTOVENDORID IS NULL
-GO-
UPDATE dbo.PURCHORDHDR SET DOCREMARKS = ''  WHERE DOCREMARKS IS NULL
-GO-
UPDATE dbo.PURCHORDHDR SET POTYPE = 1,POSOURCE = 1, AddOnBeftaxHdrper = 0,AddOnAfttaxHdrper = 0,DeductBeftaxHdrper=0,DeductAfttaxHdrper=0,DiscountBeftaxHdrper=0,DiscountAfttaxHdrper=0  WHERE POTYPE = 0 
-GO-
UPDATE dbo.PURCHORDHDR SET SOURCECOMPCD = TXT  FROM dbo.SYSPARAM WHERE PARAMCODE = 'COMPANYCODE' AND SOURCECOMPCD IS NULL 
-GO-
UPDATE dbo.PURCHORDDTL SET SALESTAXPER =0  WHERE SALESTAXPER IS NULL 
-GO-
UPDATE dbo.PURCHORDDTL SET DELIVERYLOCATION = SOURCECOMPCD  Where DELIVERYLOCATION IS NULL
-GO-
UPDATE dbo.PURCHORDDTL SET DOCLINEGROSSVALUE = PURCHORDQTY * PURCHORDRATE  WHERE DOCLINEGROSSVALUE IS NULL 
-GO-
UPDATE dbo.PURCHORDDTL SET DOCLINENETVALUE = PURCHORDQTY * PURCHORDRATE  WHERE DOCLINENETVALUE IS NULL 
-GO-
UPDATE dbo.PURCHORDDTL SET POTYPE = 1,POAPPANLCOUNT = 0,POSOURCE = 1,POATTRIBUTELEVEL = '10000000000000000000000000000000000000'  WHERE POTYPE = 0 
-GO-
UPDATE dbo.PURCHORDDTL SET SOURCECOMPCD = TXT  FROM dbo.SYSPARAM WHERE PARAMCODE = 'COMPANYCODE' AND SOURCECOMPCD IS NULL 
-GO-

</S9QSCRIPT>
</S9QSQLBLK>


<S9QSQLBLK>
<S9QSCRIPTID>S9Q_013_2_0015</S9QSCRIPTID>
<S9QTITLE>Exitsing Data Correcting in the PT File (Header and Detail) Transaction Tabl</S9QTITLE>
<S9QPGMTYPE>D</S9QPGMTYPE>
<S9QVERSION>*</S9QVERSION>
<S9QENVIRONMENT>P</S9QENVIRONMENT>
<S9QRUNMULTIPLE>0</S9QRUNMULTIPLE>
<S9QSEVERITY>3</S9QSEVERITY>
<S9QQRYTYPE>DML</S9QQRYTYPE>
<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
<S9QSCRIPT>

Update dbo.PTInvoiceHdr Set PgmFlag = 'SR324400'  where pgmflag = 'DC Import'
-GO-
Update dbo.PTInvoiceDtl Set PgmFlag = 'SR324400'  where pgmflag = 'DC Import'
-GO-
Update a Set a.Qty=0 From dbo.PtInvoiceDtl a, dbo.PtInvoiceHdr b Where a.TrnType = b.TrnType and a.SuppCode = b.SuppCode and a.BillNo = b.BillNo and a.BillDate = b.BillDate and b.PgmFlag <> 'SR127000' and a.pgmflag = 'SR127000'
-GO-

</S9QSCRIPT>
</S9QSQLBLK>



<S9QSQLBLK>
<S9QSCRIPTID>S9Q_013_2_0016</S9QSCRIPTID>
<S9QTITLE>Existing Data Correction in the Transaction Table (STD and STH) for Tally Interface and Rounding the Value</S9QTITLE>
<S9QPGMTYPE>D</S9QPGMTYPE>
<S9QVERSION>*</S9QVERSION>
<S9QENVIRONMENT>P</S9QENVIRONMENT>
<S9QRUNMULTIPLE>0</S9QRUNMULTIPLE>
<S9QSEVERITY>3</S9QSEVERITY>
<S9QQRYTYPE>DML</S9QQRYTYPE>
<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
<S9QSCRIPT>

--Update dbo.StkTrnDtls Set DocEntTax = Round(DocEntTax,2), TaxComp1 = Round(DocEntTax,2), DocEntAddons = round(isnull(DocEntAddons,0),2),DocEntDedns = round(isnull(DocEntDedns,0),2), DocEntTotDisc = round(isnull(DocEntTotDisc,0),2), DocEntBillDisc = round(isnull(DocEntBillDisc,0),2), DocEntDisc = round(isnull(DocEntDisc,0),2), DocEntAftTaxAddons = round(isnull(DocEntAftTaxAddons,0),2), DocEntBefTaxAddons = round(isnull(DocEntBefTaxAddons,0),2), DocEntAftTaxDedns = round(isnull(DocEntAftTaxDedns,0),2),DocEntBefTaxDedns = round(isnull(DocEntBefTaxDedns,0),2), DocEntValue = round(DocEntValue,2), DocEntNetValue = round(DocEntNetValue,2) From dbo.StkTrnHdr a, dbo.StkTrnDtls b Where a.TrnType = b.TrnType and a.ShoperDbVer = 730 and b.TrnType in (1100,1200,1400,1500,2200,2300,2400,2500)
Update dbo.StkTrnDtls Set DocEntTax = Round(DocEntTax,2), TaxComp1 = Round(DocEntTax,2), StkUpdtRate=Round(StkUpdtRate,2), StkUpdtValueIn=Round(StkUpdtValueIn,2),StkUpdtValueOut=Round(StkUpdtValueOut,2),DocEntAddons = round(isnull(DocEntAftTaxAddons,0) + isnull(DocEntBefTaxAddons,0),2), DocEntDedns = round(isnull(DocEntAftTaxDedns,0)+isnull(DocEntBefTaxDedns,0),2), DocEntTotDisc = round(isnull(DocEntTotDisc,0),2), DocEntBillDisc = round(isnull(DocEntBillDisc,0),2), DocEntDisc = round(isnull(DocEntDisc,0),2), DocEntAftTaxAddons = round(isnull(DocEntAftTaxAddons,0),2), DocEntBefTaxAddons = round(isnull(DocEntBefTaxAddons,0),2), DocEntAftTaxDedns = round(isnull(DocEntAftTaxDedns,0),2),DocEntBefTaxDedns = round(isnull(DocEntBefTaxDedns,0),2), DocEntValue = round(DocEntValue,2), DocEntNetValue = round(DocEntNetValue,2) From dbo.StkTrnHdr a, dbo.StkTrnDtls b Where a.TrnType = b.TrnType and a.ShoperDbVer = 730 and b.TrnType in (1100,1200,1400,1500,2200,2300,2400,2500)
-GO-
Select TrnType,TrnCtrlNo,0 as MaxRow, Round(sum(DocEntValue),2) as TotValue, Round(sum(isnull(DocEntTotDisc,0)),2) as DiscTot, Round(sum(isnull(DocEntTax,0)),2) as TaxAmt, Round(Sum(isnull(DocEntBefTaxAddons,0)),2) as AddOnBTax, Round(Sum(isnull(DocEntAftTaxAddons,0)),2) as AddOnATax, Round(sum(isnull(DocEntAddons,0)),2) as AddOnTot, Round(Sum(isnull(DocEntBefTaxDedns,0)),2) as DednBTax, Round(Sum(isnull(DocEntAftTaxDedns,0)),2) as DednATax, Round(sum(isnull(DocEntDedns,0)),2) as DednTot, Round(sum(isnull(DocEntNetValue,0)),2) as NetVal1, Round(sum(isnull(DocEntValue,0))- sum(isnull(DocEntTotDisc,0))+sum(isnull(DocEntTax,0))+sum(isnull(DocEntAddons,0))-sum(isnull(DocEntDedns,0)),2) as NetVal2, 0.00 as DifAdd, 0.00 as DifDed, 123 as DbVer Into TempTrans From dbo.StkTrnDtls Where TrnType in (1100,1200,1400,1500,2200,2300,2400,2500) Group by TrnType,TrnCtrlNo Having sum(isnull(DocEntNetValue,0)) <> round(sum(isnull(DocEntValue,0))-sum(isnull(DocEntTotDisc,0))+sum(isnull(DocEntTax,0))+sum(isnull(DocEntAddons,0))-sum(isnull(DocEntDedns,0)),2)
-GO-
Update TempTrans Set DbVer = ShoperDbVer From dbo.StkTrnHdr a, TempTrans b Where b.TrnType = a.TrnType and a.TrnCtrlNo = b.TrnCtrlNo 
-GO-
Delete From TempTrans Where DbVer <> 730
-GO-
Update TempTrans Set DifDed = round((NetVal2-NetVal1),2) Where NetVal2-NetVal1>0
-GO-
Update TempTrans Set DifAdd = Round((NetVal1-NetVal2),2) Where NetVal1-NetVal2>0
-GO-
Update TempTrans Set DednATax = DednATax+DifDed
-GO-
Update TempTrans Set AddOnATax = AddOnATax+DifAdd
-GO-
Update TempTrans Set MaxRow = (Select Max(EntSrlNo) From dbo.StkTrnDtls Where StkTrnDtls.TrnType = TempTrans.Trntype and StkTrnDtls.TrnCtrlNo = TempTrans.TrnCtrlNo)
-GO-
Update dbo.StkTrnDtls SET DocEntBefTaxDedns = Round(DocEntBefTaxDedns+(a.DednBTax-b.SumDednBTax),2) From (Select Trntype,TrnCtrlNo,MaxRow,DednBTax from TempTrans where DednBTax>0) a, (Select Trntype,TrnCtrlNo,SUM(DocEntBefTaxDedns) as SumDednBTax From dbo.StkTrnDtls Where TrnType In (1100,1200,1400,1500,2200,2300,2400,2500) Group by Trntype,TrnCtrlNo) b, dbo.StkTrnDtls as c  Where a.TrnType = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo and a.TrnType = c.Trntype and a.TrnCtrlNo = c.TrnCtrlNo and c.EntSrlNo = a.MaxRow
-GO-
Update dbo.StkTrnDtls SET DocEntAftTaxDedns = Round(DocEntAftTaxDedns+(a.DednATax-b.SumDednATax),2) From (Select Trntype,TrnCtrlNo,MaxRow,DednATax from TempTrans where DednATax>0) a, (Select Trntype,TrnCtrlNo,SUM(DocEntAftTaxDedns) as SumDednATax From dbo.StkTrnDtls Where TrnType In (1100,1200,1400,1500,2200,2300,2400,2500) Group by Trntype,TrnCtrlNo) b, dbo.StkTrnDtls as c Where a.TrnType = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo and a.TrnType = c.Trntype and a.TrnCtrlNo = c.TrnCtrlNo and c.EntSrlNo = a.MaxRow
-GO-
Update dbo.StkTrnDtls SET DocEntBefTaxAddons = Round(DocEntBefTaxAddons+(a.AddOnBTax-b.SumAddOnBTax),2) From (Select Trntype,TrnCtrlNo,MaxRow,AddOnBTax from TempTrans where AddOnBTax>0) a, (Select Trntype,TrnCtrlNo,SUM(DocEntBefTaxAddons) as SumAddOnBTax From dbo.StkTrnDtls Where TrnType In (1100,1200,1400,1500,2200,2300,2400,2500) Group by Trntype,TrnCtrlNo) b, dbo.StkTrnDtls as c Where a.TrnType = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo and a.TrnType = c.Trntype and a.TrnCtrlNo = c.TrnCtrlNo and c.EntSrlNo = a.MaxRow
-GO-
Update dbo.StkTrnDtls SET DocEntAftTaxAddons = Round(DocEntAftTaxAddons+(a.AddOnATax-b.SumAddOnATax),2) From (Select Trntype,TrnCtrlNo,MaxRow,AddOnATax from TempTrans where AddOnATax>0) a, (Select Trntype,TrnCtrlNo,SUM(DocEntAftTaxAddons) as SumAddOnATax From dbo.StkTrnDtls Where TrnType In (1100,1200,1400,1500,2200,2300,2400,2500) Group by Trntype,TrnCtrlNo) b, dbo.StkTrnDtls as c Where a.TrnType = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo and a.TrnType = c.Trntype and a.TrnCtrlNo = c.TrnCtrlNo and c.EntSrlNo = a.MaxRow
-GO-
Update dbo.StkTrnDtls Set DocEntAddons = Round(DocEntBefTaxAddons+DocEntAftTaxAddons,2), DocEntDedns = Round(DocEntBefTaxDedns+DocEntAftTaxDedns,2) From dbo.StkTrnDtls a, TempTrans b Where a.Trntype = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo 
-GO-
Update dbo.StkTrnDtls SET TaxComp1 = DocEntTax From dbo.StkTrnDtls a, TempTrans b Where a.Trntype = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo 
-GO-
Update dbo.StkTrnDtls SET DocEntNetValue = Round((DocEntValue+DocEntTax+DocEntAddons)-(DocEntDedns+DocEntTotDisc),2) From dbo.StkTrnDtls a, TempTrans b Where a.Trntype = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo 
-GO-
Update dbo.StkTrnHdr Set TotDocValue = Round(isnull(a.DocEntValue,0),2), TotDocDisc = Round(isnull(DocEntTotDisc,0),2), TotDocTax = Round(isnull(DocEntTax,0),2), TaxComp1 = Round(isnull(DocEntTax,0),2), TotDocAddons = Round(isnull(DocEntAddons,0),2), TotDocDedns = Round(isnull(DocEntDedns,0),2), TotDocEntBefTaxAddons = Round(isnull(DocEntBefTaxAddons,0),2), TotDocEntBefTaxDedns = Round(isnull(DocEntBefTaxDedns,0),2), TotDocEntAftTaxAddons = Round(isnull(DocEntAftTaxAddons,0),2), TotDocEntAftTaxDedns = Round(isnull(DocEntAftTaxDedns,0),2), NetDocValue = Round(isnull(DocEntNetValue,0),2) From (Select Trntype,TrnCtrlNo,Sum(DocEntValue) as DocEntValue, sum(DocEntTotDisc) as DocEntTotDisc, sum(DocEntTax) as DocEntTax, Sum(DocEntAddons) as DocEntAddons, sum(DocEntDedns) as DocEntDedns, sum(DocEntBefTaxAddons) as DocEntBefTaxAddons, sum(DocEntBefTaxDedns) as DocEntBefTaxDedns, sum(DocEntAftTaxAddons) as DocEntAftTaxAddons, sum(DocEntAftTaxDedns) as DocEntAftTaxDedns, sum(DocEntNetValue) as DocEntNetValue From dbo.StkTrnDtls Where TrnType in (1100,1200,1400,1500,2200,2300,2400,2500) Group by Trntype,TrnCtrlNo ) a, dbo.StkTrnHdr b Where a.TrnType = b.Trntype and a.TrnCtrlNo = b.TrnCtrlNo and b.TrnType In (1100,1200,1400,1500,2200,2300,2400,2500) and b.ShoperDbVer = 730
-GO-
drop table TempTrans
-GO-

</S9QSCRIPT>
</S9QSQLBLK>


<S9QSQLBLK>
<S9QSCRIPTID>S9Q_013_2_0017</S9QSCRIPTID>
<S9QTITLE>Existing Data Correcting in the Transaction Table (STD and STH) for Void Transaction of Goods Inward and Goods outwards</S9QTITLE>
