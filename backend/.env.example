# ============================================================
# SMRITI-OS — Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase / Cloud PostgreSQL (used in CLOUD storage mode)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Local PostgreSQL (used in LOCAL_POSTGRES offline/LAN node mode)
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smriti_local

# ── Supabase Cloud ────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── [R1-A] ES256 JWK (optional) ──────────────────────────────────────────────
# Paste the full JWK JSON from: Supabase Dashboard → Settings → API → JWT Keys
# If your project uses ES256 algorithm, this is required.
# Leave blank if using HS256 (most common).
# SUPABASE_JWK_JSON={"kty":"EC","crv":"P-256","x":"...","y":"...","alg":"ES256"}
SUPABASE_JWK_JSON=

# ── [R1-B] Local Node Authentication ─────────────────────────────────────────
# SECRET: Signs local JWTs for LOCAL_POSTGRES offline node mode.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If blank, an ephemeral secret is auto-generated (tokens lost on server restart).
LOCAL_JWT_SECRET=

# PIN: Enables local login at POST /api/v1/auth/local-login
# Use a strong numeric or alphanumeric PIN (e.g. 6 digits).
# If blank, local login is disabled.
LOCAL_ADMIN_PIN=

# ── General ───────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_fallback
ANTHROPIC_API_KEY=your_anthropic_key
ENVIRONMENT=development

# ── Storage Mode ──────────────────────────────────────────────────────────────
# Options: CLOUD | LOCAL_POSTGRES | SOVEREIGN
STORAGE_MODE=LOCAL_POSTGRES

# ── Legacy MSSQL (SOVEREIGN mode only) ───────────────────────────────────────
MSSQL_SERVER=AITDL
MSSQL_DATABASE=SHOPER9WH1
MSSQL_USER=sa
MSSQL_PASSWORD=your_mssql_password
MSSQL_DRIVER=SQL Server

# ── Sync ──────────────────────────────────────────────────────────────────────
OFFLINE_SYNC_INTERVAL=30
