IF  EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[ReportDates]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
DROP TABLE [dbo].[ReportDates]
-GO-
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[ReportDates]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[ReportDates](
	[SNO] [int] NOT NULL,
	[TYPE] [char](2)  NOT NULL,
	[CAPTION] [varchar](64)  NULL,
	[FORMULA_TYPE] [char](1)  NULL,
	[FROM_DATE_FORMULA] [varchar](1024)  NULL,
	[TO_DATE_FORMULA] [varchar](1024)  NULL
)
END
-GO-
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (1, 'T1', 'Only Today', 'Q', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (2, 'T1', 'Current Week', 'Q', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-DATEPART(DW,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))+1,3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (3, 'T1', 'Last Week', 'Q', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-DATEPART(DW,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-6,3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-DATEPART(DW,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (4, 'T1', 'Current Month', 'Q', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-(DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1),3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (5, 'T1', 'Last Month', 'Q', 'SELECT CONVERT(CHAR(8),DATEADD(MONTH,-1,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')- DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))+1),3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-(DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (6, 'T1', 'Current Quarter', 'S', 'pGET_CURRENT_QUARTER', NULL)
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (7, 'T1', 'Last Quarter', 'S', 'pGET_LAST_QUARTER', NULL)
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (8, 'T1', 'Current Financial Year', 'Q', 'SELECT CASE WHEN MONTH((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))<MONTH(TXT+SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')) AS CHAR(4))) THEN CONVERT(CHAR(20),TXT +SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1 AS CHAR(4)),3) ELSE CONVERT(CHAR(20),TXT +SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')) AS CHAR(4)),3) END FROM SYSPARAM WHERE PARAMCODE LIKE ''FISCALMONTH''', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (9, 'T1', 'Last Financial Year', 'Q', 'SELECT CASE WHEN MONTH((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))<MONTH(TXT+SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')) AS CHAR(4))) THEN CONVERT(CHAR(20),TXT +SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-2 AS CHAR(4)),3) ELSE CONVERT(CHAR(20),TXT +SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1 AS CHAR(4)),3) END FROM SYSPARAM WHERE PARAMCODE LIKE ''FISCALMONTH''', 'SELECT CASE WHEN MONTH((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))<MONTH(TXT+SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')) AS CHAR(4))) THEN CONVERT(CHAR(8), DATEADD(DD,-1,TXT+SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1 AS CHAR(4))),3) ELSE CONVERT(CHAR(8), DATEADD(DD,-1,TXT+SPACE(1)+CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')) AS CHAR(4))),3) END FROM SYSPARAM WHERE PARAMCODE LIKE ''FISCALMONTH''' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (10, 'T1', 'Current Calendar Year', 'Q', 'SELECT CONVERT(CHAR(8), (SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')+1- DATEPART(DY,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')),3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (11, 'T1', 'Last Calendar Year', 'Q', 'SELECT CONVERT(CHAR(10),CAST(DAY(0) AS CHAR(1))+ CHAR(47) +CAST(MONTH(0)AS CHAR(1))+ CHAR(47) + CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1 AS CHAR(4)),3)', 'SELECT CONVERT(CHAR(10),CAST(DAY(0)+30 AS CHAR(2)) + CHAR(47) + CAST(MONTH(0)+11 AS CHAR(2))+ CHAR(47) + CAST(YEAR((SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1 AS CHAR(4)),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (12, 'T2', 'Current Month', 'Q', NULL, 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (13, 'T2', 'Last Week', 'Q', NULL, 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-DATEPART(DW,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (14, 'T2', 'Last Month', 'Q', NULL, 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-(DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (15, 'T4', 'Current Month', 'Q', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-(DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))-1),3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''),3)' )
INSERT [dbo].[ReportDates] ([SNO], [TYPE], [CAPTION], [FORMULA_TYPE], [FROM_DATE_FORMULA], [TO_DATE_FORMULA]) VALUES (16, 'T4', 'Last Month', 'Q', 'SELECT CONVERT(CHAR(8),DATEADD(MONTH,-1,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')- DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))+1),3)', 'SELECT CONVERT(CHAR(8),(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt'')-(DATEPART(DD,(SELECT Dt FROM Sysparam WHERE ParamCode = ''SHOPERSysDt''))),3)' )
-GO-
IF  EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[pGET_LAST_QUARTER]') AND OBJECTPROPERTY(id,N'IsProcedure') = 1)
DROP PROCEDURE [dbo].[pGET_LAST_QUARTER]
-GO-
IF  EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[pGET_CURRENT_QUARTER]') AND OBJECTPROPERTY(id,N'IsProcedure') = 1)
DROP PROCEDURE [dbo].[pGET_CURRENT_QUARTER]
-GO-
CREATE PROCEDURE [dbo].[pGET_CURRENT_QUARTER] @From_Dt CHAR(15) OUTPUT,@To_Dt CHAR(15) OUTPUT       
AS        
BEGIN       
DECLARE @FISCAL_DATE DATETIME       
DECLARE @MONTH VARCHAR(10)  
DECLARE @REFDATE DATETIME     
DECLARE @CUR_DATE DATETIME      
SET @MONTH=(SELECT TXT FROM SYSPARAM WHERE PARAMCODE LIKE 'FISCALMONTH')     
SET @REFDATE=(SELECT CONVERT(DATETIME, DT, 121) FROM SYSPARAM WHERE PARAMCODE = 'SHOPERSYSDT') 
IF MONTH(@REFDATE)< MONTH(@MONTH +' '+ CAST(YEAR(@REFDATE)-1  AS CHAR(15)))       
 SET @FISCAL_DATE=(SELECT @MONTH +' '+ CAST(YEAR(@REFDATE)-1  AS CHAR(15)))        
ELSE      
 SET @FISCAL_DATE= (SELECT @MONTH +' '+ CAST(YEAR(@REFDATE)  AS CHAR(15)))       
SET @CUR_DATE=(SELECT @REFDATE)       
IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),@FISCAL_DATE,103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,3,@FISCAL_DATE)),103) AS DATETIME)  
  BEGIN      
  SET @From_Dt=(SELECT CONVERT(CHAR(8),@FISCAL_DATE,3))      
  SET @To_Dt=(CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,3,@FISCAL_DATE)),3))      
  END      
ELSE        
 IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),DATEADD(MM,3,@FISCAL_DATE),103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,6,@FISCAL_DATE)),103) AS DATETIME)  
  BEGIN      
  SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,3,@FISCAL_DATE),3))       
  SET @To_Dt=(CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,6,@FISCAL_DATE)),3))      
  END      
 ELSE        
 IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),DATEADD(MM,6,@FISCAL_DATE),103)AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,9,@FISCAL_DATE)),103) AS DATETIME)  
  BEGIN      
  SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,6,@FISCAL_DATE),3))       
  SET @To_Dt=(CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,9,@FISCAL_DATE)),3))      
  END      
 ELSE       
 IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),DATEADD(MM,9,@FISCAL_DATE),103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,12,@FISCAL_DATE)),103) AS DATETIME)  
  BEGIN      
  SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,9,@FISCAL_DATE),3))       
  SET @To_Dt=(CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,12,@FISCAL_DATE)),3))      
  END      
      
 ELSE       
  BEGIN      
  SET @FROM_dT=(SELECT CONVERT(CHAR(8),DATEADD(MM,-3,@FISCAL_DATE),3))      
  SET @To_Dt=(CONVERT(CHAR(8),DATEADD(DD,-1,@FISCAL_DATE),3))      
  END      
      
SELECT @FROM_DT,@TO_DT      
END
-GO-
CREATE PROCEDURE [dbo].[pGET_LAST_QUARTER] @From_Dt CHAR(10) OUTPUT,@To_Dt CHAR(10) OUTPUT       
AS        
BEGIN       
DECLARE @FISCAL_DATE DATETIME       
DECLARE @MONTH VARCHAR(10)
DECLARE @REFDATE DATETIME
DECLARE @CUR_DATE DATETIME       
SET @MONTH=(SELECT TXT FROM SYSPARAM WHERE PARAMCODE LIKE 'FISCALMONTH')   
SET @REFDATE=(SELECT CONVERT(DATETIME, DT, 121) FROM SYSPARAM WHERE PARAMCODE = 'SHOPERSYSDT')
IF MONTH(@REFDATE)< MONTH(@MONTH +' '+ CAST(YEAR(@REFDATE)-1  AS CHAR(15)))       
 SET @FISCAL_DATE=(SELECT @MONTH +' '+ CAST(YEAR(@REFDATE)-1  AS CHAR(15)))        
ELSE      
 SET @FISCAL_DATE= (SELECT @MONTH +' '+ CAST(YEAR(@REFDATE)  AS CHAR(15)))       
    
SET @CUR_DATE=(SELECT @REFDATE)       
    
IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),@FISCAL_DATE,103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,3,@FISCAL_DATE)),103) AS DATETIME)  
BEGIN       
 SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,-3,@FISCAL_DATE),3))       
 SET @To_Dt=(SELECT CONVERT(CHAR(8),@FISCAL_DATE-1,3))     
END       
ELSE        
    
 IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),DATEADD(MM,3,@FISCAL_DATE),103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,6,@FISCAL_DATE)),103) AS DATETIME)  
 BEGIN       
  SET @From_Dt=(SELECT CONVERT(CHAR(8),@FISCAL_DATE,3))       
  SET @To_Dt=(SELECT CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,3,@FISCAL_DATE)),3))         
 END       
 ELSE        
    
  IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),DATEADD(MM,6,@FISCAL_DATE),103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,9,@FISCAL_DATE)),103) AS DATETIME)  
  BEGIN       
   SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,3,@FISCAL_DATE),3))       
   SET @To_Dt=(SELECT CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,6,@FISCAL_DATE)),3))          
  END       
  ELSE       
     
   IF CAST(CONVERT(CHAR(10),@CUR_DATE,103) AS DATETIME) BETWEEN CAST(CONVERT(CHAR(10),DATEADD(MM,9,@FISCAL_DATE),103) AS DATETIME) AND CAST(CONVERT(CHAR(10),DATEADD(DD,-1,DATEADD(MM,12,@FISCAL_DATE)),103) AS DATETIME)      
   BEGIN       
   SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,6,@FISCAL_DATE),3))       
   SET @To_Dt=(SELECT CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,9,@FISCAL_DATE)),3))         
   END       
          
   ELSE       
   BEGIN       
    SET @From_Dt=(SELECT CONVERT(CHAR(8),DATEADD(MM,-6,@FISCAL_DATE),3))       
    SET @To_Dt=(SELECT CONVERT(CHAR(8),DATEADD(DD,-1,DATEADD(MM,-3,@FISCAL_DATE)),3))           
   END       
         
SELECT @From_Dt,@To_Dt       
END 
-GO-
  </s9qScript>
</s9qsqlblk>
