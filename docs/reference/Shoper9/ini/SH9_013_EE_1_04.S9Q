<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>

insert into dbo.genlookup (Recid,Code,Descr,Flag,Number,VaUid,VaTermId,VaCompCode)
select 101,'2100','Sales',null,0,'super','.',(select txt from dbo.sysparam where paramcode = 'CompanyCode')
-GO-
insert into dbo.genlookup (Recid,Code,Descr,Flag,Number,VaUid,VaTermId,VaCompCode)
 select 101,'1600','Void Sales',null,0,'super','.',(select txt from dbo.sysparam where paramcode = 'CompanyCode')
-GO-
insert into dbo.genlookup (Recid,Code,Descr,Flag,Number,VaUid,VaTermId,VaCompCode)
 select 101,'1300','Sales Return',null,0,'super','.',(select txt from dbo.sysparam where paramcode = 'CompanyCode')
-GO-
insert into dbo.genlookup (Recid,Code,Descr,Flag,Number,VaUid,VaTermId,VaCompCode)
select 101,'4000','Pos Cash',null,0,'super','.',(select txt from dbo.sysparam where paramcode = 'CompanyCode')
-GO-
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0030</s9qScriptID>
<s9qtitle>Updating the Max contorl to the FOR SALES , SALES RETURN, VOID SALES AND POS CASH ENTRIES  </s9qtitle>
<s9qpgmtype>D</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>

update dbo.genlookup set number=(select isnull(max(TrnCtrlNo),0)+1 from dbo.stktrnhdr where trntype=2100) where recid=101 and code='2100'
-GO-
update dbo.genlookup set number=(select isnull(max(TrnCtrlNo),0)+1 from dbo.stktrnhdr where trntype=1600) where recid=101 and code='1600'
-GO-
update dbo.genlookup set number=(select isnull(max(TrnCtrlNo),0)+1 from dbo.stktrnhdr where trntype=1300) where recid=101 and code='1300'
-GO-
update dbo.genlookup set number=(select isnull(max(CtrlNo),0)+1 from dbo.Poscashtrn) where recid=101 and code='4000'
-GO-
update dbo.genlookup set Number=(select isnull(max(Docno),0)+1 from dbo.poscashtrn where entrytype=13 and DocNoPrefix= (select reverse(left(reverse(code),charindex('+',reverse(code),1)-1 )) from dbo.genlookup where recid=102 and code like '4000+13+%')) where recid=102 and code like '4000+13+%'
-GO-
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0031</s9qScriptID>
<s9qtitle>Insertion to the posmodedatadtls table for sales,sales return, void sales  </s9qtitle>
<s9qpgmtype>D</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>

insert into dbo.posmodedatadtls (fld1,fld2,fld3,fld4,fld5,fld6,fld7,fld8,fld9,fld10,fld11,fld12,VAUid,Vactr,VATermId,VACompCode,Shoperdbver) 
select '2100','1','1','Shoper',0,(select isnull(max(TrnCtrlNo),(select [number] from dbo.genlookup where recid=101 and code='2100')) from dbo.stktrnhdr where trntype=2100),'12:00:00Am',getdate(),'Super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),(select txt from dbo.sysparam where paramcode = 'CompanyCode'),'0','Super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),'.',(select txt from dbo.sysparam where paramcode = 'CompanyCode'),'730'
-GO-

insert into dbo.posmodedatadtls (fld1,fld2,fld3,fld4,fld5,fld6,fld7,fld8,fld9,fld10,fld11,fld12,VAUid,Vactr,VATermId,VACompCode,Shoperdbver) 
select '1300','1','1','Shoper',0,(select isnull(max(TrnCtrlNo),(select [number] from dbo.genlookup where recid=101 and code='1300')) from dbo.stktrnhdr where trntype=2100),'12:00:00Am',getdate(),'Super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),(select txt from dbo.sysparam where paramcode = 'CompanyCode'),'0','Super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),'.',(select txt from dbo.sysparam where paramcode = 'CompanyCode'),'730'
-GO-

insert into dbo.posmodedatadtls (fld1,fld2,fld3,fld4,fld5,fld6,fld7,fld8,fld9,fld10,fld11,fld12,VAUid,Vactr,VATermId,VACompCode,Shoperdbver) 
select '1600','1','1','Shoper',0,(select isnull(max(TrnCtrlNo),(select [number] from dbo.genlookup where recid=101 and code='1600')) from dbo.stktrnhdr where trntype=2100),'12:00:00Am',getdate(),'Super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),(select txt from dbo.sysparam where paramcode = 'CompanyCode'),'0','Super',(select intg from dbo.sysparam where paramcode = 'VaSysCounter'),'.',(select txt from dbo.sysparam where paramcode = 'CompanyCode'),'730'
-GO-
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0032</s9qScriptID>
<s9qtitle>Updating the Tax percentage for void records  </s9qtitle>
<s9qpgmtype>D</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>
update dbo.stktrndtls set stdTaxComp1Per = (select StdTaxComp1Per from dbo.stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ), 
stdTaxComp2Per = (select StdTaxComp2Per from dbo.stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ),
stdTaxComp3Per = (select StdTaxComp3Per from dbo.stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ),
stdTaxComp4Per = (select StdTaxComp4Per from dbo.stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ) ,
stdTaxComp5Per = (select StdTaxComp5Per from dbo.stktrndtls std1 where std.backRefTrnType =std1.TrnType and std.BackRefCtrlNo =std1.TrnCtrlNo and std.BackRefDocEntSrlNo =std1.EntSrlNo ) 
from dbo.stktrndtls std where trntype =1600
-GO-
</s9qScript>
</s9qsqlblk>


<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0033</s9qScriptID>
<s9qtitle>replacing the enter key from order remarks column  </s9qtitle>
<s9qpgmtype>D</s9qpgmtype>
<s9qenvironment>P</s9qenvironment>
<s9qQryType>DML</s9qQryType>
<s9qRunMultiple>0</s9qRunMultiple>
<s9qScript>
UPDATE dbo.ExpectedTrnHdr SET OrderRemarks = REPLACE(OrderRemarks, CHAR(13), '') where (OrderRemarks is not null or OrderRemarks <> '')
-GO-
UPDATE dbo.ExpectedTrnHdr SET OrderRemarks = REPLACE(OrderRemarks, CHAR(10), '')  where (OrderRemarks is not null or OrderRemarks <> '')
-GO-
</s9qScript>
</s9qsqlblk>



