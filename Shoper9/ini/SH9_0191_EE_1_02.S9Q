-GO-
update sysparam set txt= substring(txt,1,73) + replace(substring(txt,74,1),0,1) + substring(txt,75,LEN(txt)) FROM SYSPARAM WHERE PARAMCODE='ACCEPTEDITEMDTLSINET'
-GO-
update sysparam set txt= substring(txt,1,83) + replace(substring(txt,84,1),0,1) + substring(txt,85,LEN(txt)) FROM SYSPARAM WHERE PARAMCODE='ACCEPTEDITEMDTLSINET'
-GO-
  </s9qScript>
</s9qsqlblk>

