-GO-
update daybeginpgms set pgmdate=b.dt from daybeginpgms as a,(select dt from SysParam where ParamCode='shopersysdt') as b where pgmindex=1
-GO-
update daybeginpgms set vactr=b.intg from daybeginpgms as a,(select intg from SysParam where paramcode='vasyscounter') as b where pgmindex=1
