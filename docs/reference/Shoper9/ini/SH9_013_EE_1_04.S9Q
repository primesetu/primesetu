<s9qsqlblk>
<s9qScriptid>S9Q_013_1_0029</s9qScriptID>
<s9qtitle>INSERTION to GENLOOKUP RECORDS FOR SALES , SALES RETURN, VOID SALES AND POS CASH ENTRIES  </s9qtitle>
