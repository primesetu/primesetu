UPDATE dbo.CUSTOMERS SET CUSTCLASS1 = '.'  Where  CUSTCLASS1 IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET CUSTCLASS2 = '.'  Where  CUSTCLASS2 IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET CUSTCLASS3 = '.'  Where  CUSTCLASS3 IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET CUSTCLASS4 = '.'  Where  CUSTCLASS4 IS NULL
