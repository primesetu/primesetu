-GO-
INSERT INTO Acceptdisplaydtls(Trntype,[Index],AcptCap,DispCap,AcptVisible,DispVisible,AcptPos,DispPos,AcptDataType,DispDataType,AcptWidth,DispWidth,AcptAlign,DispAlign,AcptFontName,DispFontName,AcptFourColour,DispFourColour,AcptFontSize,DispFontSize,AcptRowHight,DispRowHight,AcptBackColour,DispBackColour,VAUid,VActr,VATermId,VACompCode)VALUES(  2100,143,'Remarks','Remarks',0,0,143,143,1,2,15,15,2,2,'','','','',0,0,0,0,'0','0','',1,'','')
-GO- 
update  Acceptdisplaydtls set vactr=(select intg from sysparam where paramcode='VaSysCounter')
-GO-
</s9qScript>
</s9qsqlblk>

<s9qsqlblk>
