-GO-
update sysparam set txt= substring(txt,1,33) + replace(substring(txt,34,1),0,1) + substring(txt,35,LEN(txt)) FROM SYSPARAM WHERE PARAMCODE='ACCEPTEDITEMDTLSINET'
-GO-
update sysparam set txt= substring(txt,1,43) + replace(substring(txt,44,1),0,1) + substring(txt,45,LEN(txt)) FROM SYSPARAM WHERE PARAMCODE='ACCEPTEDITEMDTLSINET'
-GO-
update sysparam set txt= substring(txt,1,53) + replace(substring(txt,54,1),0,1) + substring(txt,55,LEN(txt)) FROM SYSPARAM WHERE PARAMCODE='ACCEPTEDITEMDTLSINET'
-GO-
