UPDATE TallyPrintConfigHeader SET ReportName = T.ReportName, TcpLocation = T.TcpLocation, IsActive = T.IsActive, PrinterName = T.PrinterName, PrintPreview = T.PrintPreview, NoOfCopies = T.NoOfCopies FROM TallyPrintConfigHeader AS A JOIN BakTallyPrintConfigHeader AS T ON (A.Terminal = T.Terminal AND A.TrnType = T.TrnType AND A.ConfigName = T.ConfigName)
-GO-
UPDATE TallyPrintConfigDetails SET ParamValue = T.ParamValue FROM TallyPrintConfigDetails AS A JOIN BakTallyPrintConfigDetails AS T ON (A.ConfigName = T.ConfigName AND A.ParamName = T.ParamName)
-GO-
  </s9qScript>
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptid>S9Q_019_0_0004</s9qScriptid> 
  <s9qtitle></s9qtitle> 
  <s9qpgmtype>I</s9qpgmtype>  
  <s9qpgmtype>L</s9qpgmtype>  
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>1</s9qRunMultiple> 
  <s9qQryType>DDL</s9qQryType> 
  <s9qScript>
DROP TABLE ##TempReportConfig
-GO-
CREATE TABLE ##TempReportConfig
(
ConfigId int Identity (1,1) NOT NULL,
ConfigurationName varchar(64),
TaskId varchar(64),
Configuration text,
Status tinyint
)
-GO-
INSERT INTO ##TempReportConfig (ConfigurationName, TaskID, Configuration, Status ) SELECT ConfigurationName, TaskID, Configuration, Status FROM ReportConfigSettings
-GO-
DROP TABLE ReportConfigSettings
-GO-
CREATE TABLE ReportConfigSettings
(
ConfigId int NOT NULL,
ConfigurationName varchar(64),
TaskId varchar(64),
Configuration text,
Status tinyint
CONSTRAINT [PK_ReportConfigSettings] PRIMARY KEY CLUSTERED(ConfigId, TaskId)
)
-GO-
INSERT INTO ReportConfigSettings SELECT * FROM ##TempReportConfig
-GO-
DROP TABLE ##TempReportConfig
-GO-
DELETE FROM ReportConfigSettings WHERE ConfigurationName = 'Default' AND TaskId = '205'
-GO-
INSERT INTO ReportConfigSettings (ConfigId, ConfigurationName, TaskId, Configuration, Status) (SELECT (SELECT (MAX (ConfigId) + 1) FROM ReportConfigSettings), 'Default', 205, '<SETTINGS><CONFIGURATION><REPORTTITLE>Tender Summary Report</REPORTTITLE><COMPANYCODE></COMPANYCODE><COMPANYNAME></COMPANYNAME><TRANSACTIONTYPE>Payments</TRANSACTIONTYPE><REPEATFIELD></REPEATFIELD><MANDATORYFIELD></MANDATORYFIELD></CONFIGURATION><PERIOD><TODATE>09/06/2011</TODATE><FROMDATE>09/06/2011</FROMDATE><PERIODTYPE>Only Today</PERIODTYPE><DATETYPE>PERIOD</DATETYPE></PERIOD><VALUES><FIELD><NAME>AmountReceived</NAME><CAPTION>Net Amount</CAPTION></FIELD></VALUES><PARTICULARS><FIELD><NAME>EntryName</NAME><CAPTION>Transaction Type</CAPTION><INDEX>0</INDEX></FIELD><FIELD><NAME>PayModeDesc</NAME><CAPTION>Payment Mode</CAPTION><INDEX>1</INDEX></FIELD>  <FIELD><NAME>PayModeCode</NAME><CAPTION>Payment Code</CAPTION><INDEX>2</INDEX></FIELD><FIELD><NAME>CurrencyName</NAME><CAPTION>Currency Name</CAPTION><INDEX>3</INDEX></FIELD></PARTICULARS><FILTER><ANDCLAUSE><CONDITION>BETWEEN</CONDITION><TEMPLATE>TRANSACTIONDATE</TEMPLATE><VALUE>&#39;09/06/2011&#39; AND &#39;09/06/2011&#39;</VALUE></ANDCLAUSE></FILTER></SETTINGS>', 1)
-GO-
UPDATE ReportConfigSettings SET Configuration = '<SETTINGS><CONFIGURATION><REPORTTITLE>Stock Summary Report</REPORTTITLE><TRANSACTIONTYPE>StockSummary</TRANSACTIONTYPE><REPEATFIELD></REPEATFIELD></CONFIGURATION><PERIOD><TODATE>17/06/2011</TODATE><FROMDATE>17/06/2011</FROMDATE><PERIODTYPE>Current Month</PERIODTYPE><DATETYPE>PERIOD</DATETYPE></PERIOD><VALUES><FIELD><NAME>OpeningStockQuantity</NAME><CAPTION>Opening Quantity</CAPTION></FIELD><FIELD><NAME>OpeningStockValue</NAME><CAPTION>Opening Value</CAPTION></FIELD><FIELD><NAME>ClosingStockQuantity</NAME><CAPTION>Closing Quantity</CAPTION></FIELD><FIELD><NAME>ClosingStockValue</NAME><CAPTION>Closing Value</CAPTION></FIELD></VALUES><PARTICULARS><FIELD><NAME>Class1Desc</NAME><CAPTION>Secondary Category Desc</CAPTION><INDEX>0</INDEX></FIELD><FIELD><NAME>Class2Desc</NAME><CAPTION>Vendor Desc</CAPTION><INDEX>1</INDEX></FIELD></PARTICULARS><FILTER></FILTER></SETTINGS>' WHERE ConfigurationName = 'Default' AND TaskID = 202
-GO-
UPDATE ReportConfigSettings SET Configuration = '<SETTINGS><CONFIGURATION><REPORTTITLE>Stock Summary Report</REPORTTITLE><TRANSACTIONTYPE>StockSummary</TRANSACTIONTYPE><REPEATFIELD></REPEATFIELD></CONFIGURATION><PERIOD><FROMDATE>01/06/2011</FROMDATE><TODATE>17/06/2011</TODATE><DATETYPE>ASON</DATETYPE></PERIOD><VALUES><FIELD><NAME>ClosingStockQuantity</NAME><CAPTION>Closing Quantity</CAPTION></FIELD><FIELD><NAME>ClosingStockValue</NAME><CAPTION>Closing Value</CAPTION></FIELD></VALUES><PARTICULARS><FIELD><NAME>Class1Desc</NAME><CAPTION>Secondary Category Desc</CAPTION><INDEX>0</INDEX></FIELD><FIELD><NAME>Class2Desc</NAME><CAPTION>Vendor Desc</CAPTION><INDEX>1</INDEX></FIELD></PARTICULARS><FILTER></FILTER></SETTINGS>' WHERE ConfigurationName = 'Default' AND TaskID = 204
-GO-
  </s9qScript>
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptid>S9Q_019_0_0005</s9qScriptid> 
  <s9qtitle></s9qtitle> 
  <s9qpgmtype>I</s9qpgmtype>  
  <s9qpgmtype>L</s9qpgmtype>  
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>1</s9qRunMultiple> 
  <s9qQryType>DDL</s9qQryType> 
  <s9qScript>
IF EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[ReportDates]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
	DROP TABLE [dbo].[ReportDates]
END
-GO-
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[ReportDates]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[ReportDates](
	[SNO] [int] NOT NULL,
	[TYPE] [char](2) NOT NULL,
	[CAPTION] [varchar](64) NULL,
	[FORMULA_TYPE] [char](1) NULL,
