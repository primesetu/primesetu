<s9qsqlblk>
  <s9qScriptid>S9Q_019_1_0008</s9qScriptid> 
  <s9qtitle> iNSERT STATEMENT FOR Billing components and event base extesion return value</s9qtitle> 
  <s9qpgmtype>I</s9qpgmtype>  
  <s9qpgmtype>L</s9qpgmtype>  
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>1</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>

IF NOT EXISTS (SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'[dbo].[EventExtnKeyValueConfig]') AND type in (N'U'))
BEGIN
CREATE TABLE [dbo].[EventExtnKeyValueConfig](
	[ProgramId] [varchar](64) NOT NULL,
	[EventId] [varchar](64) NOT NULL,
	[SrlNo] [int] NOT NULL,
	[EventKeyValue] [varchar](64) NOT NULL,
	[DllName] Varchar(128),
	[VaUid] [varchar](32) NULL,
	[VaCtr] [int] NULL,
	[VaTermId] [varchar](32) NULL,
	[VaCompCode] [varchar](16) NULL,
 CONSTRAINT [PK_EventExtnKeyValueConfig] PRIMARY KEY CLUSTERED 
(
	[ProgramId] ASC,
	[EventId] ASC,
	[SrlNo] ASC,
	[EventKeyValue] ASC
)
) ON [PRIMARY]
END
-GO-
  </s9qScript>
</s9qsqlblk>

