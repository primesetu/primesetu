-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,10,'CREATE TABLE [dbo].[BakPrefixTerminalGroups]([TerminalGroupId] [varchar](16) NOT NULL,[SrlNo] [int] NOT NULL,[TerminalId] [varchar](16) NULL,[TerminalGroupDescr] [varchar](50) NOT NULL,[IsActive] Int NULL,[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32) NULL,[VaCompCode] [varchar](16) NULL,UpdFlag varchar(1))','',1,'.','')
-GO-
Update [DBO].[VersionwiseTblsScript] Set Vactr = (select intg from [DBO].sysparam where paramcode = 'VaSysCounter') where VerId=8
-GO-
Update Sysparam set Txt=txt + '#PrefixMaster' where txt not like '%#PrefixMaster%' AND ParamCode='AdlTablesToSync'
-GO-
Update Sysparam set Txt=txt + '#PrefixConfig' where txt not like '%#PrefixConfig%' AND ParamCode='AdlTablesToSync'
-GO-
Update Sysparam set Txt=txt + '#PrefixTerminalGroups' where txt not like '%#PrefixTerminalGroups%' AND ParamCode='AdlTablesToSync'
-GO-
Update Sysparam set Txt=txt + '#PrefixTrnLog' where txt not like '%#PrefixTrnLog%' AND ParamCode='AdlTablesToSync'
-GO-
Update Sysparam set Txt=txt + '#PrefixTrnNo' where txt not like '%#PrefixTrnNo%' AND ParamCode='AdlTablesToSync'
-GO-
</s9qScript>
</s9qsqlblk

