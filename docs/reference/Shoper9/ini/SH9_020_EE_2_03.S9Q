<S9QSQLBLK>
	<S9QSCRIPTID>S9Q_020_2_0005</S9QSCRIPTID>
	<S9QTITLE>Stock-Data Migration File for 2.0</S9QTITLE>
	<S9QPGMTYPE>D</S9QPGMTYPE>
	<S9QVERSION>*</S9QVERSION>
	<S9QENVIRONMENT>P</S9QENVIRONMENT>
	<S9QRUNMULTIPLE>1</S9QRUNMULTIPLE>
	<S9QSEVERITY>3</S9QSEVERITY>
	<S9QQRYTYPE>DML</S9QQRYTYPE>
	<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
	<S9QSCRIPT>

if not exists (Select * from GenLookUp where Recid = 14400 and Code like 'SR526500+PostInternalZipComponents%' and Descr = 'SR543100.ClsZipComponent')
Insert Into GenLookUp (Recid,Code,Descr,Flag) Values (14400,'SR526500+PostInternalZipComponents+1','SR543100.ClsZipComponent',1)
-GO-
if not exists (Select * from GenLookUp where Recid = 14400 and Code like 'SR526500+PostInternalSISComponents%' and Descr = 'SR543100.ClsSISComponent')
Insert Into GenLookUp (Recid,Code,Descr,Flag) Values (14400,'SR526500+PostInternalSISComponents+1','SR543100.ClsSISComponent',1)
-GO-
if not exists (Select * from GenLookUp where Recid = 14400 and Code like 'SR127000+InternalToCaptureAddonDedn%' and Descr = 'SR543600.ClsAddonDedn')
Insert Into GenLookUp (Recid,Code,Descr,Flag) Values (14400,'SR127000+InternalToCaptureAddonDedn+1','SR543600.ClsAddonDedn',1)
-GO-
Insert Into SysParam (Id,Descr,ParamCode,Txt,Opt) Values ('SR3-0901-0000457','Multiple Add-on and Deduction Applicable','WhetherMultipleAddonDednApplicable','NNNN','T')
-GO-
Insert Into SysParamExtd (Id,ParamCode,Fixed,Category,CatDescr,DispOrder) Values ('SR3-0901-0000457','Multiple Add-on and Deduction Applicable','Variable','09. Inwards','This Gives Inwards Parameters',41)
-GO-
Insert Into Sysparam (Id,Descr,ParamCode,Txt,Opt) Values ('SR3-0901-0000453','Auto calculate purchase tax based on predefined rates','AutoCalculatePurchaseTaxonPredefinedRates','NNNN','T')
-GO-
Insert Into SysparamExtd (Id,ParamCode,Fixed,Category,CatDescr,DispOrder) Values ('SR3-0901-0000453','AutoCalculatePurchaseTaxonPredefinedRates','Variable','09. Inwards','This Gives Inwards Parameters',40)
-GO-
Insert Into GenLookUp (Recid,Code,Descr) Values (141,'TZip','*2PT#?3ccc0103#?3sss0103#?2mm0102#?2dd0102#*4.ZIP')
-GO-
Update GenLookUp Set Descr = '*2PT#?2mm0102#?2dd0102#?3ccc0103#*1.#?3sss0103' Where Recid = 141 and Code in ('T2100','T9800','T9900')
-GO-
Update GenLookUp Set Descr = '*2TT#?2mm0102#?2dd0102#?3ccc0103#*1.#?3sss0103' Where Recid = 141 and Code in ('T2200')
-GO-
Update GenLookUp Set Descr = '*2RT#?2mm0102#?2dd0102#?3ccc0103#*1.#?3sss0103' Where Recid = 141 and Code in ('T2300')
-GO-
Update GenLookUp Set Descr = '*2AT#?2mm0102#?2dd0102#?3ccc0103#*1.#?3sss0103' Where Recid = 141 and Code in ('T2400')
-GO-
Update GenLookUp Set Descr = '*2MT#?2mm0102#?2dd0102#?3ccc0103#*1.#?3sss0103' Where Recid = 141 and Code in ('T2500')
-GO-
Update SysParam Set Intg = 1 Where ParamCode like 'PTFileToOverwriteOrAppend' 
-GO-
Update Sysparam Set Txt = '12' Where id = 'SR3-0602-0000050'
-GO-
Update GenLookUp Set Descr = '?3ccc0103#*2PT#?3sss0103#?2mm0102#?2dd0102#*4.ZIP' where Recid = 141 and Code = 'TZip'
-GO-
Delete from AcceptDisplayDtls where Trntype in (2200,2300,2500)
-GO-
Delete from TransactionComponentsDtls where Trntype in (2200,2300,2500)
-GO-
Delete from EventExtnFieldConfig where ProgramId in (2200,2300,2500)
-GO-
