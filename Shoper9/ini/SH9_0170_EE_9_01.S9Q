INSERT INTO STOCKMASTER (StockNo,BatchSrlNo,LocnId,YrOpBalQty,YrOpBalVal,CurBalQty,CurBalVal,
 VAUid,VActr,VATermId,VACompCode) SELECT StockNo,BatchSrlNo,0,0,0,0,0,VAUid,VActr,VATermId,VACompCode 
	FROM ITEMMASTER WHERE STOCKNO NOT IN (SELECT STOCKNO FROM STOCKMASTER)
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           

                             
COMMIT TRANSACTION                                     
set @returnValue=0                           
return (0)                                     
                                     
ErrorHandle:                                     
                                                          
begin                                     
 ROLLBACK transaction                                     
 RAISERROR('Error Occured in the Procedure',16,1) with nowait                                     
 set @returnValue = -1                                 
 return (-1)                                          
end     


