--Updating genlookup 320 entry if default bill formtype21 descr has been changed to include custom value
-- createing new billformtype and genlookup entries
DECLARE @DEFAULT_DESCR VARCHAR(256)
DECLARE @DESCR VARCHAR(256)

IF EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE LIKE '21+01%' AND DESCR<>'SR525700.GeneralPrinting')
BEGIN
SET @DEFAULT_DESCR='SR525700.GeneralPrinting';
SET @DESCR=(SELECT DESCR FROM GENLOOKUP WHERE RECID=320 AND CODE LIKE '21+01%')

UPDATE GENLOOKUP SET DESCR=@DEFAULT_DESCR WHERE RECID=320 AND CODE ='21+01';

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='21+02')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'21+02','99');

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='21+03')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'21+03','N');

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='21+04')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'21+04','Y#GENERALIZEDPRINTING');

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='90+01')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'90+01',''+@DESCR+'');

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='90+02')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'90+02','99');

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='90+03')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'90+03','N');

IF NOT EXISTS( SELECT * FROM GENLOOKUP WHERE RECID=320 AND CODE='90+04')
INSERT INTO GENLOOKUP (RECID,CODE,DESCR) VALUES(320,'90+04','Y#CUSTOMPRINTWRAPPER');

UPDATE SYSPARAM SET INTG=90 WHERE PARAMCODE='BILLFORMTYPE' AND INTG = 21;
END    
-GO-
UPDATE PRINTCONFIGSETTING SET CONFIGPARAMVALUE = (SELECT TXT FROM SYSPARAM WHERE PARAMCODE LIKE 'NoOfCopies') where configsettingid='DEFAULTCS' and configparamid='NoOfCopies'
-GO-
update [PrintNodeTrnConfigMaster] set printpreference = (select cast(Boolean As int) from sysparam where paramcode='POSPrintingON') where [TrnTypeIdentifier] in ('2100','1300','1600')
-GO-
update [PrintNodeTrnConfigMaster] set printpreference = (select cast(Boolean As int) from sysparam where paramcode='SlipPrintingOnOff') where [TrnTypeIdentifier] in ('9100','9200','9300','9400','9500','9600','9700','9800','9900')
-GO-
Insert into genlookup (recid,code,descr) values(320,'50+01','SR535300.ClsPrintingInterface')
-GO-
