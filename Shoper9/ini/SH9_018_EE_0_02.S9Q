CREATE TABLE [dbo].[PurgeLogHdr] 
(
[CtrlNumber] [int] NOT NULL ,
[PurgeDate] [datetime] NULL ,
[VaUid] [varchar] (32)   NULL ,
[Vactr] [int] NULL ,
[VaTermId] [varchar] (32)   NULL ,
[VaCompCode] [varchar] (16)   NULL ,
 CONSTRAINT [PK_PurgeLogHdr] PRIMARY KEY CLUSTERED 
(
	[CtrlNumber] ASC
 ) 
 )ON [PRIMARY]              
-GO-               
CREATE TABLE [dbo].[PurgeLogDtls] 
( 
[CtrlNumber] [int] NOT NULL ,
[SrlNo] [int] NOT NULL ,
[StockNo] [varchar] (32) NULL ,
[VaUid] [varchar] (32)   NULL , 
[Vactr] [int] NULL , 
[VaTermId] [varchar] (32)   NULL , 
[VaCompCode] [varchar] (16)   NULL , 
CONSTRAINT [PK_PurgeLogDtls] PRIMARY KEY  CLUSTERED 
(
	[CtrlNumber], 
	[SrlNo] 
)
)  ON [PRIMARY]
  </s9qScript>
</s9qsqlblk>

