if exists (select * from dbo.sysobjects where id = object_id(N'[dbo].[INSERTUPDATEPROMOMNINTERMEDIATE]') and OBJECTPROPERTY(id, N'IsProcedure') = 1) drop procedure [dbo].[INSERTUPDATEPROMOMNINTERMEDIATE]
-GO-
if exists (select * from dbo.sysobjects where id = object_id(N'[dbo].[SalesPromoProcessNewItems]') and OBJECTPROPERTY(id, N'IsProcedure') = 1) drop procedure [dbo].[SalesPromoProcessNewItems]
-GO-
CREATE PROCEDURE [dbo].[INSERTUPDATEPROMOMNINTERMEDIATE]  
 @StrTableName VARCHAR(100),  
 @returnValue  INT  OUTPUT  
AS  
DECLARE    
	@StrSql                      VARCHAR(1024),  
	@ErrorSave                   VARCHAR(256),  
	@SPCodeCount INT

SET NOCOUNT ON  
SET @ErrorSave = ' '  

BEGIN TRANSACTION
	--INSERT INTO TEMPTIME VALUES ('BEFORE DELETE FROM STAGE0 TABLE...', getdate())

	SET @StrSql = 'delete from ' + @StrTableName + ' where SalesPromoCd in(select distinct SalesPromoCode from  PromoMnIntermediate)'
	EXECUTE( @StrSql)  

	--INSERT INTO TEMPTIME VALUES ('AFTER DELETE FROM STAGE0 TABLE...', getdate())

	Select @SPCodeCount = Count(*) From TmpinsertionfromStage0
	-- exit the loop IF no codes present in stage 0 table
	IF (@SPCodeCount = 0)
		BEGIN
		-- sree on 07/08/2008, Donot change "NoNewSPCodesToProcess" in the following If Condition,
		-- since it is raised in Stored Procedure, when no Sp codes to process
		   SET @ErrorSave = 'NoNewSPCodesToProcess'
		   GOTO ERREXIT  
		END
		
	-- NOTE ----  
	-- sree on 03/02/2009 -- Following new logic written to populate Intermediate table to avoid "COALESCE" related performance issues
	-- 21/10/2009 -- Modified to properly indicate Set No In Each Sales Promo
	-- To Process Buy Item Details (For All Items)
	BEGIN
		--INSERT INTO TEMPTIME VALUES ('Start FOR ALL ITEMS ...', getdate())
		-- 26/09/2009
		-- Set No Is Udpated From Main Table Value
		Insert Into PromoMnIntermediate
		(StockNo,SalesPromoCode,PromoDescription,BuyOrGetId,SetNo,ApplicableHappyHours,HappyHoursStartTime,HappyHoursEndTime,Weekdays,ApplicableCustomers,DefinationType, FixedOrVariable,ItemLvlDiscountType,ItemLvlDefVariesOnBuyingQty, ItemLvlBuyingRateValueCond ,UseIMTable,ItemDiscPercent,ItemDiscAmount,ItemDiscountedRate,ItemMaxDiscPercent,ItemMaxDiscAmount ,BuyingQuantity,BUYANDGETSAMEITEMS)
		select 'FOR ALL ITEMS',A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,	C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,
		case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,PROMOMNBUYITEMGRPDTLS as A
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 1 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode
		--INSERT INTO TEMPTIME VALUES ('END FOR ALL ITEMS ...', getdate())
		IF (@@ERROR <> 0)  
			BEGIN  
				SET @ErrorSave = 'Failure: Insertion to PromoMnIntermediate (All-Items-Buy) ' + CAST(@@ERROR AS VARCHAR(32))  
				GOTO ERREXIT  
			END  
	END

	-- 14/07/2009, Replacing "ApplicableItems" field with "FreeOfferItemType" field, since Get Item, Item Selection Type Is Updated In "FreeOfferItemType".
	-- Where ever "ApplicableItems" field is present in the following Get Item SQL Stmts, it is replaced with "FreeOfferItemType"
	-- To Process Get Item Details (For All Items)
	BEGIN
		--INSERT INTO TEMPTIME VALUES ('Start FOR ALL ITEMS ...', getdate())
		Insert Into PromoMnIntermediate
		(StockNo,SalesPromoCode,PromoDescription,BuyOrGetId,SetNo,ApplicableHappyHours,HappyHoursStartTime,HappyHoursEndTime,Weekdays,ApplicableCustomers,DefinationType, FixedOrVariable,ItemLvlDiscountType,ItemLvlDefVariesOnBuyingQty, ItemLvlBuyingRateValueCond ,UseIMTable,ItemDiscPercent,ItemDiscAmount,ItemDiscountedRate,ItemMaxDiscPercent,ItemMaxDiscAmount ,BuyingQuantity,BUYANDGETSAMEITEMS)
		select 'FOR ALL ITEMS',A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,	C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,PROMOMNGETITEMGRPDTLS as A
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.FreeOfferItemType = 1 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode
		--INSERT INTO TEMPTIME VALUES ('END FOR ALL ITEMS ...', getdate())
		IF (@@ERROR <> 0)  
			BEGIN  
				SET @ErrorSave = 'Failure: Insertion to promomnintermediate (All-Items-Get) ' + CAST(@@ERROR AS VARCHAR(32))  
				GOTO ERREXIT  
			END  
	END
	-- End FOR ALL ITEMS    

		
	-- To Process Buy Item Details
	BEGIN	
		Insert Into PromoMnIntermediate
		(StockNo,SalesPromoCode,PromoDescription,BuyOrGetId,SetNo,ApplicableHappyHours,HappyHoursStartTime,HappyHoursEndTime,Weekdays,ApplicableCustomers,DefinationType, FixedOrVariable,ItemLvlDiscountType, ItemLvlDefVariesOnBuyingQty, ItemLvlBuyingRateValueCond ,UseIMTable,ItemDiscPercent,ItemDiscAmount,ItemDiscountedRate,ItemMaxDiscPercent,ItemMaxDiscAmount ,BuyingQuantity,BUYANDGETSAMEITEMS)
		-- 0. Stockno
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 3 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Stockno= B.Stockno 
		Union All
		-- 1. C1,C2,SC1,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 2. C1,C2,SC1,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 3. C1,C2,SC1,SC2=All,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = B.SizeCd
		Union All
		-- 4. C1,C2,SC1,SC2=All,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = B.SubClass1Cd AND A.SubClass2Cd = '<<ALL>>' AND A.SizeCd = '<<ALL>>'
		Union All
		-- 5. C1,C2,SC1=All,SC2,Size
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = B.SizeCd
		Union All
		-- 6. C1,C2,SC1=All,SC2,Size=All
		select b.stockno,A.salespromocode,C.SalesPromoDesc,1,A.ItemSetNo, C.ApplicableHappyHours,C.HappyHoursStartTime,C.HappyHoursEndTime,C.WeekDays,C.ApplicableCustomers,C.DefinitionType,C.FixedOrVariable,C.ItemLvlDiscountType,C.ItemLvlDefVariesOnBuyingQty,C.ItemLvlBuyingRateValueCond,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then 1 ELSE 2 end,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMDISCOUNTEDRATE ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCPERCENT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMMAXDISCAMOUNT ELSE NULL END,case C.ITEMLVLDEFVARIESONBUYINGQTY + C.MultipleRateCond when 0 then d.ITEMLVLDISCBUYQTY ELSE NULL END,C.ItemLvlOfferBuyNGetItemsAreSame
		from promomnheader as C LEFT OUTER JOIN PROMOMNITEMLVLDISCDTLS as d on C.SalesPromocode = d.SalesPromocode and d.srlno=1 ,ItemMaster as b,PROMOMNBUYITEMGRPDTLS as A 
		where C.salespromocode In (Select SalesPromoCd From TmpinsertionfromStage0) And C.ApplicableItems = 2 AND C.Status  In(1,9) AND A.ItemIncExFlag =1 AND C.SalesPromocode = A.salespromocode  and 
		ISNULL(B.JwlCaratage,0) = 0  AND A.Class1Cd = B.Class1Cd AND A.Class2Cd = B.Class2Cd AND A.SubClass1Cd = '<<ALL>>' AND A.SubClass2Cd = B.SubClass2Cd AND A.SizeCd = '<<ALL>>'
		Union All
		-- 7. C1,C2,SC1=All,SC2=All,Size
