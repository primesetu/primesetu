CREATE PROCEDURE UpdatePromoMnIntermediate
@StrTableName Nvarchar(100)
 AS
declare
@strSql varchar(500)

	set dateformat dmy 
	
	begin	
		set @strSql = 'Update  PromoMnIntermediate set Status=PMH.Status,PriorityNo=PMH.PriorityNo,
		StartDate=PMH.startDate,EndDate=Pmh.Enddate from PromoMnHeader as PMH where 
		pmh.SalesPromoCode=PromoMnIntermediate.SalesPromoCode and pmh.SalesPromoCode in (select SalesPromoCd from ' + @StrTableName +')'
		--print @strSql
		execute(@strSql)
		set @strSql ='Drop Table  '+@StrTableName
		execute(@strSql)
	end
