CREATE TRIGGER Tr_Ins_ItemMaster ON ItemMaster FOR INSERT AS UPDATE ItemMaster SET JwlCaratage =1 FROM INSERTED WHERE INSERTED.STOCKNO = ItemMaster.StockNo
-GO-
ALTER TRIGGER [Tr_Ins_ItemMaster] ON [dbo].[ItemMaster] FOR INSERT 
AS 
SET NOCOUNT ON
Select StockNo Into #TmpIMINSERTED From INSERTED 
UPDATE ItemMaster SET JwlCaratage =1 FROM #TmpIMINSERTED WHERE #TmpIMINSERTED.STOCKNO = ItemMaster.StockNo
DROP Table #TmpIMINSERTED
-GO-
