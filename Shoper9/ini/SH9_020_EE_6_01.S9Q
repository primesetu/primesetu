<s9qsqlblk>
<s9qScriptID>S9Q_020_6_0001</s9qScriptID>
<s9qtitle>Security Database Script</s9qtitle>
<s9qpgmtype>I</s9qpgmtype>
<s9qpgmtype>L</s9qpgmtype>
<s9qversion>*</s9qversion>
<s9qenvironment>M</s9qenvironment>
<s9qRunMultiple>1</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>
CREATE TABLE [PrintDesignerCategory](
	[CatID] [Varchar] (50) Not NULL, 
	[CategoryCap] [Varchar] (250) NOT NULL,
	[CategoryParent] [Varchar] (50) NOT NULL,
	[DisplayOrder] [Int] NOT NULL,
	[CatActive] [Int] NOT NULL,	
	[CatCreationType] [Varchar] (16) NOT NULL,
	[CatType] [Varchar] (16) NOT NULL,
	[CatRemarks] [Varchar] (250),	
	[AdditionalCatDetail1] [Varchar] (250),
	[AdditionalCatDetail2] [Varchar] (250),
	[AdditionalCatDetail3] [Varchar] (250),
	[AdditionalCatDetail4] [Varchar] (250),
	[AdditionalCatDetail5] [Varchar] (250),
	[AdditionalCatDetail6] [Varchar] (250),
	[VAUid] [Varchar] (32),
	[VActr] [Int],
	[VATermId] [Varchar] (32),
	[VACompCode] [Varchar] (16)
)
-GO-
ALTER TABLE [dbo].[PrintDesignerCategory] WITH NOCHECK ADD CONSTRAINT [PK_PrintDesignerCategory] PRIMARY KEY CLUSTERED 
(
	[CatID],
	[CategoryCap],
	[CategoryParent]
)  ON [PRIMARY]
-GO-
CREATE TABLE [PrintDesignerFields]
(	
	[CatRefID] [Varchar] (50) NOT NULL,
	[FieldName] varchar(250) NOT NULL,
	[FieldDisplayCaption] [Varchar] (250),
	[FieldDescription] [Varchar] (250) NOT NULL,
	[FieldDataType] [Varchar] (16) NOT NULL,		
	[FieldDisplayOrder] [Int] NOT NULL,
	[FieldPreviewData] [Varchar] (250),
	[FieldActive] [Int] NOT NULL,
	[FieldType] [Varchar] (16),
	[FieldRemarks] [Varchar] (250),
	[FieldEnv] [Varchar] (8),
	[SISTemplateName] [Varchar] (250),
	[SetupType] [Varchar] (16),
	[CompCode] [Varchar] (16) NOT NULL,
	[TrnType] [Varchar] (250)  NOT NULL,
	[FieldKeyID] [Varchar] (250) NOT NULL,
	[isGeneralField] [Int] NULL,
	[AdditionalFieldDetail1] [Varchar] (250),
	[AdditionalFieldDetail2] [Varchar] (250),
	[AdditionalFieldDetail3] [Varchar] (250),
	[AdditionalFieldDetail4] [Varchar] (250),
	[AdditionalFieldDetail5] [Varchar] (250),
	[AdditionalFieldDetail6] [Varchar] (250),
	[VAUid] [Varchar] (32),
	[VActr] [Int],
	[VATermId] [Varchar] (32),
	[VACompCode] [Varchar] (16)
)
-GO-
ALTER TABLE [dbo].[PrintDesignerFields] WITH NOCHECK ADD CONSTRAINT [PK_PrintDesignerFields] PRIMARY KEY CLUSTERED (
	[CatRefID],
	[FieldName],
	[CompCode],
	[TrnType],
	[FieldKeyID]
)  ON [PRIMARY]
-GO-
</s9qScript>
</s9qsqlblk>

