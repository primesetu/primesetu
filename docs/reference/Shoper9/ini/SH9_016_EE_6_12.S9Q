(
	SELECT * from sysparam WHERE paramcode = 'ShoperEnv' and Txt='D'
)
INSERT INTO SysParamExtd(Id,ParamCode,Fixed,Changed,Category,CatDescr,DispOrder)  Values('SR1-0901-0000341','PrnSKUORItemWiseExtnFields','Variable','0','14. Bill - Printing','This Gives Bill - Printing Parameters','9')
-GO-
