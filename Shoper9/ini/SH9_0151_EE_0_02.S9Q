INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,1,'CREATE TABLE [dbo].[PrefixTrnNo]([TrnType] [varchar](10)  NOT NULL,	[ActualPrefix] [varchar](8) NOT NULL,[DocNumber] [int] NOT NULL,[IsActive] Int Not NULL,[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32)  NULL,[VaCompCode] [varchar](16) NULL,CONSTRAINT [PK_PrefixTrnNo] PRIMARY KEY CLUSTERED ([TrnType] ASC,[ActualPrefix]))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,2,'CREATE TABLE [dbo].[BakPrefixTrnNo]([TrnType] [varchar](10)  NOT NULL,	[ActualPrefix] [varchar](8) NOT NULL,[DocNumber] [int] NOT NULL,[IsActive] Int Not NULL,[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32)  NULL,[VaCompCode] [varchar](16) NULL,UpdFlag varchar(1))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,3,'CREATE TABLE [dbo].[PrefixMaster]([Trntype] [varchar](10)  NOT NULL,[OPId] [varchar](10)  NOT NULL, [TerminalGroupId] [varchar](32)  NOT NULL,[Srlno] [int] NOT NULL,[Prefix] [varchar](8)  NULL,[BasePrefix] [varchar](8) NULL,[Suffix] [varchar](8) NULL,	[IsActive] Int NOT NULL,[ResetRequired] Int,[ResetType] Varchar(16),[VaUID] [varchar](32)  NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32) NULL,[VaCompCode] [varchar](16)  NULL,CONSTRAINT [PK_Prefixmaster] PRIMARY KEY CLUSTERED ([Trntype] ASC,[OPId] ASC,	[TerminalGroupId] ASC,[Srlno] ASC))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,4,'CREATE TABLE [dbo].[BakPrefixMaster]([Trntype] [varchar](10)  NOT NULL,[OPId] [varchar](10)  NOT NULL, [TerminalGroupId] [varchar](32)  NOT NULL,[Srlno] [int] NOT NULL,[Prefix] [varchar](8)  NULL,[BasePrefix] [varchar](8) NULL,[Suffix] [varchar](8) NULL,	[IsActive] Int NOT NULL,[ResetRequired] Int,[ResetType] Varchar(16),[VaUID] [varchar](32)  NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32) NULL,[VaCompCode] [varchar](16)  NULL,UpdFlag varchar(1))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,5,'CREATE TABLE [dbo].[PrefixTrnLog]([Fld1] [varchar](8)  NOT NULL,[Fld2] [varchar](10) NOT NULL,[Fld3] [varchar](10) NULL,[Fld4] int NOT NULL,[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32)  NULL,[VaCompCode] [varchar](16) NULL, CONSTRAINT [PK_PrefixTrnLog] PRIMARY KEY CLUSTERED ([Fld1] ASC,[Fld2] ASC,[Fld4] ASC))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,6,'CREATE TABLE [dbo].[BakPrefixTrnLog]([Fld1] [varchar](8) NOT NULL,[Fld2] [varchar](10) NOT NULL,[Fld3] [varchar](10) NULL,[Fld4] int NOT NULL,[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32) NULL,[VaCompCode] [varchar](16) NULL,UpdFlag varchar(1))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,7,'CREATE TABLE [dbo].[PrefixConfig]([SlNo] [int] NOT NULL,[TrnType] [varchar](10) NOT NULL,[OPId] [varchar](10) NULL,[TrnName] [varchar](128) NOT NULL,[TrnSubName] [varchar](128) NOT NULL,[IsActive] Int NULL,[TerminalWisePrefix] Int Null,[NumberReset] Int Null,[SamePrefixforSubTran] Int Null,[ParentTrnType] Varchar(10),[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32) NULL,[VaCompCode] [varchar](16) NULL,CONSTRAINT [PK_PrefixConfig] PRIMARY KEY CLUSTERED ( SlNo ASC ))','',1,'.','')
-GO-
INSERT INTO [DBO].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (8,8,'CREATE TABLE [dbo].[BakPrefixConfig]([SlNo] [int] NOT NULL,[TrnType] [varchar](10) NOT NULL,[OPId] [varchar](10) NULL,[TrnName] [varchar](128) NOT NULL,[TrnSubName] [varchar](128) NOT NULL,[IsActive] Int NULL,[TerminalWisePrefix] Int Null,[NumberReset] Int Null,[SamePrefixforSubTran] Int Null,[ParentTrnType] Varchar(10),[VaUID] [varchar](32) NULL,[VaCtr] [int] NULL,[VaTermID] [varchar](32) NULL,[VaCompCode] [varchar](16) NULL,UpdFlag varchar(1))','',1,'.','')
