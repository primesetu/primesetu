update dbo.stktrndtls set StkUpdtValueOut=StkUpdtValuein,StkUpdtValuein=0 where Trntype = 2710 and StkupdtValueOut=0 and StkUpdtValuein > 0 
-GO-
update dbo.stktrndtls set Phyqtyout=Phyqtyin,PhyQtyin=0 where trntype=2720 and Phyqtyout=0 and phyqtyin > 0 
-GO-
update dbo.stktrndtls set StkUpdtValueOut=StkUpdtValuein,StkUpdtValuein=0 where Trntype = 2720 and StkupdtValueOut=0 and StkUpdtValuein > 0 
-GO-
update dbo.stktrndtls set Phyqtyout=Phyqtyin,PhyQtyin=0 where trntype=2730 and Phyqtyout=0 and phyqtyin > 0 
-GO-
update dbo.stktrndtls set StkUpdtValueOut=StkUpdtValuein,StkUpdtValuein=0 where Trntype = 2730 and StkupdtValueOut=0 and StkUpdtValuein > 0 
-GO-
update dbo.stktrndtls set Phyqtyout=Phyqtyin,PhyQtyin=0 where trntype=2740 and Phyqtyout=0 and phyqtyin > 0 
-GO-
update dbo.stktrndtls set StkUpdtValueOut=StkUpdtValuein,StkUpdtValuein=0 where Trntype = 2740 and StkupdtValueOut=0 and StkUpdtValuein > 0 
-GO-
update dbo.stktrndtls set Phyqtyin=Phyqtyout,Phyqtyout=0 where trntype=1710 and PhyqtyIn=0 and phyqtyOut > 0 
-GO-
update dbo.stktrndtls set StkUpdtValuein=StkUpdtValueOut,StkUpdtValueOut=0 where Trntype = 1710 and StkupdtValueIn=0 and StkUpdtValueOut > 0 
-GO-
update dbo.stktrndtls set Phyqtyin=Phyqtyout,Phyqtyout=0 where trntype=1720 and PhyqtyIn=0 and phyqtyOut > 0 
-GO-
update dbo.stktrndtls set StkUpdtValuein=StkUpdtValueOut,StkUpdtValueOut=0 where Trntype = 1720 and StkupdtValueIn=0 and StkUpdtValueOut > 0 
-GO-
update dbo.stktrndtls set Phyqtyin=Phyqtyout,Phyqtyout=0 where trntype=1730 and PhyqtyIn=0 and phyqtyOut > 0 
-GO-
update dbo.stktrndtls set StkUpdtValuein=StkUpdtValueOut,StkUpdtValueOut=0 where Trntype = 1730 and StkupdtValueIn=0 and StkUpdtValueOut > 0 
-GO-
update dbo.stktrndtls set Phyqtyin=Phyqtyout,Phyqtyout=0 where trntype=1740 and PhyqtyIn=0 and phyqtyOut > 0 
-GO-
update dbo.stktrndtls set StkUpdtValuein=StkUpdtValueOut,StkUpdtValueOut=0 where Trntype = 1740 and StkupdtValueIn=0 and StkUpdtValueOut > 0 
-GO-

</S9QSCRIPT>
</S9QSQLBLK>


<S9QSQLBLK>
<S9QSCRIPTID>S9Q_013_2_0018</S9QSCRIPTID>
<S9QTITLE>Existing Data Correcting in the Transaction Table (STD and STH) for updating the Tax components and Tally Interface</S9QTITLE>
<S9QPGMTYPE>D</S9QPGMTYPE>
<S9QVERSION>*</S9QVERSION>
<S9QENVIRONMENT>P</S9QENVIRONMENT>
<S9QRUNMULTIPLE>0</S9QRUNMULTIPLE>
<S9QSEVERITY>3</S9QSEVERITY>
<S9QQRYTYPE>DML</S9QQRYTYPE>
<S9QSENDFEEDBACK>1</S9QSENDFEEDBACK>
<S9QSCRIPT>

Update dbo.StkTrnDtls Set SField4 = '36402', StdTaxComp1Per= Taxcomp1, Taxcomp1 = DocEntTax Where TrnType in (2200,2300,2500) and DocEntTax>0 and StdTaxComp1Per = 0
-GO-
UPDATE dbo.STKTRNDTLS SET SRCTAXTYPE = 0  WHERE SRCTAXTYPE = '-N..A-' and TrnType in (1100,1200,1400,1500,2200,2300,2400,2500)
-GO-

</S9QSCRIPT>
</S9QSQLBLK>

<S9QSQLBLK>
<S9QSCRIPTID>S9Q_013_2_0019</S9QSCRIPTID>
<S9QTITLE>Physical Stock Taking - Inserting the Reasons for Stock Taking</S9QTITLE>
