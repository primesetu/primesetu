<s9qsqlblk>
  <s9qScriptID>S9Q_019_0_0001</s9qScriptID>
  <s9qtitle>Security Database Script</s9qtitle>
  <s9qpgmtype>I</s9qpgmtype>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>M</s9qenvironment>
  <s9qRunMultiple>1</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>
IF  EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[AlertHistory]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
DROP TABLE [dbo].[AlertHistory]
-GO-
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[AlertHistory]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[AlertHistory](
	[SerialNo] [varchar](64) NOT NULL,
	[EntrySerialNo] [int] NULL,
	[CompanyCode] [varchar](64) NULL,
	[AlertId] [int] NULL,
	[Application] [varchar](64) NULL,
	[Event] [varchar](64) NULL,
	[AlertMode] [varchar](64) NULL,
	[ExecutedTime] [datetime] NULL,
	[Status] [varchar](64) NULL,
	[Description] [varchar](8000) NULL,
 CONSTRAINT [PK_AlertHistory] PRIMARY KEY CLUSTERED 
(
	[SerialNo] ASC
)
)
END
</s9qScript>		
</s9qsqlblk>

<s9qsqlblk>
  <s9qScriptID>S9Q_019_0_0002</s9qScriptID>
  <s9qtitle>Security Database Script</s9qtitle>
  <s9qpgmtype>I</s9qpgmtype>
  <s9qpgmtype>L</s9qpgmtype>
  <s9qversion>*</s9qversion>
  <s9qenvironment>M</s9qenvironment>
  <s9qRunMultiple>1</s9qRunMultiple>
  <s9qQryType>DML</s9qQryType>
  <s9qScript>
IF  EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[SISSysParam]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
DROP TABLE [dbo].[SISSysParam]
-GO-
IF NOT EXISTS (SELECT * FROM dbo.sysobjects WHERE id = OBJECT_ID(N'[dbo].[SISSysParam]') AND OBJECTPROPERTY(id, N'IsUserTable') = 1)
BEGIN
CREATE TABLE [dbo].[SISSysParam](
	[Code] [varchar](32) NOT NULL,
	[Value] [varchar](256) NULL,
	[Default] [varchar](256) NULL,
	[DataType] [varchar](8) NULL,
	[DisplayName] [varchar](256) NULL,
	[Status] [varchar](16) NULL,
	[Description] [varchar](256) NULL
)
END
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('SISName', '', '', 'S', 'SIS Name', '2', 'Server name using which client can connect; Dynamically obtains machine name.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('SISPort', '', '9525', 'N', 'SIS Port', '1', 'Port number in which the server will be running.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('SISSrvcName', '', '', 'S', 'Service Name', '2', 'Service name of the server in the machine;')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('JCThrdSlpTime', '10', '10', 'N', 'JC Wait Time', '1', 'Job Controller thread sleep time after processing the job store; Specify in seconds.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('JCThrdSlpNetNtAv', '30', '30', 'N', 'JC Wait while N/w unavailable', '1', 'Job Controller thread sleep time when network is not available; Specify in minutes.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('MaxThrds', '10', '10', 'N', 'Maximum Threads', '1', 'Maximum threads that can be created for job processing; Specify number per processor.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('MinThrds', '0', '0', 'N', 'Minimum Threads', '1', 'Minimum threads which always be present for job processing; Specify number per processor.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('LogFilePath', '', '', 'S', 'Log File Path', '1', 'The path where log file Log.log is created; Dynamically obtains shoper share folder.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('TruncLogSize', '10', '10', 'N', 'Backup Threshold', '1', 'The max file size after which the log file will be truncated; Specify in MB.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('ThrdIdleTime', '60', '60', 'N', 'Thread Idle Time', '1', 'Idle time to wait for the job thread before getting destroyed; Specify in seconds.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('DBCmdTimeOut', '0', '15', 'N', 'Query Time Out', '1', 'Waiting time for the query response from sql server before closing it; Specify in seconds.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('PersistPath', '', '', 'S', 'Persist Path', '1', 'The path where persisting files are created; Dynamically obtains shoper share folder.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('TempPath', '', '', 'S', 'Temp Path', '1', 'The path where temp files are created; Dynamically obtains shoper share folder.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('PingInterval', '1', '1', 'N', 'Ping Interval', '1', 'The time interval by which the Shoper manager will ping (heart beat) the SIS; Specify in minutes.')
-GO-
INSERT [dbo].[SISSysParam] ([Code], [Value], [Default], [DataType], [DisplayName], [Status], [Description]) VALUES ('CheckInterval', '5', '5', 'N', 'Upload Check Interval', '1', 'The time interval by which the Shoper manager will check for pending upload jobs in SIS; Specify in minutes.')
-GO-
