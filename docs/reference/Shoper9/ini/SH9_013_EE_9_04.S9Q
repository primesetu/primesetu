<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0017</s9qScriptid> 
  <s9qtitle>Catalogue Module: Update JwlCaratage In Item Master</s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype> 
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 

  <s9qScript>
update dbo.Itemmaster set JwlCaratage = 0 Where JwlCaratage <> 0
  </s9qScript>

