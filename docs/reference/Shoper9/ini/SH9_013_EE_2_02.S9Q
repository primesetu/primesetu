INSERT INTO [dbo].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (4,3,'CREATE TABLE [dbo].[BAKPhyStockTakingItemBkUp] ([ScopeId] [int] NOT NULL ,[StockNo] [varchar] (50)   NOT NULL ,[BatchSrlNo] [varchar] (50)   NOT NULL ,[ItemDesc] [varchar] (75)   NULL , [CurrCost] [money] NULL ,[MRP] [money] NULL ,[SOH] [real] NULL ,[PhyStock] [real] NULL ,[DiffQty] [real] NULL ,[UpdtFlag] [int] NULL ,[PhyStkBatchNo] [varchar] (16)   NULL ,[PageNo] [int] NULL ,[RecDt] [datetime] NULL ,[RecTime] [datetime] NULL ,[LocId] [varchar] (50)   NULL ,[SC1Cd] [varchar] (50)   NULL ,[SC1Desc] [varchar] (256)   NULL ,[SC2Cd] [varchar] (50)   NULL ,[SC2Desc] [varchar] (256)   NULL ,[Cls1Cd] [varchar] (50)   NULL ,[Cls1Desc] [varchar] (256)   NULL ,[Cls2Cd] [varchar] (50)   NULL ,[Cls2Desc] [varchar] (256)   NULL ,[SubCls1Cd] [varchar] (50)   NULL ,[SubCls1Desc] [varchar] (50)   NULL ,[SubCls2Cd] [varchar] (50)   NULL ,[SubCls2Desc] [varchar] (50)   NULL ,[SizeCd] [varchar] (50)   NULL ,[UserId] [varchar] (100)   NULL ,[VAUid] [varchar] (32)   NULL ,[VActr] [int] NULL ,[VATermId] [varchar] (32)   NULL ,[VACompCode] [varchar] (16)   NULL ,[SHOPERDBVER] [Int] NULL ,[StkTakeMode] VARCHAR(64) NULL,[UpdFlag] [varchar] (1)   NULL ) ON [PRIMARY]','',1,'.','')
-GO-
Update [dbo].VersionwiseTblsScript Set Vactr = (select intg from dbo.sysparam where paramcode = 'VaSysCounter') where VerId=4
-GO-

</S9QSCRIPT>
</S9QSQLBLK>

