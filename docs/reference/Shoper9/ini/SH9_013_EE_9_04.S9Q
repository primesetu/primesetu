-GO-
UPDATE dbo.CUSTOMERS SET CUSTPROF3 = '.'  Where  CUSTPROF3 IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET CUSTPROF4 = '.'  Where  CUSTPROF4 IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET CUSTPROF5 = '.'  Where  CUSTPROF5 IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET SHOPERENV = 'R-Y'  Where  SHOPERENV IS NULL
-GO-
UPDATE dbo.CUSTOMERS SET ATTACHEDTOCD = 'NA'  Where  ATTACHEDTOCD IS NULL
