Update VaSecurityConfig Set Fixed = 'Hidden' Where Category ='Node Configuration'

-GO-

Update VaSecurityConfig Set Boolean = 1 Where ParamCode ='NodeAc1Present'

-GO-

Update VaSecurityConfig Set Boolean = 0 Where ParamCode ='NodeAc2Present'

-GO-

Update VaSecurityConfig Set Txt = 'CENTER CASH POINT' Where ParamCode ='NodeAc1Caption'

-GO-

Update VaSecurityConfig Set Txt = 'CASH COLLECTION POINT' Where ParamCode ='NodeAc2Caption'

-GO-

