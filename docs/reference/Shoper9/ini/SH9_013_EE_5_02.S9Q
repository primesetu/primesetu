  SET @SQUERY = 'UPDATE TMPPRICEMASTER SET ANALDESC26 = A.DESCR FROM '+@DBNAME+'.GENLOOKUP AS A,TMPPRICEMASTER AS B WHERE A.CODE = B.ANALCODE26 AND A.RECID = 7020'              
  EXEC (@SQUERY)               
  SET @SQUERY = 'UPDATE TMPPRICEMASTER SET ANALDESC27 = A.DESCR FROM '+@DBNAME+'.GENLOOKUP AS A,TMPPRICEMASTER AS B WHERE A.CODE = B.ANALCODE27 AND A.RECID = 7021'              
  EXEC (@SQUERY)               
  SET @SQUERY = 'UPDATE TMPPRICEMASTER SET ANALDESC28 = A.DESCR FROM '+@DBNAME+'.GENLOOKUP AS A,TMPPRICEMASTER AS B WHERE A.CODE = B.ANALCODE28 AND A.RECID = 7022'              
  EXEC (@SQUERY)               
  SET @SQUERY = 'UPDATE TMPPRICEMASTER SET ANALDESC29 = A.DESCR FROM '+@DBNAME+'.GENLOOKUP AS A,TMPPRICEMASTER AS B WHERE A.CODE = B.ANALCODE29 AND A.RECID = 7023'              
