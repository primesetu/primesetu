IF @insertflag = 1          
Begin                                                              
 insert into itemmaster(StockNo,BatchSrlNo,Class1Cd,Class2Cd,VaUid,DateInsert)                                                             
 select Distinct StockNo,BatchSrlNo,'','','SUPER',GETDATE() From TmpPricemaster                                      
 WHERE StockNo NOT IN (SELECT DISTINCT StockNo From ItemMaster)                                                
 IF (@@ERROR <> 0)                                     
 BEGIN                                     
  GOTO ErrorHandle                                     
 END                      
End         
         
         
if @insertflag = 1          
Begin          
 Update ITEMMASTER Set Class1Cd=t.Class1Cd,Class2Cd=t.Class2Cd,SubClass1Cd=t.SubClass1Cd,                                                             
 SubClass2Cd=t.SubClass2Cd,SizeCd=t.SizeCd,Retail_Price=t.Retail_Price,LastPurchPrice=t.LastPurchPrice,Dealer_Price=t.Dealer_Price,currentcost= t.currentcost,          
 Leastsalableqty=t.Leastsalableqty,ISRPTAXINCLUSIVE=T.ISRPTAXINCLUSIVE,REGULARIND=T.REGULARIND,GRADECD=T.GRADECD,                                     
 ItemDesc=t.ItemDesc,ProdTaxType=t.ProdTaxType,AnalCode1=t.AnalCode1,AnalCode2=t.AnalCode2,AnalCode3=t.AnalCode3,AnalCode4=t.AnalCode4,                                              
 AnalCode5=t.AnalCode5,AnalCode6=t.AnalCode6,AnalCode7=t.AnalCode7,AnalCode8=t.AnalCode8,AnalCode9=t.AnalCode9,                                                    
 AnalCode10=t.AnalCode10,AnalCode11=t.AnalCode11,AnalCode12=t.AnalCode12,AnalCode13=t.AnalCode13,AnalCode14=t.AnalCode14,                                                    
 AnalCode15=t.AnalCode15,AnalCode16=t.AnalCode16,AnalCode17=t.AnalCode17,AnalCode18=t.AnalCode18,AnalCode19=t.AnalCode19,                                                    
 AnalCode20=t.AnalCode20,AnalCode21=t.AnalCode21,AnalCode22=t.AnalCode22,AnalCode23=t.AnalCode23,AnalCode24=t.AnalCode24,                                                    
 AnalCode25=t.AnalCode25,AnalCode26=t.AnalCode26,AnalCode27=t.AnalCode27,AnalCode28=t.AnalCode28,AnalCode29=t.AnalCode29,                                                    
 AnalCode30=t.AnalCode30,AnalCode31=t.AnalCode31,AnalCode32=t.AnalCode32,                                     
 IMAGEPRESENT = t.IMAGEPRESENT,ISINVENTORYITEM = t.ISINVENTORYITEM,SRCTAXTYPE = t.SRCTAXTYPE,                                     
 EXTDESCPRESENT = t.EXTDESCPRESENT,EOQ= t.EOQ,MINORDQTY = t.minordqty,ISBILLABLE = t.ISBILLABLE,                                     
 ISSERVICE = t.ISSERVICE,BATCHSRLNO = t.BATCHSRLNO From TmpPriceMaster as t          
 inner join ITEMMASTER as i on t.StockNo = i.StockNo and i.class1cd = ''         
 IF (@@ERROR <> 0)                                     
     BEGIN              
     GOTO ErrorHandle                                     
   END                                           
End         
         
if @updatepriceflag = 1          
 begin         
 update itemmaster set currentcost= t.currentcost, Retail_Price=t.Retail_Price,
	LastPurchPrice=t.LastPurchPrice,Dealer_Price=t.Dealer_Price,DateInsert = GetDate() 
	From TmpPriceMaster as t inner join ITEMMASTER as i on t.StockNo = i.StockNo          
 IF (@@ERROR <> 0)                                     
 BEGIN                                     
    GOTO ErrorHandle                                     
 END                      
end         
         
if @updateflag = 1          
Begin          
 Update ITEMMASTER Set DateInsert = GetDate(),VActr = @vaCtr From TmpPriceMaster as t inner join ITEMMASTER as i on          
 t.StockNo = i.StockNo where (i.Class1Cd<>t.Class1Cd or i.Class2Cd <> t.Class2Cd or i.SubClass1Cd<>t.SubClass1Cd or         
 i.SubClass2Cd<>t.SubClass2Cd or i.SizeCd<>t.SizeCd or i.Leastsalableqty<>t.Leastsalableqty or         
 i.ISRPTAXINCLUSIVE<>T.ISRPTAXINCLUSIVE or i.REGULARIND<>T.REGULARIND or i.GRADECD<>T.GRADECD or         
 i.ItemDesc<>t.ItemDesc or i.ProdTaxType<>t.ProdTaxType or i.AnalCode1<>t.AnalCode1 or i.AnalCode2<>t.AnalCode2 or i.AnalCode3<>t.AnalCode3 or i.AnalCode4<>t.AnalCode4 or         
 i.AnalCode5<>t.AnalCode5 or i.AnalCode6<>t.AnalCode6 or i.AnalCode7<>t.AnalCode7 or i.AnalCode8<>t.AnalCode8 or i.AnalCode9<>t.AnalCode9 or          
 i.AnalCode10<>t.AnalCode10 or i.AnalCode11<>t.AnalCode11 or i.AnalCode12<>t.AnalCode12 or i.AnalCode13<>t.AnalCode13 or i.AnalCode14<>t.AnalCode14 or         
 i.AnalCode15<>t.AnalCode15 or i.AnalCode16<>t.AnalCode16 or i.AnalCode17<>t.AnalCode17 or i.AnalCode18<>t.AnalCode18 or i.AnalCode19<>t.AnalCode19 or         
 i.AnalCode20<>t.AnalCode20 or i.AnalCode21<>t.AnalCode21 or i.AnalCode22<>t.AnalCode22 or i.AnalCode23<>t.AnalCode23 or i.AnalCode24<>t.AnalCode24 or         
 i.AnalCode25<>t.AnalCode25 or i.AnalCode26<>t.AnalCode26 or i.AnalCode27<>t.AnalCode27 or i.AnalCode28<>t.AnalCode28 or i.AnalCode29<>t.AnalCode29 or         
 i.AnalCode30<>t.AnalCode30 or i.AnalCode31<>t.AnalCode31 or i.AnalCode32<>t.AnalCode32 or         
 i.IMAGEPRESENT <> t.IMAGEPRESENT or i.ISINVENTORYITEM <> t.ISINVENTORYITEM or i.SRCTAXTYPE <> t.SRCTAXTYPE or         
 i.EXTDESCPRESENT <> t.EXTDESCPRESENT or i.EOQ<> t.EOQ or i.MINORDQTY <> t.minordqty or i.ISBILLABLE <> t.ISBILLABLE or         
 i.ISSERVICE <> t.ISSERVICE or i.BATCHSRLNO <> t.BATCHSRLNO)         
         
 IF (@@ERROR <> 0)                                     
 BEGIN              
  GOTO ErrorHandle                                     
 END                  
End       
         
if @updateflag = 1          
Begin          
         
 Update ITEMMASTER Set Class1Cd=t.Class1Cd,Class2Cd=t.Class2Cd,SubClass1Cd=t.SubClass1Cd,                                                             
 SubClass2Cd=t.SubClass2Cd,SizeCd=t.SizeCd,Leastsalableqty=t.Leastsalableqty,                                                             
 ISRPTAXINCLUSIVE=T.ISRPTAXINCLUSIVE,REGULARIND=T.REGULARIND,GRADECD=T.GRADECD,                                     
 ItemDesc=t.ItemDesc,ProdTaxType=t.ProdTaxType,AnalCode1=t.AnalCode1,AnalCode2=t.AnalCode2,AnalCode3=t.AnalCode3,AnalCode4=t.AnalCode4,                                                    
 AnalCode5=t.AnalCode5,AnalCode6=t.AnalCode6,AnalCode7=t.AnalCode7,AnalCode8=t.AnalCode8,AnalCode9=t.AnalCode9,                                                    
 AnalCode10=t.AnalCode10,AnalCode11=t.AnalCode11,AnalCode12=t.AnalCode12,AnalCode13=t.AnalCode13,AnalCode14=t.AnalCode14,                                                    
 AnalCode15=t.AnalCode15,AnalCode16=t.AnalCode16,AnalCode17=t.AnalCode17,AnalCode18=t.AnalCode18,AnalCode19=t.AnalCode19,                                                    
 AnalCode20=t.AnalCode20,AnalCode21=t.AnalCode21,AnalCode22=t.AnalCode22,AnalCode23=t.AnalCode23,AnalCode24=t.AnalCode24,                                                    
 AnalCode25=t.AnalCode25,AnalCode26=t.AnalCode26,AnalCode27=t.AnalCode27,AnalCode28=t.AnalCode28,AnalCode29=t.AnalCode29,                                                    
 AnalCode30=t.AnalCode30,AnalCode31=t.AnalCode31,AnalCode32=t.AnalCode32,                                     
 IMAGEPRESENT = t.IMAGEPRESENT,ISINVENTORYITEM = t.ISINVENTORYITEM,SRCTAXTYPE = t.SRCTAXTYPE,                                     
 EXTDESCPRESENT = t.EXTDESCPRESENT,EOQ= t.EOQ,MINORDQTY = t.minordqty,ISBILLABLE = t.ISBILLABLE,                                     
 ISSERVICE = t.ISSERVICE,BATCHSRLNO = t.BATCHSRLNO                                     
 From TmpPriceMaster as t inner join ITEMMASTER as i on t.StockNo = i.StockNo                                     
 IF (@@ERROR <> 0)                                     
 BEGIN              
  GOTO ErrorHandle                                     
 END                                           
                                   
End         
                                                             
INSERT INTO CLASS12COMBO(Class1Cd,Class2Cd,VAUid,DateInsert)                                                             
select Distinct Class1Cd,Class2Cd,'SUPER',GETDATE() From TmpPricemaster WHERE                                                              
CLASS1CD+CLASS2CD NOT IN (SELECT DISTINCT CLASS1CD+CLASS2CD FROM class12combo)                                                             
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                      
UPDATE CLASS12COMBO SET SizeGroup = t.SizeGroupId,PrefVendorId=t.VendorCode,
ProdTaxType=t.ProdTaxType,SuperClass1=t.SuperClass1,SuperClass2=t.SuperClass2,VActr = @vaCtr
From TmpPriceMaster as t inner join CLASS12COMBO as c                                                             
on t.CLASS1CD = c.CLASS1CD and t.CLASS2CD = c.CLASS2CD 
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                                           
INSERT INTO SUBCLASS1CAT(Class1Cd,Class2Cd,SubClass1Cd,SubClass1Desc,VAUid,Lastupdateddate,Dateinsert)                                                             
SELECT DISTINCT Class1Cd,Class2Cd,SubClass1Cd,'','SUPER',GETDATE(),GETDATE() FROM TmpPricemaster                                                             
WHERE Class1Cd+Class2Cd+SubClass1Cd NOT IN (SELECT DISTINCT CLASS1CD+CLASS2CD+SUBCLASS1CD FROM SUBCLASS1CAT )                                                             
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                                 
UPDATE SUBCLASS1CAT Set SubClass1Desc=t.SubClass1Desc,ProdTaxType=t.ProdTaxType,                                                             
AnalCode1=t.AnalCode1,AnalCode2=t.AnalCode2,AnalCode3=t.AnalCode3,AnalCode4=t.AnalCode4,                                                             
AnalCode5=t.AnalCode5,AnalCode6=t.AnalCode6,AnalCode7=t.AnalCode7,AnalCode8=t.AnalCode8,AnalCode9=t.AnalCode9,                                                    
AnalCode10=t.AnalCode10,AnalCode11=t.AnalCode11,AnalCode12=t.AnalCode12,AnalCode13=t.AnalCode13,AnalCode14=t.AnalCode14,                                                    
AnalCode15=t.AnalCode15,AnalCode16=t.AnalCode16,AnalCode17=t.AnalCode17,AnalCode18=t.AnalCode18,AnalCode19=t.AnalCode19,                                     
AnalCode20=t.AnalCode20,AnalCode21=t.AnalCode21,AnalCode22=t.AnalCode22,AnalCode23=t.AnalCode23,AnalCode24=t.AnalCode24,                                                    
AnalCode25=t.AnalCode25,AnalCode26=t.AnalCode26,AnalCode27=t.AnalCode27,AnalCode28=t.AnalCode28,AnalCode29=t.AnalCode29,                                                    
AnalCode30=t.AnalCode30,AnalCode31=t.AnalCode31,AnalCode32=t.AnalCode32,LastUpdatedDate=GetDate(),VActr = @vaCtr                          
FROM TmpPriceMaster as t inner join SUBCLASS1CAT as sc1 on t.Class1Cd = sc1.Class1Cd and t.Class2Cd = sc1.Class2Cd                         
and t.SubClass1Cd = sc1.SubClass1Cd                            
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                                             
UPDATE SUBCLASS1CAT Set SubClass1Desc=t.SubClass1Desc,ProdTaxType=t.ProdTaxType,                                                             
AnalCode1=t.AnalCode1,AnalCode2=t.AnalCode2,AnalCode3=t.AnalCode3,AnalCode4=t.AnalCode4,                                                             
AnalCode5=t.AnalCode5,VActr = @vaCtr FROM TmpPriceMaster as t inner join SUBCLASS1CAT as sc1 on                      
t.Class1Cd = sc1.Class1Cd and t.Class2Cd = sc1.Class2Cd and t.SubClass1Cd = sc1.SubClass1Cd                           
where sc1.SubClass1Desc = '' and sc1.AnalCode1 Is NULL and sc1.AnalCode2 Is NULL and                                                     
sc1.AnalCode3 is NULL and sc1.AnalCode4 Is Null and sc1.AnalCode5 Is NULL                            
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                                           
INSERT INTO SUBCLASS2CAT(Class1Cd,Class2Cd,SubClass2Cd,SubClass2Desc,VAUid,DateInsert)                                                             
SELECT DISTINCT Class1Cd,Class2Cd,SubClass2Cd,'','SUPER',GETDATE() FROM TmpPricemaster                                                              
WHERE Class1Cd+Class2Cd+SubClass2Cd NOT IN (SELECT DISTINCT CLASS1CD+CLASS2CD+SUBCLASS2CD FROM SUBCLASS2CAT)                                                             
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                                    
UPDATE SUBCLASS2CAT SET SubClass2Desc=t.SubClass2Desc,VActr = @vaCtr FROM TmpPriceMaster as t inner join SUBCLASS2CAT as sc2                          
on t.Class1Cd = sc2.CLASS1CD and t.Class2Cd= sc2.CLASS2CD and t.SubClass2Cd = sc2.SUBCLASS2CD where sc2.SubClass2Desc = ''                          
IF (@@ERROR <> 0)                                     
BEGIN                  
 GOTO ErrorHandle                                     
END                               
                                  
Select * into #TmpSizeCat from SizeCat where 1=2            
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
INSERT INTO #TmpSizeCat (Class1Cd,Class2Cd,SizeCd,SizeGroupId,VAUid)                                                   
select Distinct CLASS1CD,CLASS2CD,SIZECD,'','SUPER' FROM TmpPricemaster                                                             
WHERE CLASS1CD+CLASS2CD+SIZECD NOT IN (SELECT DISTINCT CLASS1CD+CLASS2CD+Sizecd                           
FROM Sizecat) order by class1cd,class2cd,sizecd                                                       
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
                                   
UPDATE #TmpSizeCat SET IsPivotalSize=0,SizeGroupId = IsNULL(t.SizeGroupId,0),                                                      
SizeGroupSrlNo=t.SizeGroupSrlNo,IdealStockRatioQty = '0'                                              
FROM TmpPricemaster as t inner join #TmpSizeCat as sz on t.CLASS1CD=sz.CLASS1CD and t.CLASS2CD = sz.CLASS2CD                         
and t.SIZECD=sz.Sizecd where sz.SizeGroupId = ''                                                             
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END               
Update #TmpSizeCat set SizeGroupSrlNo=0 from #TmpSizeCat as T,SizeCat as S where S.Class1Cd=T.Class1Cd             
and S.Class2Cd=T.Class2Cd and S.SizeGroupSrlNo=T.SizeGroupSrlNo            
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END               
INSERT INTO SIZECAT (Class1Cd,Class2Cd,SizeCd,SizeGroupId,SizeGroupSrlNo,IdealStockRatioQty,            
VAUid)                                             
select Class1Cd,Class2Cd,SizeCd,SizeGroupId,SizeGroupSrlNo,IdealStockRatioQty,            
VAUid FROM #TmpSizeCat where SizeGroupSrlNo<>0                                                            
order by class1cd,class2cd,sizecd                                                       
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                           
Delete from #TmpSizeCat where SizeGroupSrlNo<>0            
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                  
Update #TmpSizeCat set SizeGroupSrlNo=0            
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                  
declare SizeGroupNum_cursor cursor for select Class1cd,Class2Cd,SizeCd from #TmpSizeCat where isnumeric(sizecd) =1 order by class1cd,class2cd,convert(numeric(10),sizecd)            
declare SizeGroupAlp_cursor cursor for select Class1cd,Class2Cd,SizeCd from #TmpSizeCat where isnumeric(sizecd) <>1 order by class1cd,class2cd,Sizecd            
set @SrlNo=0            
set @strClass1CdPrev=''         
set @strClass2CdPrev =''            
open SizeGroupNum_cursor                    
fetch next from SizeGroupNum_cursor into @strClass1Cd,@strClass2Cd,@strSizeCd            
while @@fetch_Status=0                    
begin                    
             
 if (@strClass1Cd<>@strClass1CdPrev or @strClass2Cd<>@strClass2CdPrev)            
 begin            
  Select @SrlNo=(select isnull(max(isnull(SizeGroupSrlNo,0)),0) from Sizecat where Class1cd= @strClass1Cd and Class2Cd= @strClass2Cd)            
  IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
  END                  
  set @strClass1CdPrev=@strClass1Cd            
  set @strClass2CdPrev=@strClass2Cd            
 end            
 set @SrlNo=@SrlNo+1            
 Update #TmpSizeCat set SizeGroupSrlNo=@SrlNo where Class1cd=@strClass1Cd and Class2Cd=@strClass2Cd and SizeCd=@strSizeCd            
 IF (@@ERROR <> 0)                                     
 BEGIN                                     
  GOTO ErrorHandle                                     
 END                   
 fetch next from SizeGroupNum_cursor into @strClass1Cd,@strClass2Cd,@strSizeCd            
end            
close SizeGroupNum_cursor                    
deallocate SizeGroupNum_cursor                 
set @SrlNo=0            
set @strClass1CdPrev=''            
set @strClass2CdPrev =''            
open SizeGroupAlp_cursor                    
fetch next from SizeGroupAlp_cursor into @strClass1Cd,@strClass2Cd,@strSizeCd            
while @@fetch_Status=0                    
begin                    
 if (@strClass1Cd<>@strClass1CdPrev or @strClass2Cd<>@strClass2CdPrev )            
 begin            
  Select @SrlNo=(select isnull(max(isnull(SizeGroupSrlNo,0)),0) from Sizecat where Class1cd= @strClass1Cd and Class2Cd= @strClass2Cd)            
  IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
  END                  
  set @strClass1CdPrev=@strClass1Cd            
  set @strClass2CdPrev=@strClass2Cd            
 end            
 set @SrlNo=@SrlNo+1            
 Update #TmpSizeCat set SizeGroupSrlNo=@SrlNo where Class1cd=@strClass1Cd and Class2Cd=@strClass2Cd and SizeCd=@strSizeCd            
 IF (@@ERROR <> 0)                                     
 BEGIN                                     
  GOTO ErrorHandle                                     
 END                  
             
 fetch next from SizeGroupAlp_cursor into @strClass1Cd,@strClass2Cd,@strSizeCd           
end            
close SizeGroupAlp_cursor                    
deallocate SizeGroupAlp_cursor                 
         
INSERT INTO SIZECAT (Class1Cd,Class2Cd,SizeCd,SizeGroupId,IsPivotalSize,SizeGroupSrlNo,IdealStockRatioQty,            
VAUid,VActr)                                                   
select CLASS1CD,CLASS2CD,SIZECD,SizeGroupId,IsPivotalSize,SizeGroupSrlNo,IdealStockRatioQty,VAUid,@vaCtr
 FROM #TmpSizeCat where SizeGroupSrlNo<>0                                                            
order by class1cd,class2cd,sizecd                                                       
