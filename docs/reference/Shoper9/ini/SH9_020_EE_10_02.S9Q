<s9qsqlblk>
<s9qScriptID>S9Q_020_10_0004</s9qScriptID>
<s9qtitle>Security Database Script</s9qtitle>
<s9qpgmtype>I</s9qpgmtype>
<s9qpgmtype>L</s9qpgmtype>
<s9qversion>*</s9qversion>
<s9qenvironment>M</s9qenvironment>
<s9qRunMultiple>1</s9qRunMultiple>
<s9qQryType>DML</s9qQryType>
<s9qScript>

insert into VaSecurityConfig(id,Descr,ParamCode,Boolean,Opt,Fixed,Category,CatSrlNo,ParamSrlNo)
values('Sec-000023','Allow Dashboard Report Selection','AllowDashboardReportSelection',1,'B','Variable','Housekeeping',3,5)
-GO-	
If NOT exists (select * from VaGenlookup where Recid = 103 and Code='DashBoardRestrict')
Insert into VaGenlookup(Recid,Code,Descr,Flag,Number) Values(103,'DashBoardRestrict','Restrict users from selecting Dashboard Reports',1,3)
-GO-
CREATE TABLE [dbo].[BrowseSettings](
	[BrowseID] [varchar](16) NULL,
	[BrowseType] [varchar](64) NULL,
	[BrowseName] [varchar](16) NULL,
	[UserId] [varchar](16) NULL,
	[AppName] [varchar](32) NULL,
	[TrnType] [int] NULL,
	[FldName] [varchar](64) NULL,
	[FldCaption] [varchar](64) NULL,
	[FldType] [varchar](16) NULL,
	[FldEnabled] [bit] NULL,
	[DispInBrowse] [bit] NULL,
	[DispInFilter] [bit] NULL,
	[DispInResult] [bit] NULL,
	[AlowFilter] [bit] NULL,
	[Condition] [varchar](16) NULL,
	[SearchVal1] [varchar](1000) NULL,
	[SearchVal2] [varchar](1000) NULL,
	[OthValue] [varchar](1000) NULL,
	[SortOrder] [int] NULL,
	[VaUid] [varchar](32) NULL,
	[VaCtr] [int] NULL,
	[VaTermId] [varchar](32) NULL,
	[VaCompCode] [varchar](16) NULL
) ON [PRIMARY]

-GO-
