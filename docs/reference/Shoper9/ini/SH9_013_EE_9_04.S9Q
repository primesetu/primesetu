<s9qsqlblk>
  <s9qScriptid>S9Q_013_9_0032</s9qScriptid> 
  <s9qtitle>Catalogue Module: Sales Tax Revision Data Modifications </s9qtitle> 
  <s9qpgmtype>D</s9qpgmtype>
  <s9qversion>*</s9qversion> 
  <s9qenvironment>P</s9qenvironment> 
  <s9qRunMultiple>0</s9qRunMultiple> 
  <s9qQryType>DML</s9qQryType> 
  <s9qScript>

Update [dbo].[SalesTaxCat] Set TaxRevisionId = 0, ShowRoomCode ='0'
-GO-
Update [dbo].[SalesTaxCat] Set EffectiveDate = '2010-04-01',AppliedDate='2010-04-01'
-GO-
INSERT INTO [dbo].VersionDtls VALUES (4,getdate(),'9','1.3','A','P901130','',1,'.','')
-GO-
Update [dbo].VersionDtls Set Vactr = (select intg from [dbo].sysparam where paramcode = 'VaSysCounter') where VerId=4
-GO-
INSERT INTO [dbo].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (4,9,'Alter Table [dbo].[SalesTaxCat] Add EffectiveDate datetime','',1,'.','')
-GO-
INSERT INTO [dbo].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (4,10,'Alter Table [dbo].[SalesTaxCat] Add AppliedDate datetime','',1,'.','')
-GO-
INSERT INTO [dbo].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (4,11,'Alter Table [dbo].[SalesTaxCat] Add DateInsert datetime','',1,'.','')
-GO-
INSERT INTO [dbo].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (4,12,'Alter Table [dbo].[SalesTaxCat] Add ShowRoomCode varchar(32) NULL','',1,'.','')
-GO-
INSERT INTO [dbo].VersionwiseTblsScript(VerID,SrlNo,TblScript,VAUid,VActr,VATermId,VACompCode) VALUES (4,13,'Alter Table [dbo].[SalesTaxRevision] Add DateInsert datetime','',1,'.','')
-GO-
