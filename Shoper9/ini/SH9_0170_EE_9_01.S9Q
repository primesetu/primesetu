CREATE PROCEDURE DataLoadPriceMaster @returnValue INT OUTPUT,@LogRunNumber int = 0,   
@insertflag int =1,@updateflag int =1,@updatepriceflag int = 1   
as                                                
Declare @updtctr as int                                                
Declare @strexe as varchar(500)                                               
Declare @AnalCount as int                    
Declare @RunNumber as int                              
Declare @RecCount As int                     
declare @strClass1Cd as varchar(16)            
declare @strClass2Cd as varchar(16)            
declare @strClass1CdPrev as varchar(16)            
declare @strClass2CdPrev as varchar(16)            
declare @strSizeCd as varchar(16)            
declare @SrlNo as int       
declare @vaCtr as int       
Begin transaction                                               
         
Select @vaCtr = Intg from Sysparam where paramcode = 'VaSysCounter'

set @RunNumber = @LogRunNumber  
if @LogRunNumber = 0   
begin                  
   select @RunNumber = isnull(Max(RunNumber),0)+ 1  From IniLoadingErrorLog  
end  
                    
select @RecCount = Count(*) From TmpPriceMaster where CurrentCost is null or currentcost = 0                     
if @RecCount > 0                      
     BEGIN                     
		 INSERT INTO IniLoadingErrorLog(RunNumber,RunDate,ErrorItem,ErrorRecords,ErrorDesc)                     
		 SELECT @RunNumber,GETDATE(),StockNo,1,'Record Deleted - Currentcost is zero' FROM TMPPRICEMASTER                     
		 WHERE CurrentCost is null or currentcost = 0                     
		 IF (@@ERROR <> 0)                                     
		 BEGIN                                     
		  GOTO ErrorHandle                                     
		 END                                     
		                    
		 DELETE FROM TMPPRICEMASTER WHERE CURRENTCOST IS NULL OR CURRENTCOST = 0                      
		 IF (@@ERROR <> 0)                                     
		 BEGIN                                     
		  GOTO ErrorHandle                                     
		 END                                     
     END                     
                    
select @RecCount = Count(*) From TmpPriceMaster where Retail_Price is null or Retail_Price = 0                     
if @RecCount > 0                     
     BEGIN                     
 INSERT INTO IniLoadingErrorLog(RunNumber,RunDate,ErrorItem,ErrorRecords,ErrorDesc)                     
 SELECT @RunNumber,GETDATE(),StockNo,1,'Record Deleted - Retail Price is zero' FROM TMPPRICEMASTER                     
 WHERE Retail_Price is null or Retail_Price = 0                     
 IF (@@ERROR <> 0)                                     
 BEGIN                                     
  GOTO ErrorHandle                                     
 END                                     
                    
 DELETE FROM TMPPRICEMASTER WHERE Retail_Price IS NULL OR Retail_Price = 0                      
     IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
  END                                     
     END                     
Set @RecCount = 0                              
SELECT @RecCount = count(*) FROM SYSPARAM WHERE PARAMCODE = 'AllowDealerPriceZeroPMImport' AND Boolean = 0                              
if @RecCount > 0                              
   begin                             
   select @RecCount = Count(*) From TmpPriceMaster where Dealer_Price is null or Dealer_Price = 0                     
   if @RecCount > 0                     
      BEGIN                     
   INSERT INTO IniLoadingErrorLog(RunNumber,RunDate,ErrorItem,ErrorRecords,ErrorDesc)                     
   SELECT @RunNumber,GETDATE(),StockNo,1,'Record Deleted - Dealer Price is zero' FROM TMPPRICEMASTER                     
   WHERE Dealer_Price is null or Dealer_Price = 0                     
   IF (@@ERROR <> 0)                                     
   BEGIN                                     
    GOTO ErrorHandle                                     
   END                                            
   DELETE FROM TMPPRICEMASTER WHERE Dealer_Price IS NULL OR Dealer_Price = 0                      
   IF (@@ERROR <> 0)                                     
   BEGIN                                     
    GOTO ErrorHandle                                     
   END                                     
      END                     
   end                  
                     
select @RecCount = Count(*) From TmpPriceMaster where Dealer_Price > Retail_Price                    
if @RecCount > 0                     
     BEGIN                     
  INSERT INTO IniLoadingErrorLog(RunNumber,RunDate,ErrorItem,ErrorRecords,ErrorDesc)                     
  SELECT @RunNumber,GETDATE(),StockNo,1,'Record Deleted - Dealer Price > Retail Price' FROM TMPPRICEMASTER                     
  WHERE Dealer_Price > Retail_Price                     
  IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
         END                                     
                    
  DELETE FROM TMPPRICEMASTER WHERE Dealer_Price > Retail_Price                       
  IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
  END                                     
     END                     
select @RecCount = Count(*) From TmpPriceMaster where ProdTaxtype is null or ProdTaxtype = ''               
if @RecCount > 0                     
  BEGIN                     
     INSERT INTO IniLoadingErrorLog(RunNumber,RunDate,ErrorItem,ErrorRecords,ErrorDesc)                     
     SELECT @RunNumber,GETDATE(),StockNo,1,'Record Deleted - Product Tax type is null' FROM TMPPRICEMASTER                     
     WHERE ProdTaxtype is null or ProdTaxtype = ''                     
     IF (@@ERROR <> 0)                                     
       BEGIN                                     
         GOTO ErrorHandle                                     
       END                                     
                    
     DELETE FROM TMPPRICEMASTER WHERE ProdTaxtype is null or ProdTaxtype = ''                      
     IF (@@ERROR <> 0)                                     
     BEGIN                                     
       GOTO ErrorHandle                                     
     END                                     
  END                     
select @RecCount = Count(*) From TmpPriceMaster where SizeGroupId is null or SizeGroupId = ''               
if @RecCount > 0                     
  BEGIN                     
     INSERT INTO IniLoadingErrorLog(RunNumber,RunDate,ErrorItem,ErrorRecords,ErrorDesc)                     
     SELECT @RunNumber,GETDATE(),StockNo,1,'Record Deleted - Size Group id is null' FROM TMPPRICEMASTER                     
     WHERE SizeGroupId is null or SizeGroupId = ''                     
     IF (@@ERROR <> 0)                                     
       BEGIN                                     
         GOTO ErrorHandle                                     
       END                                     
                    
     DELETE FROM TMPPRICEMASTER WHERE SizeGroupId is null or SizeGroupId = ''                      
     IF (@@ERROR <> 0)                                     
     BEGIN                                     
       GOTO ErrorHandle                                     
     END                                     
  END                     
                    
UPDATE TmpPriceMaster SET REGULARIND = '0' WHERE REGULARIND  ='Y'                                                      
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                               
UPDATE TmpPriceMaster SET REGULARIND = '1' WHERE REGULARIND  <> '0'                                                      
IF (@@ERROR <> 0)                       
 BEGIN                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET ISRPTAXINCLUSIVE ='1' where ISRPTAXINCLUSIVE is null                               
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                                
UPDATE TmpPriceMaster SET ISRPTAXINCLUSIVE ='1' where ISRPTAXINCLUSIVE ='Y'                   
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                                
                             
UPDATE TmpPriceMaster SET ISRPTAXINCLUSIVE ='0' where ISRPTAXINCLUSIVE <> '1'         
IF (@@ERROR <> 0)                                     
BEGIN                                     
GOTO ErrorHandle                                     
END                                                
                             
UPDATE TmpPriceMaster SET BATCHSRLNO = 0 WHERE BATCHSRLNO IS NULL                                                 
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET LEASTSALABLEQTY = 1 WHERE LEASTSALABLEQTY IS NULL OR LEASTSALABLEQTY = 0               
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
                    
UPDATE TmpPriceMaster SET SizeGroupSrlno = 0 WHERE SizeGroupSrlno IS NULL                                                 
IF (@@ERROR <> 0)                                     
BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET Stockno = 'NA' Where Stockno is null or Stockno = ''                    
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET Class1cd = 'NA' Where Class1cd is null or Class1Cd = ''                                                 
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET Class2cd = 'NA' Where Class2cd is null or Class2Cd = ''                                               
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SubClass1cd = 'NA' Where SubClass1cd is null or SubClass1Cd = ''                                                 
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SubClass2CD = 'NA' Where SubClass2CD is null or SubClass2Cd = ''                                               
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SizeCd = 'NA' Where Sizecd is null OR SizeCd = ''                                              
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET Class1Desc = Class1cd Where Class1Desc is null or Class1Desc = ''                                           
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET Class2Desc = Class2cd Where Class2Desc is null or Class2Desc =''                                               
IF (@@ERROR <> 0)                                  
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SubClass1Desc = SubClass1cd Where SubClass1Desc is null or SubClass1Desc =''    
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SubClass2Desc = SubClass2cd Where SubClass2Desc is null or SubClass2Desc =''    
IF (@@ERROR <> 0)               
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SizeGroupDesc = SizeGroupId Where SizeGroupDesc is null or SizeGroupDesc =''    
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET ProdTaxDesc = ProdTaxtype Where ProdTaxDesc is null or ProdTaxDesc =''    
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
                             
Set @AnalCount = 0                              
SELECT @AnalCount = count(*) FROM SYSPARAM WHERE PARAMCODE = 'SuperClass1Present' AND BOOLEAN = 1                              
if @AnalCount > 0                              
   begin                             
       UPDATE TmpPriceMaster SET SUPERCLASS1 = 'NA' WHERE SuperClass1 IS NULL OR SuperClass1 = ''                    
       IF (@@ERROR <> 0)                                     
       BEGIN                                     
         GOTO ErrorHandle                                     
       END                                     
   end                              
                             
Set @AnalCount = 0                              
SELECT @AnalCount = count(*) FROM SYSPARAM WHERE PARAMCODE = 'SuperClass2Present' AND BOOLEAN = 1                              
if @AnalCount > 0                              
   begin                             
     UPDATE TmpPriceMaster SET SUPERCLASS2 = 'NA' WHERE SuperClass2 IS NULL OR SuperClass2 =''                    
     IF (@@ERROR <> 0)                                     
     BEGIN                                     
        GOTO ErrorHandle                                     
    END                                     
   end                              
                             
UPDATE TmpPriceMaster SET SUPERCLASS1DESC = SUPERCLASS1 Where SUPERCLASS1DESC is null or SUPERCLASS1DESC =''                                                
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TmpPriceMaster SET SUPERCLASS2DESC = SUPERCLASS2 Where SUPERCLASS2DESC is null or SUPERCLASS2DESC = ''                                                
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                
    
UPDATE TMPPRICEMASTER SET ISRPTAXINCLUSIVE = 1 WHERE ISRPTAXINCLUSIVE IS NULL                                      
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle              
END                                     
UPDATE TMPPRICEMASTER SET IMAGEPRESENT = 0 WHERE IMAGEPRESENT IS NULL                                                       
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET ISINVENTORYITEM = 1 WHERE ISINVENTORYITEM IS NULL                                 
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET SRCTAXTYPE = 0 WHERE SRCTAXTYPE IS NULL or SRCTAXTYPE = ''    
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                    
END                                     
UPDATE TMPPRICEMASTER SET EXTDESCPRESENT = 0 WHERE EXTDESCPRESENT IS NULL                                                       
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET EOQ = 0 WHERE EOQ IS NULL                                                       
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                    
END                                     
UPDATE TMPPRICEMASTER SET MINORDQTY = 0 WHERE MINORDQTY IS NULL                                                       
IF (@@ERROR <> 0)                                     
 BEGIN                          
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET MINORDQTY = 0 WHERE MINORDQTY IS NULL                                        
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET ISBILLABLE = 1 WHERE ISBILLABLE IS NULL                                                       
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET ISSERVICE = 0 WHERE ISSERVICE IS NULL                                                       
IF (@@ERROR <> 0)                  
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET REGULARIND = 0 WHERE REGULARIND IS NULL                                                       
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
UPDATE TMPPRICEMASTER SET BATCHSRLNO = 0 WHERE BATCHSRLNO IS NULL                                                    
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
                                     
UPDATE TmpPriceMaster SET Stockno = LTRIM(RTRIM(Stockno)), Class1Cd = LTRIM(RTRIM(LEFT(Class1Cd,16))), Class2Cd = LTRIM(RTRIM(LEFT(Class2Cd,16))),                                     
 CLASS1DESC = LTRIM(RTRIM(CLASS1DESC)), CLASS2DESC = LTRIM(RTRIM(CLASS2DESC)), SUBCLASS1CD = LTRIM(RTRIM(LEFT(SUBCLASS1CD,16))),                                     
 SUBCLASS2CD = LTRIM(RTRIM(LEFT(SUBCLASS2CD,16))), SUBCLASS1DESC = LTRIM(RTRIM(SUBCLASS1DESC)), SUBCLASS2DESC = LTRIM(RTRIM(LEFT(SUBCLASS2DESC,50))),                                     
 SIZECD = LTRIM(RTRIM(LEFT(SIZECD,16))), ITEMDESC = LTRIM(RTRIM(ITEMDESC)), PRODTAXTYPE = LTRIM(RTRIM(LEFT(PRODTAXTYPE,16))),                                     
 PRODTAXDESC = LTRIM(RTRIM(PRODTAXDESC)),SIZEGROUPID = LTRIM(RTRIM(SIZEGROUPID)), SIZEGROUPDESC = LTRIM(RTRIM(LEFT(SIZEGROUPDESC,30))),                                     
 VENDORCODE = LTRIM(RTRIM(LEFT(VENDORCODE,16))),SUPERCLASS1 = LTRIM(RTRIM(left(SUPERCLASS1,16))),                                     
 SUPERCLASS2 = LTRIM(RTRIM(left(SUPERCLASS2,16))),SUPERCLASS1DESC = LTRIM(RTRIM(SUPERCLASS1DESC)),                                     
 SUPERCLASS2DESC = LTRIM(RTRIM(SUPERCLASS2DESC)),GRADECD = LTRIM(RTRIM(GRADECD)),BatchSrlNo = LTRIM(RTRIM(BatchSrlNo)),                                     
 SrcTaxType = LTRIM(RTRIM(SrcTaxType)),CCStockNo = LTRIM(RTRIM(CCStockNo))                                     
IF (@@ERROR <> 0)                                     
 BEGIN                                     
 GOTO ErrorHandle                                     
END                                     
                                               
set @updtctr = 1                 
WHILE @updtctr <= 32                                               
BEGIN                                
   Set @AnalCount = 0                              
   SELECT @AnalCount = count(*) FROM SYSPARAM WHERE PARAMCODE = 'ItemAnaCd'+convert(varchar,@updtctr)+'Present' AND BOOLEAN = 1                              
   if @AnalCount > 0                              
  begin                             
    set @strexe = 'UPDATE TmpPriceMaster SET ANALCODE' + CONVERT(VARCHAR,@updtctr)+' = '+CHAR(39)+'NA'+CHAR(39)+' WHERE ANALCODE' + CONVERT(VARCHAR,@updtctr) +' IS NULL OR ' + 'ANALCODE' + CONVERT(VARCHAR,@updtctr) + '=' +CHAR(39)+CHAR(39)               
  
    
     
    execute (@strexe)                               
           IF (@@ERROR <> 0)                                     
           BEGIN                                     
         GOTO ErrorHandle                                     
        END                                     
 end                              
   set @strexe = 'UPDATE TmpPriceMaster SET ANALCODE' + CONVERT(VARCHAR,@updtctr) + ' = LTRIM(RTRIM(ANALCODE' + CONVERT(VARCHAR,@updtctr) + '))'                                      
   execute (@strexe)                                               
 IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
 END                                     
   set @strexe = 'UPDATE TmpPriceMaster SET ANALDESC' + CONVERT(VARCHAR,@updtctr) + ' = LTRIM(RTRIM(ANALDESC' + CONVERT(VARCHAR,@updtctr) + '))'                                               
   execute (@strexe)                                               
 IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
  END                                     
   set @strexe = 'UPDATE TmpPriceMaster SET ANALDESC' + CONVERT(VARCHAR,@updtctr) + ' = ANALCODE' + CONVERT(VARCHAR,@updtctr) + ' Where ANALDESC' + CONVERT(VARCHAR,@updtctr) + ' is null'                                               
   execute (@strexe)                                               
 IF (@@ERROR <> 0)                                     
  BEGIN                                     
   GOTO ErrorHandle                                     
  END                                     
   set @strexe = 'UPDATE TmpPriceMaster SET ANALCODE' + CONVERT(VARCHAR,@updtctr) + ' = REPLACE(ANALCODE' + CONVERT(VARCHAR,@updtctr) + ',CHAR(39),' + CHAR(39) + CHAR(39)+ ')'                                               
   execute (@strexe)                                               
 IF (@@ERROR <> 0)                                     
  BEGIN                                     
                                     
  GOTO ErrorHandle                                     
 END                                     
   set @strexe = 'UPDATE TmpPriceMaster SET ANALDESC' + CONVERT(VARCHAR,@updtctr) + ' = REPLACE(ANALDESC' + CONVERT(VARCHAR,@updtctr) + ',CHAR(39),' + CHAR(39) + CHAR(39)+ ')'                                               
   execute (@strexe)                                               
    IF (@@ERROR <> 0)                                     
  BEGIN                                     
                                     
  GOTO ErrorHandle                                     
 END                                           
                                   
 set @strexe = 'UPDATE TmpPriceMaster SET ANALDESC' + CONVERT(VARCHAR,@updtctr) + ' = REPLACE(ANALDESC' + CONVERT(VARCHAR,@updtctr) + ',CHAR(13),' + CHAR(39) + CHAR(39)+ ')'                                               
   execute (@strexe)                                               
    IF (@@ERROR <> 0)                                     
  BEGIN                                     
                                     
  GOTO ErrorHandle                                     
 END                                           
                                       
 set @strexe = 'UPDATE TmpPriceMaster SET ANALCODE' + CONVERT(VARCHAR,@updtctr) + ' = REPLACE(ANALCODE' + CONVERT(VARCHAR,@updtctr) + ',CHAR(13),' + CHAR(39) + CHAR(39)+ ')'                                      
   execute (@strexe)                                               
    IF (@@ERROR <> 0)                                     
  BEGIN                                     
                                     
  GOTO ErrorHandle                                     
 END                                           
 set @strexe = 'UPDATE TmpPriceMaster SET ANALDESC' + CONVERT(VARCHAR,@updtctr) + ' = REPLACE(ANALDESC' + CONVERT(VARCHAR,@updtctr) + ',CHAR(10),' + CHAR(39) + CHAR(39)+ ')'                                               
   execute (@strexe)                                               
    IF (@@ERROR <> 0)                                     
  BEGIN                                     
                                     
  GOTO ErrorHandle                                     
 END                                           
                                       
 set @strexe = 'UPDATE TmpPriceMaster SET ANALCODE' + CONVERT(VARCHAR,@updtctr) + ' = REPLACE(ANALCODE' + CONVERT(VARCHAR,@updtctr) + ',CHAR(10),' + CHAR(39) + CHAR(39)+ ')'                                               
   execute (@strexe)                                               
    IF (@@ERROR <> 0)                                
  BEGIN                                     
                                     
  GOTO ErrorHandle                                     
 END                                  
                                     
   set @updtctr = @updtctr + 1                                        
END                                               
                                               
UPDATE TMPPRICEMASTER SET STOCKNO =  REPLACE(STOCKNO,CHAR(39),''),CLASS1CD =  REPLACE(CLASS1CD,CHAR(39),''),                                                
 CLASS2CD =  REPLACE(CLASS2CD,CHAR(39),''), SUBCLASS1CD =  REPLACE(SUBCLASS1CD,CHAR(39),''),                                                
 SUBCLASS2CD =  REPLACE(SUBCLASS2CD,CHAR(39),''), CLASS1DESC =  REPLACE(CLASS1DESC,CHAR(39),''),                              
 CLASS2DESC =  REPLACE(CLASS2DESC,CHAR(39),''), SUBCLASS1DESC =  REPLACE(SUBCLASS1DESC,CHAR(39),''),                                                
 SUBCLASS2DESC =  REPLACE(SUBCLASS2DESC,CHAR(39),''), SIZECD =  REPLACE(SIZECD,CHAR(39),''),                                                
 ITEMDESC =  REPLACE(ITEMDESC,CHAR(39),''), PRODTAXTYPE =  REPLACE(PRODTAXTYPE,CHAR(39),''),                                                
 PRODTAXDESC =  REPLACE(PRODTAXDESC,CHAR(39),''), SIZEGROUPID =  REPLACE(SIZEGROUPID,CHAR(39),''),                                                
 SIZEGROUPDESC =  REPLACE(SIZEGROUPDESC,CHAR(39),''), SUPERCLASS1 =  REPLACE(SUPERCLASS1,CHAR(39),''),                                                
 SUPERCLASS2 =  REPLACE(SUPERCLASS2,CHAR(39),''), SUPERCLASS1DESC =  REPLACE(SUPERCLASS1DESC,CHAR(39),''),                                          
